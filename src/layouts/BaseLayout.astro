---
import {
  SITE_KEYWORDS,
  SITE_NAME,
  SITE_OG_IMAGE_ALT,
  SITE_TWITTER_HANDLE,
  getImageMimeType,
  getMetaDescription,
  getSocialImageUrl,
  withBrandSuffix,
} from '@utils/site';

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  robots?: string;
  type?: 'website' | 'article';
  loadAds?: boolean;
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
  author?: string;
  wordCount?: number;
  section?: string;
  keywords?: string;
  breadcrumbs?: Breadcrumb[];
}

const {
  title,
  description,
  image,
  canonicalURL,
  robots = 'index, follow',
  type = 'website',
  loadAds = false,
  publishedTime,
  modifiedTime,
  author = 'bigroc',
  wordCount,
  section,
  keywords,
  breadcrumbs,
} = Astro.props;
const siteURL = Astro.site?.toString() || 'https://bigroc.cn';
const currentURL = canonicalURL || new URL(Astro.url.pathname, siteURL).toString();
const fullTitle = withBrandSuffix(title);
const metaDescription = getMetaDescription(description);
const socialImage = getSocialImageUrl(image, siteURL);
const socialImageType = getImageMimeType(image);
const publishedDate = publishedTime ? new Date(publishedTime).toISOString() : undefined;
const modifiedDate = modifiedTime ? new Date(modifiedTime).toISOString() : publishedDate;
const isToolPage = Astro.url.pathname.startsWith('/tools/') && Astro.url.pathname !== '/tools';
const tags = keywords ? keywords.split(',').map(t => t.trim()).filter(Boolean) : [];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="keywords" content={keywords || SITE_KEYWORDS} />
    <meta name="author" content="bigroc" />
    <meta name="robots" content={robots} />
    <meta name="language" content="zh-CN" />
    <meta name="revisit-after" content="7 days" />
    
    <!-- 百度站点验证 -->
    <meta name="baidu-site-verification" content="codeva-BssUIcgqU3" />
    
    <link rel="canonical" href={currentURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={currentURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    {socialImageType && <meta property="og:image:type" content={socialImageType} />}
    <meta property="og:image:alt" content={SITE_OG_IMAGE_ALT} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="zh_CN" />
    {type === 'article' && publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {type === 'article' && modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
    {type === 'article' && <meta property="article:author" content={author} />}
    {type === 'article' && section && <meta property="article:section" content={section} />}
    {type === 'article' && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={currentURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={SITE_OG_IMAGE_ALT} />
    <meta name="twitter:site" content={SITE_TWITTER_HANDLE} />
    <meta name="twitter:creator" content={SITE_TWITTER_HANDLE} />
    
    <!-- 结构化数据 (JSON-LD) -->
    {type === 'article' ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        'headline': fullTitle,
        'description': metaDescription,
        'url': currentURL,
        'image': socialImage,
        'datePublished': publishedDate,
        'dateModified': modifiedDate,
        'author': { '@type': 'Person', 'name': author, 'url': `${siteURL}about` },
        'publisher': {
          '@type': 'Organization',
          'name': SITE_NAME,
          'logo': { '@type': 'ImageObject', 'url': `${siteURL}favicon.svg` }
        },
        'mainEntityOfPage': { '@type': 'WebPage', '@id': currentURL },
        'inLanguage': 'zh-CN',
        ...(wordCount ? { 'wordCount': wordCount } : {}),
        ...(section ? { 'articleSection': section } : {}),
        ...(tags.length > 0 ? { 'keywords': tags.join(', ') } : {})
      })} />
    ) : isToolPage ? (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebApplication',
        'name': title,
        'url': currentURL,
        'description': metaDescription,
        'applicationCategory': 'DeveloperApplication',
        'operatingSystem': 'Web Browser',
        'offers': { '@type': 'Offer', 'price': '0', 'priceCurrency': 'CNY' },
        'inLanguage': 'zh-CN',
        'author': { '@type': 'Person', 'name': author, 'url': `${siteURL}about` },
        'publisher': {
          '@type': 'Organization',
          'name': SITE_NAME,
          'logo': { '@type': 'ImageObject', 'url': `${siteURL}favicon.svg` }
        }
      })} />
    ) : (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        'name': SITE_NAME,
        'url': siteURL,
        'description': metaDescription,
        'inLanguage': 'zh-CN',
        'publisher': {
          '@type': 'Organization',
          'name': SITE_NAME,
          'logo': { '@type': 'ImageObject', 'url': `${siteURL}favicon.svg` }
        },
        'potentialAction': {
          '@type': 'SearchAction',
          'target': { '@type': 'EntryPoint', 'urlTemplate': `${siteURL}search?q={search_term_string}` },
          'query-input': 'required name=search_term_string'
        }
      })} />
    )}

    {breadcrumbs && breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        'itemListElement': breadcrumbs.map((crumb, index) => ({
          '@type': 'ListItem',
          'position': index + 1,
          'name': crumb.name,
          'item': crumb.url
        }))
      })} />
    )}
    
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE_NAME} RSS`} href="/rss.xml" />
    <link rel="llms-txt" href="/llms.txt" />
    
    {loadAds && (
      <script is:inline>
        const ADSENSE_INIT_FLAG = '__bigrocAdsenseLoaded__';
        const ADSENSE_SRC =
          'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6550916586984251';

        const loadAdsense = () => {
          if (window[ADSENSE_INIT_FLAG]) {
            return;
          }

          window[ADSENSE_INIT_FLAG] = true;

          const script = document.createElement('script');
          script.async = true;
          script.src = ADSENSE_SRC;
          script.crossOrigin = 'anonymous';
          document.head.appendChild(script);
        };

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(loadAdsense, { timeout: 2000 });
        } else {
          window.addEventListener('load', loadAdsense, { once: true });
        }
      </script>
    )}
    
    <script is:inline>
      (() => {
        let theme = 'dark';

        try {
          theme = localStorage.getItem('theme') || theme;
        } catch {
          theme = 'dark';
        }

        document.documentElement.classList.toggle('dark', theme === 'dark');
      })();
    </script>
  </head>
  <body id="top" class="min-h-screen bg-slate-50 text-gray-900 antialiased transition-colors dark:bg-gray-950 dark:text-gray-100">
    <slot />

    <!-- 图片懒加载：所有 <img> 标签已使用原生 loading="lazy"，无需额外 JS -->
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --surface: 255 255 255;
    --surface-muted: 248 250 252;
    --ring: 37 99 235;
  }

  :root.dark {
    color-scheme: dark;
    --surface: 17 24 39;
    --surface-muted: 15 23 42;
    --ring: 96 165 250;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background-image:
      linear-gradient(180deg, rgba(248, 250, 252, 0.96), rgba(255, 255, 255, 0.88) 28rem),
      linear-gradient(90deg, rgba(15, 23, 42, 0.045) 1px, transparent 1px),
      linear-gradient(180deg, rgba(15, 23, 42, 0.045) 1px, transparent 1px);
    background-size: auto, 32px 32px, 32px 32px;
    background-attachment: fixed;
  }

  :root.dark body {
    background-image:
      linear-gradient(180deg, rgba(3, 7, 18, 0.98), rgba(15, 23, 42, 0.92) 28rem),
      linear-gradient(90deg, rgba(148, 163, 184, 0.07) 1px, transparent 1px),
      linear-gradient(180deg, rgba(148, 163, 184, 0.07) 1px, transparent 1px);
  }

  ::selection {
    background: rgba(37, 99, 235, 0.18);
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    outline: 2px solid rgb(var(--ring));
    outline-offset: 3px;
  }

  .surface-card {
    border: 1px solid rgba(148, 163, 184, 0.22);
    background: rgba(var(--surface), 0.82);
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.07);
    backdrop-filter: blur(16px);
  }

  .dark .surface-card {
    border-color: rgba(148, 163, 184, 0.14);
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.24);
  }

  .interactive-card {
    transform: translateY(0);
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease,
      background-color 220ms ease;
  }

  .interactive-card:hover {
    border-color: rgba(37, 99, 235, 0.34);
    box-shadow: 0 24px 65px rgba(15, 23, 42, 0.11);
    transform: translateY(-3px);
  }

  .dark .interactive-card:hover {
    border-color: rgba(96, 165, 250, 0.34);
    box-shadow: 0 24px 65px rgba(0, 0, 0, 0.32);
  }

  .animated-entry {
    animation: fade-slide-up 520ms ease both;
  }

  .animated-entry:nth-child(2) {
    animation-delay: 70ms;
  }

  .animated-entry:nth-child(3) {
    animation-delay: 140ms;
  }

  .animated-entry:nth-child(4) {
    animation-delay: 210ms;
  }

  .link-arrow svg {
    transition: transform 180ms ease;
  }

  .link-arrow:hover svg {
    transform: translateX(3px);
  }

  @keyframes fade-slide-up {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 1ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
      transition-duration: 1ms !important;
    }

    .interactive-card:hover {
      transform: none;
    }
  }
</style>
