---
import {
  SITE_KEYWORDS,
  SITE_NAME,
  SITE_OG_IMAGE_ALT,
  SITE_TWITTER_HANDLE,
  getImageMimeType,
  getMetaDescription,
  getSocialImageUrl,
  withBrandSuffix,
} from '@utils/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
  robots?: string;
  type?: 'website' | 'article';
  loadAds?: boolean;
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
}

const {
  title,
  description,
  image,
  canonicalURL,
  robots = 'index, follow',
  type = 'website',
  loadAds = false,
  publishedTime,
  modifiedTime,
} = Astro.props;
const siteURL = Astro.site?.toString() || 'https://bigroc.cn';
const currentURL = canonicalURL || new URL(Astro.url.pathname, siteURL).toString();
const fullTitle = withBrandSuffix(title);
const metaDescription = getMetaDescription(description);
const socialImage = getSocialImageUrl(image, siteURL);
const socialImageType = getImageMimeType(image);
const publishedDate = publishedTime ? new Date(publishedTime).toISOString() : undefined;
const modifiedDate = modifiedTime ? new Date(modifiedTime).toISOString() : publishedDate;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="keywords" content={SITE_KEYWORDS} />
    <meta name="author" content="bigroc" />
    <meta name="robots" content={robots} />
    <meta name="language" content="zh-CN" />
    <meta name="revisit-after" content="7 days" />
    
    <!-- 百度站点验证 -->
    <meta name="baidu-site-verification" content="codeva-BssUIcgqU3" />
    
    <link rel="canonical" href={currentURL} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={currentURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    {socialImageType && <meta property="og:image:type" content={socialImageType} />}
    <meta property="og:image:alt" content={SITE_OG_IMAGE_ALT} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="zh_CN" />
    {type === 'article' && publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {type === 'article' && modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={currentURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={SITE_OG_IMAGE_ALT} />
    <meta name="twitter:site" content={SITE_TWITTER_HANDLE} />
    <meta name="twitter:creator" content={SITE_TWITTER_HANDLE} />
    
    <!-- 结构化数据 (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Article",
        "name": "Blog Post",
        "description": "Blog post description",
        "url": "https://bigroc.cn",
        "publisher": {
          "@type": "Organization",
          "name": "大鹏的Log",
          "logo": {
            "@type": "ImageObject",
            "url": "https://bigroc.cn/favicon.svg"
          }
        },
        "author": {
          "@type": "Person",
          "name": "bigroc"
        }
      }
    </script>
    
    <link rel="sitemap" href="/sitemap-index.xml" />
    
    {loadAds && (
      <script is:inline>
        const ADSENSE_INIT_FLAG = '__bigrocAdsenseLoaded__';
        const ADSENSE_SRC =
          'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6550916586984251';

        const loadAdsense = () => {
          if (window[ADSENSE_INIT_FLAG]) {
            return;
          }

          window[ADSENSE_INIT_FLAG] = true;

          const script = document.createElement('script');
          script.async = true;
          script.src = ADSENSE_SRC;
          script.crossOrigin = 'anonymous';
          document.head.appendChild(script);
        };

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(loadAdsense, { timeout: 2000 });
        } else {
          window.addEventListener('load', loadAdsense, { once: true });
        }
      </script>
    )}
    
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'dark';
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>
  <body id="top" class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors">
    <slot />
    
    <!-- 图片懒加载 -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        // 检查浏览器是否支持 Intersection Observer
        if ('IntersectionObserver' in window) {
          const imageObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                const img = entry.target;
                const dataSrc = img.getAttribute('data-src');
                if (dataSrc) {
                  // 确保只在需要时更新 src
                  if (img.src !== dataSrc) {
                    img.src = dataSrc;
                  }
                  img.classList.remove('lazy');
                  imageObserver.unobserve(img);
                }
              }
            });
          }, {
            rootMargin: '50px 0px',
            threshold: 0.01
          });

          // 观察所有带有 data-src 属性的图片
          document.querySelectorAll('img[data-src]').forEach(img => {
            imageObserver.observe(img);
          });
        } else {
          // 降级方案：直接加载所有图片
          document.querySelectorAll('img[data-src]').forEach(img => {
            const dataSrc = img.getAttribute('data-src');
            if (dataSrc && img.src !== dataSrc) {
              img.src = dataSrc;
            }
            img.classList.remove('lazy');
          });
        }
      });
    </script>
  </body>
</html>
