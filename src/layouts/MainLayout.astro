---
import BaseLayout from './BaseLayout.astro';
import GiscusComments from '@components/GiscusComments.astro';
import PageLikeButton from '@components/PageLikeButton.astro';
import { isArticlePath } from '@utils/site';

interface Props {
  title: string;
  description?: string;
  image?: string;
  robots?: string;
  type?: 'website' | 'article';
  loadAds?: boolean;
  canonicalURL?: string;
  publishedTime?: Date | string;
  modifiedTime?: Date | string;
}

const {
  title,
  description,
  image,
  robots,
  type,
  loadAds,
  canonicalURL,
  publishedTime,
  modifiedTime,
} = Astro.props;
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isToolsSubpage = pathname.startsWith('/tools/') && pathname !== '/tools';
const isPromotionsSubpage = pathname.startsWith('/promotions/') && pathname !== '/promotions';
const showSubpageFeedback = isToolsSubpage || isPromotionsSubpage;
const defaultType = isArticlePath(pathname) ? 'article' : 'website';
const shouldLoadAds = loadAds ?? isArticlePath(pathname);
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  robots={robots}
  type={type ?? defaultType}
  loadAds={shouldLoadAds}
  canonicalURL={canonicalURL}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
>
  <a
    href="#main-content"
    class="sr-only absolute left-4 top-4 z-50 rounded-md bg-primary-600 px-4 py-2 text-white shadow focus:not-sr-only focus:outline-none focus:ring-2 focus:ring-primary-300"
  >
    跳到正文
  </a>
  <header class="border-b border-gray-200 dark:border-gray-800">
    <nav class="max-w-4xl mx-auto px-4 py-4 md:py-6 flex items-center justify-between">
      <a href="/" class="text-lg md:text-2xl font-bold text-primary-600 dark:text-primary-400 truncate mr-2">大鹏的Log</a>

      <!-- Desktop nav (>=768px) -->
      <div class="hidden md:flex gap-6 items-center">
        <a href="/posts" class="hover:text-primary-600 dark:hover:text-primary-400 transition">文章</a>
        <a href="/tags" class="hover:text-primary-600 dark:hover:text-primary-400 transition">标签</a>
        <a href="/archives" class="hover:text-primary-600 dark:hover:text-primary-400 transition">归档</a>
        <a href="/tools" class="hover:text-primary-600 dark:hover:text-primary-400 transition">工具</a>
        <a href="/promotions" class="hover:text-primary-600 dark:hover:text-primary-400 transition">推广</a>
        <a href="/about" class="hover:text-primary-600 dark:hover:text-primary-400 transition">关于</a>
        <a href="/contact" class="hover:text-primary-600 dark:hover:text-primary-400 transition">联系</a>
        <a href="/search" class="hover:text-primary-600 dark:hover:text-primary-400 transition" aria-label="搜索">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </a>
        <button id="theme-toggle" class="hover:text-primary-600 dark:hover:text-primary-400 transition" aria-label="切换主题">
          <svg class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
          <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile controls (<768px) -->
      <div class="flex md:hidden items-center gap-2">
        <a href="/search" class="p-2 hover:text-primary-600 dark:hover:text-primary-400 transition" aria-label="搜索">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </a>
        <button id="theme-toggle-mobile" class="p-2 hover:text-primary-600 dark:hover:text-primary-400 transition" aria-label="切换主题">
          <svg class="w-5 h-5 dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
          </svg>
          <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
          </svg>
        </button>
        <button id="menu-toggle" class="p-2 hover:text-primary-600 dark:hover:text-primary-400 transition" aria-label="菜单" aria-expanded="false">
          <!-- Hamburger icon -->
          <svg class="w-6 h-6 menu-open" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- Close icon -->
          <svg class="w-6 h-6 menu-close hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </nav>

    <!-- Mobile menu panel -->
    <div id="mobile-menu" class="md:hidden max-h-0 overflow-hidden transition-[max-height] duration-300 ease-in-out">
      <div class="border-t border-gray-200 dark:border-gray-800 px-4 py-3 flex flex-col gap-1">
        <a href="/posts" class="py-2 px-3 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">文章</a>
        <a href="/tags" class="py-2 px-3 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">标签</a>
        <a href="/archives" class="py-2 px-3 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">归档</a>
        <a href="/tools" class="py-2 px-3 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">工具</a>
        <a href="/promotions" class="py-2 px-3 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">推广</a>
        <a href="/about" class="py-2 px-3 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">关于</a>
        <a href="/contact" class="py-2 px-3 rounded hover:bg-gray-100 dark:hover:bg-gray-800 transition">联系</a>
      </div>
    </div>
  </header>
  
  <main id="main-content" tabindex="-1" class="max-w-4xl mx-auto px-4 py-12 focus:outline-none">
    <slot />

    {showSubpageFeedback && (
      <section class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
        <div class="flex justify-center">
          <PageLikeButton />
        </div>
        <GiscusComments />
      </section>
    )}
  </main>
  
  <footer class="border-t border-gray-200 dark:border-gray-800 mt-20">
    <div class="max-w-4xl mx-auto px-4 py-8 text-sm text-gray-600 dark:text-gray-400">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p>© {new Date().getFullYear()} Blog. 原博客地址：<a href="https://www.cnblogs.com/bigroc" class="text-primary-600 dark:text-primary-400 hover:underline" target="_blank" rel="noopener">www.cnblogs.com/bigroc</a></p>
        <div class="flex gap-4">
          <a href="/tools" class="hover:text-primary-600 dark:hover:text-primary-400">工具</a>
          <a href="/promotions" class="hover:text-primary-600 dark:hover:text-primary-400">推广</a>
          <a href="/about" class="hover:text-primary-600 dark:hover:text-primary-400">关于</a>
          <a href="/contact" class="hover:text-primary-600 dark:hover:text-primary-400">联系</a>
          <a href="/privacy" class="hover:text-primary-600 dark:hover:text-primary-400">隐私条款</a>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Theme toggle (desktop + mobile)
    const applyTheme = (dark: boolean) => {
      document.documentElement.classList.toggle('dark', dark);
      localStorage.setItem('theme', dark ? 'dark' : 'light');
    };
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      applyTheme(!document.documentElement.classList.contains('dark'));
    });
    document.getElementById('theme-toggle-mobile')?.addEventListener('click', () => {
      applyTheme(!document.documentElement.classList.contains('dark'));
    });

    // Mobile menu toggle
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    menuToggle?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('open');
      menuToggle.setAttribute('aria-expanded', String(isOpen));
      if (mobileMenu) {
        mobileMenu.style.maxHeight = isOpen ? mobileMenu.scrollHeight + 'px' : '0';
      }
      menuToggle.querySelector('.menu-open')?.classList.toggle('hidden', isOpen);
      menuToggle.querySelector('.menu-close')?.classList.toggle('hidden', !isOpen);
    });

    // Close mobile menu on navigation
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.style.maxHeight = '0';
        mobileMenu.classList.remove('open');
        menuToggle?.setAttribute('aria-expanded', 'false');
        menuToggle?.querySelector('.menu-open')?.classList.remove('hidden');
        menuToggle?.querySelector('.menu-close')?.classList.add('hidden');
      });
    });
  </script>
</BaseLayout>
