---
import BaseLayout from './BaseLayout.astro';

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  robots?: string;
  canonicalURL?: string;
  keywords?: string;
  breadcrumbs?: Breadcrumb[];
}

const {
  title,
  description,
  image,
  robots,
  canonicalURL,
  keywords,
  breadcrumbs,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  robots={robots}
  type="website"
  loadAds={false}
  canonicalURL={canonicalURL}
  keywords={keywords}
  breadcrumbs={breadcrumbs}
>
  <main id="main-content" tabindex="-1" class="min-h-screen focus:outline-none">
    <div class="mx-auto flex min-h-screen max-w-5xl flex-col px-4 py-8 sm:px-6 lg:px-8">
      <div class="flex-1">
        <slot />
      </div>
    </div>
  </main>
</BaseLayout>
