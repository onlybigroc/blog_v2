---
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getTagUrl } from '@utils/slug';

const title = '标签';
const description = '所有文章标签';

const allPosts = (await getCollection('posts')).filter((post) => !post.data.draft);

const tagCount = new Map<string, number>();
allPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCount.set(tag, (tagCount.get(tag) || 0) + 1);
  });
});

const tags = Array.from(tagCount.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([tag, count]) => ({ tag, count }));

const maxCount = Math.max(...tags.map((tagEntry) => tagEntry.count));
const minCount = Math.min(...tags.map((tagEntry) => tagEntry.count));

function getTagSize(count: number): number {
  if (maxCount === minCount) {
    return 18;
  }

  const ratio = (count - minCount) / (maxCount - minCount);
  return 14 + ratio * 18;
}
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">标签</h1>
    <p class="text-gray-600 dark:text-gray-400">共 {tags.length} 个标签</p>
  </div>

  <div class="mb-12 p-8 bg-gray-50 rounded-lg dark:bg-gray-800/50">
    <div class="flex flex-wrap gap-4 justify-center items-center">
      {tags.map(({ tag, count }) => (
        <Fragment key={`cloud-${tag}`}>
          <a
            href={getTagUrl(tag)}
            class="text-primary-600 transition-colors hover:text-primary-700 dark:text-primary-400 dark:hover:text-primary-300"
            style={`font-size: ${getTagSize(count)}px;`}
            title={`${tag} (${count} 篇)`}
          >
            {tag}
          </a>
        </Fragment>
      ))}
    </div>
  </div>

  <div class="space-y-4">
    <h2 class="text-2xl font-bold mb-6">标签列表</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {tags.map(({ tag, count }) => (
        <Fragment key={`list-${tag}`}>
          <a
            href={getTagUrl(tag)}
            class="flex items-center justify-between p-4 bg-white border border-gray-200 rounded-lg transition-colors group hover:border-primary-500 dark:bg-gray-800 dark:border-gray-700 dark:hover:border-primary-500"
          >
            <span class="text-lg font-medium text-gray-900 transition group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
              {tag}
            </span>
            <span class="px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-sm font-medium dark:bg-primary-900/30 dark:text-primary-300">
              {count}
            </span>
          </a>
        </Fragment>
      ))}
    </div>
  </div>
</MainLayout>
