---
import AINewsCard from '@components/AINewsCard.astro';
import PostCard from '@components/PostCard.astro';
import { getLatestAiNews } from '@data/aiNews';
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const title = '首页';
const description = '大鹏的Log，记录正在发生的技术事。分享技术文章与开发心得，涵盖 Java、JavaScript、Go、数据库、Docker、AI 等领域。';
const aiNews = getLatestAiNews(3, 'cn');

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 10);
---

<MainLayout title={title} description={description}>
  <section class="hero-spotlight relative text-center mb-16 overflow-hidden py-8" style="min-height: 280px;">
    <canvas id="hero-particles" class="absolute inset-0 pointer-events-none" aria-hidden="true"></canvas>
    <div class="hero-glow w-72 h-72 bg-primary-400 top-0 left-1/4 -translate-x-1/2"></div>
    <div class="hero-glow w-56 h-56 bg-purple-400 top-10 right-1/4" style="animation-delay: -4s;"></div>
    <div class="hero-glow w-40 h-40 bg-pink-400 bottom-0 left-1/2" style="animation-delay: -8s;"></div>

    <h1 class="relative text-5xl font-bold mb-4 animate-on-scroll">
      <span class="text-gradient">大鹏的Log</span>
    </h1>
    <p class="relative text-xl text-gray-600 mb-4 dark:text-gray-400 animate-on-scroll" style="transition-delay: 0.15s;">
      <span class="typewriter-text">记录正在发生的事</span>
    </p>
    <p class="relative text-base text-gray-500 max-w-2xl mx-auto dark:text-gray-500 animate-on-scroll" style="transition-delay: 0.3s;">
      这里有关于 Java、JavaScript、Go、数据库、Docker、AI 等技术领域的原创文章，
      记录了我从 2017 年至今的技术学习和实践经验。希望这些内容能帮助到你。
    </p>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const canvas = document.getElementById('hero-particles') as HTMLCanvasElement | null;
      if (!canvas) return;

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) return;

      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      let animationId: number;
      let particles: { x: number; y: number; vx: number; vy: number; r: number }[] = [];
      const particleCount = 40;
      const connectionDistance = 120;

      const resize = () => {
        const rect = canvas.parentElement!.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
      };

      const initParticles = () => {
        particles = [];
        for (let i = 0; i < particleCount; i++) {
          particles.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.4,
            vy: (Math.random() - 0.5) * 0.4,
            r: Math.random() * 2 + 1,
          });
        }
      };

      const draw = () => {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const dark = document.documentElement.classList.contains('dark');
        const dotColor = dark ? 'rgba(147, 197, 253, 0.5)' : 'rgba(59, 130, 246, 0.3)';
        const lineColorBase = dark ? 'rgba(147, 197, 253, ' : 'rgba(59, 130, 246, ';

        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > canvas.width) p.vx *= -1;
          if (p.y < 0 || p.y > canvas.height) p.vy *= -1;

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = dotColor;
          ctx.fill();
        }

        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < connectionDistance) {
              const opacity = 1 - dist / connectionDistance;
              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.strokeStyle = lineColorBase + (opacity * 0.3).toFixed(2) + ')';
              ctx.lineWidth = 0.6;
              ctx.stroke();
            }
          }
        }

        animationId = requestAnimationFrame(draw);
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              resize();
              initParticles();
              draw();
            } else {
              cancelAnimationFrame(animationId);
            }
          });
        },
        { threshold: 0.1 }
      );

      observer.observe(canvas.parentElement!);

      const handleResize = () => {
        resize();
        initParticles();
      };
      window.addEventListener('resize', handleResize);

      document.addEventListener('astro:before-swap', () => {
        cancelAnimationFrame(animationId);
        observer.disconnect();
        window.removeEventListener('resize', handleResize);
      });
    });
  </script>

  <section class="mb-16">
    <div class="mb-8 flex items-end justify-between gap-4 animate-on-scroll">
      <div>
        <h2 class="text-3xl font-bold">AI 资讯速览</h2>
        <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">优先展示最近的中文 AI 动态，同时长期保留国际资讯与站内历史存档。</p>
      </div>
      <a href="/ai-news" class="text-sm font-medium text-primary-600 hover:underline dark:text-primary-400">
        查看全部
      </a>
    </div>

    {aiNews.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-gray-300 p-8 text-center text-gray-500 dark:border-gray-700 dark:text-gray-400">
        运行 <code class="rounded bg-gray-100 px-2 py-1 dark:bg-gray-800">npm run sync:ai-news</code> 后会在这里显示每日 AI 资讯。
      </div>
    ) : (
      <div class="grid gap-5 lg:grid-cols-3">
        {aiNews.map((item) => (
          <AINewsCard item={item} compact />
        ))}
      </div>
    )}
  </section>

  <section>
    <h2 class="text-3xl font-bold mb-8 animate-on-scroll">最新文章</h2>
    {posts.length === 0 ? (
      <div class="space-y-6">
        <p class="text-gray-600 dark:text-gray-400">正在同步文章中...</p>
        <p class="text-sm text-gray-500 dark:text-gray-500">
          运行 <code class="px-2 py-1 bg-gray-100 rounded dark:bg-gray-800">npm run sync</code> 同步博客文章
        </p>
      </div>
    ) : (
      <>
        <div class="space-y-6">
          {posts.map((post) => (
            <PostCard key={post.id} post={post} headingTag="h3" tagLimit={3} />
          ))}
        </div>

        <div class="mt-12 text-center animate-on-scroll">
          <a
            href="/posts"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-lg font-medium transition-colors hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-600"
          >
            查看全部文章
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>
      </>
    )}
  </section>
</MainLayout>
