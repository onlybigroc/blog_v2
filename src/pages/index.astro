---
import PostCard from '@components/PostCard.astro';
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const title = '首页';
const description = '大鹏的Log，记录正在发生的技术事。分享技术文章与开发心得，涵盖 Java、JavaScript、Go、数据库、Docker 等领域。';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 10);
---

<MainLayout title={title} description={description}>
  <section class="text-center mb-16">
    <h1 class="text-5xl font-bold mb-4">大鹏的Log</h1>
    <p class="text-xl text-gray-600 mb-4 dark:text-gray-400">记录正在发生的事</p>
    <p class="text-base text-gray-500 max-w-2xl mx-auto dark:text-gray-500">
      这里有关于 Java、JavaScript、Go、数据库、Docker 等技术领域的原创文章，
      记录了我从 2017 年至今的技术学习和实践经验。希望这些内容能帮助到你。
    </p>
  </section>

  <section>
    <h2 class="text-3xl font-bold mb-8">最新文章</h2>
    {posts.length === 0 ? (
      <div class="space-y-6">
        <p class="text-gray-600 dark:text-gray-400">正在同步文章中...</p>
        <p class="text-sm text-gray-500 dark:text-gray-500">
          运行 <code class="px-2 py-1 bg-gray-100 rounded dark:bg-gray-800">npm run sync</code> 同步博客文章
        </p>
      </div>
    ) : (
      <>
        <div class="space-y-8">
          {posts.map((post) => (
            <PostCard key={post.id} post={post} headingTag="h3" tagLimit={3} />
          ))}
        </div>

        <div class="mt-12 text-center">
          <a
            href="/posts"
            class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-lg font-medium transition-colors hover:bg-primary-700 dark:bg-primary-500 dark:hover:bg-primary-600"
          >
            查看全部文章
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>
      </>
    )}
  </section>
</MainLayout>
