---
import MainLayout from '@layouts/MainLayout.astro';
import TextRepeatTool from '@components/tools/TextRepeatTool.astro';
const title = '文本重复 | 工具';
const description = '将文本重复指定次数。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">文本重复</h1>
    <p class="text-gray-600 dark:text-gray-400">将文本重复指定次数。</p>
  </div>
  <TextRepeatTool cleanPath="/tools/text-repeat/clean/" showCleanLink />
</MainLayout>
