---
import MainLayout from '@layouts/MainLayout.astro';
import TomlToJsonTool from '@components/tools/TomlToJsonTool.astro';
const title = 'TOML 转 JSON | 工具';
const description = '将 TOML 格式转换为 JSON。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">TOML 转 JSON</h1>
    <p class="text-gray-600 dark:text-gray-400">将 TOML 格式转换为 JSON。</p>
  </div>
  <TomlToJsonTool cleanPath="/tools/toml-to-json/clean/" showCleanLink />
</MainLayout>
