---
import MainLayout from '@layouts/MainLayout.astro';
import TipCalcTool from '@components/tools/TipCalcTool.astro';
const title = '小费计算器 | 工具';
const description = '根据账单金额计算小费。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">小费计算器</h1>
    <p class="text-gray-600 dark:text-gray-400">根据账单金额计算小费。</p>
  </div>
  <TipCalcTool cleanPath="/tools/tip-calc/clean/" showCleanLink />
</MainLayout>
