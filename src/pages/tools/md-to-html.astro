---
import MainLayout from '@layouts/MainLayout.astro';
import MdToHtmlTool from '@components/tools/MdToHtmlTool.astro';
const title = 'Markdown 转 HTML | 工具';
const description = '将 Markdown 文本转换为 HTML 代码。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">Markdown 转 HTML</h1>
    <p class="text-gray-600 dark:text-gray-400">将 Markdown 文本转换为 HTML 代码。</p>
  </div>
  <MdToHtmlTool cleanPath="/tools/md-to-html/clean/" showCleanLink />
</MainLayout>
