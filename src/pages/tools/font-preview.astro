---
import MainLayout from '@layouts/MainLayout.astro';
import FontPreviewTool from '@components/tools/FontPreviewTool.astro';
const title = '字体预览工具 | 工具';
const description = '预览不同字体效果，支持自定义文本。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">字体预览工具</h1>
    <p class="text-gray-600 dark:text-gray-400">预览不同字体效果，支持自定义文本。</p>
  </div>
  <FontPreviewTool cleanPath="/tools/font-preview/clean/" showCleanLink />
</MainLayout>
