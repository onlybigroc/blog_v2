---
import MainLayout from '@layouts/MainLayout.astro';
import BorderRadiusGenTool from '@components/tools/BorderRadiusGenTool.astro';
const title = 'Border Radius 生成器 | 工具';
const description = '可视化调整圆角，支持四角独立设置。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">Border Radius 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">可视化调整圆角，支持四角独立设置。</p>
  </div>
  <BorderRadiusGenTool cleanPath="/tools/border-radius-gen/clean/" showCleanLink />
</MainLayout>
