---
import MainLayout from '@layouts/MainLayout.astro';
import DiceRollTool from '@components/tools/DiceRollTool.astro';
const title = '掷骰子 | 工具';
const description = '虚拟掷骰子，支持多骰子。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">掷骰子</h1>
    <p class="text-gray-600 dark:text-gray-400">虚拟掷骰子，支持多骰子。</p>
  </div>
  <DiceRollTool cleanPath="/tools/dice-roll/clean/" showCleanLink />
</MainLayout>
