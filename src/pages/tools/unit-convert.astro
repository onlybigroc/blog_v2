---
import MainLayout from '@layouts/MainLayout.astro';
import UnitConvertTool from '@components/tools/UnitConvertTool.astro';
const title = '通用单位换算 | 工具';
const description = '长度/重量/体积等单位互相换算。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">通用单位换算</h1>
    <p class="text-gray-600 dark:text-gray-400">长度/重量/体积等单位互相换算。</p>
  </div>
  <UnitConvertTool cleanPath="/tools/unit-convert/clean/" showCleanLink />
</MainLayout>
