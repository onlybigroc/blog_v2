---
import MainLayout from '@layouts/MainLayout.astro';
import RandomColorTool from '@components/tools/RandomColorTool.astro';
const title = '随机颜色 | 工具';
const description = '生成随机颜色并展示 HEX/RGB 值。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">随机颜色</h1>
    <p class="text-gray-600 dark:text-gray-400">生成随机颜色并展示 HEX/RGB 值。</p>
  </div>
  <RandomColorTool cleanPath="/tools/random-color/clean/" showCleanLink />
</MainLayout>
