---
import MainLayout from '@layouts/MainLayout.astro';
import CurrencyConvertTool from '@components/tools/CurrencyConvertTool.astro';
const title = '汇率换算 | 工具';
const description = '主要货币之间的汇率换算。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">汇率换算</h1>
    <p class="text-gray-600 dark:text-gray-400">主要货币之间的汇率换算。</p>
  </div>
  <CurrencyConvertTool cleanPath="/tools/currency-convert/clean/" showCleanLink />
</MainLayout>
