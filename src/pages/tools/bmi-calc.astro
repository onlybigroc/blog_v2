---
import MainLayout from '@layouts/MainLayout.astro';
import BmiCalcTool from '@components/tools/BmiCalcTool.astro';
const title = 'BMI 计算器 | 工具';
const description = '计算身体质量指数。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">BMI 计算器</h1>
    <p class="text-gray-600 dark:text-gray-400">计算身体质量指数。</p>
  </div>
  <BmiCalcTool cleanPath="/tools/bmi-calc/clean/" showCleanLink />
</MainLayout>
