---
import MainLayout from '@layouts/MainLayout.astro';
import CsvViewerTool from '@components/tools/CsvViewerTool.astro';

const title = 'CSV 查看器 | 工具';
const description = '解析 CSV 数据，以表格形式展示，支持排序和筛选。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-4xl font-bold mt-3 mb-3">CSV 查看器</h1>
    <p class="text-gray-600 dark:text-gray-400">解析 CSV 数据，以表格形式展示，支持排序和筛选。</p>
  </div>
  <CsvViewerTool cleanPath="/tools/csv-viewer/clean/" showCleanLink />
</MainLayout>
