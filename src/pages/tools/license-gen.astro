---
import MainLayout from '@layouts/MainLayout.astro';
import LicenseGenTool from '@components/tools/LicenseGenTool.astro';
const title = '开源协议生成器 | 工具';
const description = '选择协议类型，自动生成 LICENSE 文件。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">开源协议生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">选择协议类型，自动生成 LICENSE 文件。</p>
  </div>
  <LicenseGenTool cleanPath="/tools/license-gen/clean/" showCleanLink />
</MainLayout>
