---
import MainLayout from '@layouts/MainLayout.astro';
import TextHighlightTool from '@components/tools/TextHighlightTool.astro';
const title = '文本高亮 | 工具';
const description = '在文本中高亮搜索关键词。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">文本高亮</h1>
    <p class="text-gray-600 dark:text-gray-400">在文本中高亮搜索关键词。</p>
  </div>
  <TextHighlightTool cleanPath="/tools/text-highlight/clean/" showCleanLink />
</MainLayout>
