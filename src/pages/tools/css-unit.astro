---
import MainLayout from '@layouts/MainLayout.astro';
import CssUnitTool from '@components/tools/CssUnitTool.astro';

const title = 'CSS 单位换算 | 工具';
const description = 'px / rem / em / vw / % 等 CSS 单位互相换算。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">CSS 单位换算</h1>
    <p class="text-gray-600 dark:text-gray-400">px / rem / em / vw / % 等 CSS 单位互相换算。</p>
  </div>

  <CssUnitTool cleanPath="/tools/css-unit/clean/" showCleanLink />
</MainLayout>
