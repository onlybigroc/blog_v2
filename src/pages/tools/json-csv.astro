---
import MainLayout from '@layouts/MainLayout.astro';
import JsonCsvTool from '@components/tools/JsonCsvTool.astro';

const title = 'JSON 转 CSV | 工具';
const description = 'JSON 与 CSV 互转，支持嵌套对象和自定义分隔符。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">JSON 转 CSV</h1>
    <p class="text-gray-600 dark:text-gray-400">JSON 与 CSV 互转，支持嵌套对象和自定义分隔符。</p>
  </div>

  <JsonCsvTool />
</MainLayout>
