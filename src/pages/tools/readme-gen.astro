---
import MainLayout from '@layouts/MainLayout.astro';
import ReadmeGenTool from '@components/tools/ReadmeGenTool.astro';
const title = 'README 生成器 | 工具';
const description = '填写项目信息，自动生成 README.md。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">README 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">填写项目信息，自动生成 README.md。</p>
  </div>
  <ReadmeGenTool cleanPath="/tools/readme-gen/clean/" showCleanLink />
</MainLayout>
