---
import MainLayout from '@layouts/MainLayout.astro';
import PortCheckTool from '@components/tools/PortCheckTool.astro';
const title = '端口占用查询 | 工具';
const description = '查看常用端口列表和端口说明。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">端口占用查询</h1>
    <p class="text-gray-600 dark:text-gray-400">查看常用端口列表和端口说明。</p>
  </div>
  <PortCheckTool cleanPath="/tools/port-check/clean/" showCleanLink />
</MainLayout>
