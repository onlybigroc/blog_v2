---
import MainLayout from '@layouts/MainLayout.astro';
import DateCalculatorTool from '@components/tools/DateCalculatorTool.astro';
const title = '日期计算器 | 工具';
const description = '计算两个日期之间的天数差。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">日期计算器</h1>
    <p class="text-gray-600 dark:text-gray-400">计算两个日期之间的天数差。</p>
  </div>
  <DateCalculatorTool cleanPath="/tools/date-calculator/clean/" showCleanLink />
</MainLayout>
