---
import MainLayout from '@layouts/MainLayout.astro';
import AnimationKeyframeTool from '@components/tools/AnimationKeyframeTool.astro';
const title = 'CSS 动画生成器 | 工具';
const description = '创建 CSS @keyframes 动画，实时预览。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">CSS 动画生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">创建 CSS @keyframes 动画，实时预览。</p>
  </div>
  <AnimationKeyframeTool cleanPath="/tools/animation-keyframe/clean/" showCleanLink />
</MainLayout>
