---
import MainLayout from '@layouts/MainLayout.astro';
import BingoGenTool from '@components/tools/BingoGenTool.astro';
const title = 'Bingo 生成器 | 工具';
const description = '生成随机 Bingo 卡片。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">Bingo 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">生成随机 Bingo 卡片。</p>
  </div>
  <BingoGenTool cleanPath="/tools/bingo-gen/clean/" showCleanLink />
</MainLayout>
