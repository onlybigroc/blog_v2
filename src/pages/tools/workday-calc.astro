---
import MainLayout from '@layouts/MainLayout.astro';
import WorkdayCalcTool from '@components/tools/WorkdayCalcTool.astro';
const title = '工作日计算 | 工具';
const description = '计算两个日期之间的工作日天数。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">工作日计算</h1>
    <p class="text-gray-600 dark:text-gray-400">计算两个日期之间的工作日天数。</p>
  </div>
  <WorkdayCalcTool cleanPath="/tools/workday-calc/clean/" showCleanLink />
</MainLayout>
