---
import MainLayout from '@layouts/MainLayout.astro';
import GraphqlDebugTool from '@components/tools/GraphqlDebugTool.astro';
const title = 'GraphQL 调试器 | 工具';
const description = '格式化并验证 GraphQL 查询语句。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">GraphQL 调试器</h1>
    <p class="text-gray-600 dark:text-gray-400">格式化并验证 GraphQL 查询语句。</p>
  </div>
  <GraphqlDebugTool cleanPath="/tools/graphql-debug/clean/" showCleanLink />
</MainLayout>
