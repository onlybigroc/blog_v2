---
import MainLayout from '@layouts/MainLayout.astro';
import LoremIpsumTool from '@components/tools/LoremIpsumTool.astro';
const title = 'Lorem Ipsum 生成器 | 工具';
const description = '生成 Lorem Ipsum 占位文本，支持段落、句子、单词模式。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-3">Lorem Ipsum 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">生成 Lorem Ipsum 占位文本，支持段落、句子、单词模式，可选中文占位文本。</p>
  </div>
  <LoremIpsumTool />
</MainLayout>
