---
import ToolLayout from '@layouts/ToolLayout.astro';
import RollCallTool from '@components/tools/RollCallTool.astro';

const title = '课堂点名 | 工具';
const description = '导入 Excel 或粘贴名单后随机点名，支持一轮内不重复点名、回答反馈和自定义表扬鼓励语。';
---

<ToolLayout title={title} description={description}>
  <RollCallTool />
</ToolLayout>
