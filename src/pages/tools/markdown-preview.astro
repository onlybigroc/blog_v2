---
import MainLayout from '@layouts/MainLayout.astro';
import MarkdownPreviewTool from '@components/tools/MarkdownPreviewTool.astro';

const title = 'Markdown 预览 | 工具';
const description = '实时预览 Markdown，支持常见语法和代码高亮。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">Markdown 预览</h1>
    <p class="text-gray-600 dark:text-gray-400">实时预览 Markdown，支持常见语法。</p>
  </div>

  <MarkdownPreviewTool />
</MainLayout>
