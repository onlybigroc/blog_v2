---
import MainLayout from '@layouts/MainLayout.astro';
import CodeMinifyTool from '@components/tools/CodeMinifyTool.astro';
const title = '代码压缩 | 工具';
const description = '压缩 JavaScript/CSS/HTML 代码，移除空白和注释。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">代码压缩</h1>
    <p class="text-gray-600 dark:text-gray-400">压缩 JavaScript/CSS/HTML 代码，移除空白和注释。</p>
  </div>
  <CodeMinifyTool cleanPath="/tools/code-minify/clean/" showCleanLink />
</MainLayout>
