---
import MainLayout from '@layouts/MainLayout.astro';
import CoinFlipTool from '@components/tools/CoinFlipTool.astro';
const title = '抛硬币 | 工具';
const description = '虚拟抛硬币，正反面随机。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">抛硬币</h1>
    <p class="text-gray-600 dark:text-gray-400">虚拟抛硬币，正反面随机。</p>
  </div>
  <CoinFlipTool cleanPath="/tools/coin-flip/clean/" showCleanLink />
</MainLayout>
