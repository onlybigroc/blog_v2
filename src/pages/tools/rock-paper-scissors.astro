---
import MainLayout from '@layouts/MainLayout.astro';
import RockPaperScissorsTool from '@components/tools/RockPaperScissorsTool.astro';
const title = '石头剪刀布 | 工具';
const description = '经典石头剪刀布游戏。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">石头剪刀布</h1>
    <p class="text-gray-600 dark:text-gray-400">经典石头剪刀布游戏。</p>
  </div>
  <RockPaperScissorsTool cleanPath="/tools/rock-paper-scissors/clean/" showCleanLink />
</MainLayout>
