---
import MainLayout from '@layouts/MainLayout.astro';
import CountdownTool from '@components/tools/CountdownTool.astro';
const title = '倒计时器 | 工具';
const description = '设置目标时间，实时显示剩余时间。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">倒计时器</h1>
    <p class="text-gray-600 dark:text-gray-400">设置目标时间，实时显示剩余时间。</p>
  </div>
  <CountdownTool cleanPath="/tools/countdown/clean/" showCleanLink />
</MainLayout>
