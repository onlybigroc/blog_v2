---
import MainLayout from '@layouts/MainLayout.astro';
import SslCheckTool from '@components/tools/SslCheckTool.astro';
const title = 'SSL 证书查询 | 工具';
const description = '查询域名的 SSL 证书信息。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">SSL 证书查询</h1>
    <p class="text-gray-600 dark:text-gray-400">查询域名的 SSL 证书信息。</p>
  </div>
  <SslCheckTool cleanPath="/tools/ssl-check/clean/" showCleanLink />
</MainLayout>
