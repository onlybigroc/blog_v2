---
import MainLayout from '@layouts/MainLayout.astro';
import PalindromeCheckTool from '@components/tools/PalindromeCheckTool.astro';
const title = '回文检测 | 工具';
const description = '检测文本是否为回文。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">回文检测</h1>
    <p class="text-gray-600 dark:text-gray-400">检测文本是否为回文。</p>
  </div>
  <PalindromeCheckTool cleanPath="/tools/palindrome-check/clean/" showCleanLink />
</MainLayout>
