---
import MainLayout from '@layouts/MainLayout.astro';
import BcryptHashTool from '@components/tools/BcryptHashTool.astro';
const title = 'Bcrypt 哈希 | 工具';
const description = '使用 Bcrypt 算法对密码进行哈希。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">Bcrypt 哈希</h1>
    <p class="text-gray-600 dark:text-gray-400">使用 Bcrypt 算法对密码进行哈希。</p>
  </div>
  <BcryptHashTool cleanPath="/tools/bcrypt-hash/clean/" showCleanLink />
</MainLayout>
