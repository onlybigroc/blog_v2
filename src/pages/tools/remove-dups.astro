---
import MainLayout from '@layouts/MainLayout.astro';
import RemoveDupsTool from '@components/tools/RemoveDupsTool.astro';
const title = '去重工具 | 工具';
const description = '去除文本中的重复行。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">去重工具</h1>
    <p class="text-gray-600 dark:text-gray-400">去除文本中的重复行。</p>
  </div>
  <RemoveDupsTool cleanPath="/tools/remove-dups/clean/" showCleanLink />
</MainLayout>
