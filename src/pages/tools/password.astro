---
import MainLayout from '@layouts/MainLayout.astro';
import PasswordTool from '@components/tools/PasswordTool.astro';

const title = '密码生成器 | 工具';
const description = '安全随机密码生成器，支持自定义字符类型、长度和批量生成。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">密码生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">使用 Web Crypto API 生成安全随机密码。</p>
  </div>

  <PasswordTool />
</MainLayout>
