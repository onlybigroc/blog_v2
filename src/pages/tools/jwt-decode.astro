---
import MainLayout from '@layouts/MainLayout.astro';
import JwtDecodeTool from '@components/tools/JwtDecodeTool.astro';

const title = 'JWT 解析 | 工具';
const description = '解码 JWT Token，展示 Header / Payload / Signature。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">JWT 解析</h1>
    <p class="text-gray-600 dark:text-gray-400">解码 JWT Token，展示 Header / Payload / Signature。</p>
  </div>

  <JwtDecodeTool cleanPath="/tools/jwt-decode/clean/" showCleanLink />
</MainLayout>
