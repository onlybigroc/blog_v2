---
import MainLayout from '@layouts/MainLayout.astro';
import TsconfigHelperTool from '@components/tools/TsconfigHelperTool.astro';
const title = 'tsconfig 辅助器 | 工具';
const description = '可视化配置 TypeScript tsconfig.json。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">tsconfig 辅助器</h1>
    <p class="text-gray-600 dark:text-gray-400">可视化配置 TypeScript tsconfig.json。</p>
  </div>
  <TsconfigHelperTool cleanPath="/tools/tsconfig-helper/clean/" showCleanLink />
</MainLayout>
