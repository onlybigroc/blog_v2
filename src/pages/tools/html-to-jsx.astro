---
import MainLayout from '@layouts/MainLayout.astro';
import HtmlToJsxTool from '@components/tools/HtmlToJsxTool.astro';
const title = 'HTML 转 JSX | 工具';
const description = '将 HTML 代码转换为 JSX 格式（class→className 等）。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">HTML 转 JSX</h1>
    <p class="text-gray-600 dark:text-gray-400">将 HTML 代码转换为 JSX 格式（class→className 等）。</p>
  </div>
  <HtmlToJsxTool cleanPath="/tools/html-to-jsx/clean/" showCleanLink />
</MainLayout>
