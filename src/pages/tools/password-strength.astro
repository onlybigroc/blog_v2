---
import MainLayout from '@layouts/MainLayout.astro';
import PasswordStrengthTool from '@components/tools/PasswordStrengthTool.astro';
const title = '密码强度检测 | 工具';
const description = '检测密码强度并给出改进建议。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">密码强度检测</h1>
    <p class="text-gray-600 dark:text-gray-400">检测密码强度并给出改进建议。</p>
  </div>
  <PasswordStrengthTool cleanPath="/tools/password-strength/clean/" showCleanLink />
</MainLayout>
