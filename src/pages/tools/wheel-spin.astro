---
import MainLayout from '@layouts/MainLayout.astro';
import WheelSpinTool from '@components/tools/WheelSpinTool.astro';
const title = '转盘 | 工具';
const description = '可自定义选项的转盘。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">转盘</h1>
    <p class="text-gray-600 dark:text-gray-400">可自定义选项的转盘。</p>
  </div>
  <WheelSpinTool cleanPath="/tools/wheel-spin/clean/" showCleanLink />
</MainLayout>
