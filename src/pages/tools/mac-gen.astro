---
import MainLayout from '@layouts/MainLayout.astro';
import MacGenTool from '@components/tools/MacGenTool.astro';
const title = 'MAC 地址生成器 | 工具';
const description = '随机生成 MAC 地址，支持多种格式。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">MAC 地址生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">随机生成 MAC 地址，支持多种格式。</p>
  </div>
  <MacGenTool cleanPath="/tools/mac-gen/clean/" showCleanLink />
</MainLayout>
