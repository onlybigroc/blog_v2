---
import MainLayout from '@layouts/MainLayout.astro';
import OtpGenTool from '@components/tools/OtpGenTool.astro';
const title = 'OTP 生成器 | 工具';
const description = '生成基于时间的一次性密码。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">OTP 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">生成基于时间的一次性密码。</p>
  </div>
  <OtpGenTool cleanPath="/tools/otp-gen/clean/" showCleanLink />
</MainLayout>
