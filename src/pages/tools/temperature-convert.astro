---
import MainLayout from '@layouts/MainLayout.astro';
import TemperatureConvertTool from '@components/tools/TemperatureConvertTool.astro';
const title = '温度换算 | 工具';
const description = '摄氏/华氏/开尔文温度互转。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">温度换算</h1>
    <p class="text-gray-600 dark:text-gray-400">摄氏/华氏/开尔文温度互转。</p>
  </div>
  <TemperatureConvertTool cleanPath="/tools/temperature-convert/clean/" showCleanLink />
</MainLayout>
