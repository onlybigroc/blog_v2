---
import MainLayout from '@layouts/MainLayout.astro';
import RegexVisualizerTool from '@components/tools/RegexVisualizerTool.astro';
const title = '正则可视化 | 工具';
const description = '输入正则表达式，可视化展示匹配结构和分组。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">正则可视化</h1>
    <p class="text-gray-600 dark:text-gray-400">输入正则表达式，可视化展示匹配结构和分组。</p>
  </div>
  <RegexVisualizerTool cleanPath="/tools/regex-visualizer/clean/" showCleanLink />
</MainLayout>
