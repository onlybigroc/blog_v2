---
import MainLayout from '@layouts/MainLayout.astro';
import XmlFormatTool from '@components/tools/XmlFormatTool.astro';
const title = 'XML 格式化 | 工具';
const description = '格式化 XML 代码，支持压缩和校验。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">XML 格式化</h1>
    <p class="text-gray-600 dark:text-gray-400">格式化 XML 代码，支持压缩和校验。</p>
  </div>
  <XmlFormatTool cleanPath="/tools/xml-format/clean/" showCleanLink />
</MainLayout>
