---
import MainLayout from '@layouts/MainLayout.astro';
import YamlToJsonTool from '@components/tools/YamlToJsonTool.astro';
const title = 'YAML 转 JSON | 工具';
const description = '将 YAML 格式转换为 JSON。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">YAML 转 JSON</h1>
    <p class="text-gray-600 dark:text-gray-400">将 YAML 格式转换为 JSON。</p>
  </div>
  <YamlToJsonTool cleanPath="/tools/yaml-to-json/clean/" showCleanLink />
</MainLayout>
