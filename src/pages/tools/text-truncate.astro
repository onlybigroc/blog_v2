---
import MainLayout from '@layouts/MainLayout.astro';
import TextTruncateTool from '@components/tools/TextTruncateTool.astro';
const title = '文本截断 | 工具';
const description = '按指定长度截断文本。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">文本截断</h1>
    <p class="text-gray-600 dark:text-gray-400">按指定长度截断文本。</p>
  </div>
  <TextTruncateTool cleanPath="/tools/text-truncate/clean/" showCleanLink />
</MainLayout>
