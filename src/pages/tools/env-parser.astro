---
import MainLayout from '@layouts/MainLayout.astro';
import EnvParserTool from '@components/tools/EnvParserTool.astro';
const title = '.env 文件解析器 | 工具';
const description = '解析 .env 文件内容，以表格展示变量。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">.env 文件解析器</h1>
    <p class="text-gray-600 dark:text-gray-400">解析 .env 文件内容，以表格展示变量。</p>
  </div>
  <EnvParserTool cleanPath="/tools/env-parser/clean/" showCleanLink />
</MainLayout>
