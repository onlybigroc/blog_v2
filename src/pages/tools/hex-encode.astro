---
import MainLayout from '@layouts/MainLayout.astro';
import HexEncodeTool from '@components/tools/HexEncodeTool.astro';
const title = '十六进制编解码 | 工具';
const description = '文本与十六进制互相转换。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">十六进制编解码</h1>
    <p class="text-gray-600 dark:text-gray-400">文本与十六进制互相转换。</p>
  </div>
  <HexEncodeTool cleanPath="/tools/hex-encode/clean/" showCleanLink />
</MainLayout>
