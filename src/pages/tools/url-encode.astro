---
import MainLayout from '@layouts/MainLayout.astro';
import UrlEncodeTool from '@components/tools/UrlEncodeTool.astro';

const title = 'URL 编解码 | 工具';
const description = 'URL 编码解码，支持 encodeURI 和 encodeURIComponent 模式。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">URL 编解码</h1>
    <p class="text-gray-600 dark:text-gray-400">URL 编码解码工具，支持 encodeURI 和 encodeURIComponent 两种模式。</p>
  </div>

  <UrlEncodeTool cleanPath="/tools/url-encode/clean/" showCleanLink />
</MainLayout>
