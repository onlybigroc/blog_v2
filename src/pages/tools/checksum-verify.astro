---
import MainLayout from '@layouts/MainLayout.astro';
import ChecksumVerifyTool from '@components/tools/ChecksumVerifyTool.astro';
const title = '校验和验证 | 工具';
const description = '计算文件或文本的校验和。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">校验和验证</h1>
    <p class="text-gray-600 dark:text-gray-400">计算文件或文本的校验和。</p>
  </div>
  <ChecksumVerifyTool cleanPath="/tools/checksum-verify/clean/" showCleanLink />
</MainLayout>
