---
import MainLayout from '@layouts/MainLayout.astro';
import UaParseTool from '@components/tools/UaParseTool.astro';

const title = 'User-Agent 解析 | 工具';
const description = '解析浏览器 UA 字符串，展示浏览器、OS、设备信息。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">User-Agent 解析</h1>
    <p class="text-gray-600 dark:text-gray-400">解析浏览器 UA 字符串，展示浏览器、OS、设备信息。</p>
  </div>

  <UaParseTool cleanPath="/tools/ua-parse/clean/" showCleanLink />
</MainLayout>
