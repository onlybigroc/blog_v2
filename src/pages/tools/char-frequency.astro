---
import MainLayout from '@layouts/MainLayout.astro';
import CharFrequencyTool from '@components/tools/CharFrequencyTool.astro';
const title = '字符频率分析 | 工具';
const description = '统计文本中每个字符出现的频率。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">字符频率分析</h1>
    <p class="text-gray-600 dark:text-gray-400">统计文本中每个字符出现的频率。</p>
  </div>
  <CharFrequencyTool cleanPath="/tools/char-frequency/clean/" showCleanLink />
</MainLayout>
