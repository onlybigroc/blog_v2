---
import MainLayout from '@layouts/MainLayout.astro';
import ParagraphMergeTool from '@components/tools/ParagraphMergeTool.astro';
const title = '段落合并 | 工具';
const description = '将多行文本合并为一个段落。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">段落合并</h1>
    <p class="text-gray-600 dark:text-gray-400">将多行文本合并为一个段落。</p>
  </div>
  <ParagraphMergeTool cleanPath="/tools/paragraph-merge/clean/" showCleanLink />
</MainLayout>
