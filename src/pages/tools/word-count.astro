---
import MainLayout from '@layouts/MainLayout.astro';
import WordCountTool from '@components/tools/WordCountTool.astro';

const title = '文字计数 | 工具';
const description = '实时统计字数、字符数、行数、段落，支持中英文混合。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">文字计数</h1>
    <p class="text-gray-600 dark:text-gray-400">实时统计字数、字符数、行数、段落，支持中英文混合。</p>
  </div>

  <WordCountTool />
</MainLayout>
