---
import MainLayout from '@layouts/MainLayout.astro';
import CodeFormatTool from '@components/tools/CodeFormatTool.astro';

const title = '代码格式化 | 工具';
const description = '在线代码格式化工具，支持 JSON/HTML/CSS/JS 格式化和压缩。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">代码格式化</h1>
    <p class="text-gray-600 dark:text-gray-400">在线代码格式化工具，支持 JSON/HTML/CSS/JS 格式化和压缩。</p>
  </div>

  <CodeFormatTool cleanPath="/tools/code-format/clean/" showCleanLink />
</MainLayout>
