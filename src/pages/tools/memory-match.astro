---
import MainLayout from '@layouts/MainLayout.astro';
import MemoryMatchTool from '@components/tools/MemoryMatchTool.astro';
const title = '记忆翻牌 | 工具';
const description = '翻牌配对记忆游戏。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">记忆翻牌</h1>
    <p class="text-gray-600 dark:text-gray-400">翻牌配对记忆游戏。</p>
  </div>
  <MemoryMatchTool cleanPath="/tools/memory-match/clean/" showCleanLink />
</MainLayout>
