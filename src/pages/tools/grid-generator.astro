---
import MainLayout from '@layouts/MainLayout.astro';
import GridGeneratorTool from '@components/tools/GridGeneratorTool.astro';
const title = 'CSS Grid 生成器 | 工具';
const description = '可视化创建 CSS Grid 布局，生成代码。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">CSS Grid 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">可视化创建 CSS Grid 布局，生成代码。</p>
  </div>
  <GridGeneratorTool cleanPath="/tools/grid-generator/clean/" showCleanLink />
</MainLayout>
