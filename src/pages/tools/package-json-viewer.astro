---
import MainLayout from '@layouts/MainLayout.astro';
import PackageJsonViewerTool from '@components/tools/PackageJsonViewerTool.astro';
const title = 'package.json 查看器 | 工具';
const description = '可视化展示 package.json 的依赖和脚本。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">package.json 查看器</h1>
    <p class="text-gray-600 dark:text-gray-400">可视化展示 package.json 的依赖和脚本。</p>
  </div>
  <PackageJsonViewerTool cleanPath="/tools/package-json-viewer/clean/" showCleanLink />
</MainLayout>
