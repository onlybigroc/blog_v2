---
import MainLayout from '@layouts/MainLayout.astro';
import CardDrawTool from '@components/tools/CardDrawTool.astro';
const title = '抽卡模拟器 | 工具';
const description = '从扑克牌中随机抽卡。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">抽卡模拟器</h1>
    <p class="text-gray-600 dark:text-gray-400">从扑克牌中随机抽卡。</p>
  </div>
  <CardDrawTool cleanPath="/tools/card-draw/clean/" showCleanLink />
</MainLayout>
