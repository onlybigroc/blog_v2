---
import MainLayout from '@layouts/MainLayout.astro';
import HashGeneratorTool from '@components/tools/HashGeneratorTool.astro';

const title = 'Hash 生成器 | 工具';
const description = '计算文本的 SHA-1 / SHA-256 / SHA-384 / SHA-512 哈希值。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">Hash 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">计算文本的 SHA-1 / SHA-256 / SHA-384 / SHA-512 哈希值。</p>
  </div>

  <HashGeneratorTool cleanPath="/tools/hash-generator/clean/" showCleanLink />
</MainLayout>
