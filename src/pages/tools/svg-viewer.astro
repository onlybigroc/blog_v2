---
import MainLayout from '@layouts/MainLayout.astro';
import SvgViewerTool from '@components/tools/SvgViewerTool.astro';
const title = 'SVG 查看器 | 工具';
const description = '粘贴 SVG 代码，实时预览并导出。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">SVG 查看器</h1>
    <p class="text-gray-600 dark:text-gray-400">粘贴 SVG 代码，实时预览并导出。</p>
  </div>
  <SvgViewerTool cleanPath="/tools/svg-viewer/clean/" showCleanLink />
</MainLayout>
