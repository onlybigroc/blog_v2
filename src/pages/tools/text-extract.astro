---
import MainLayout from '@layouts/MainLayout.astro';
import TextExtractTool from '@components/tools/TextExtractTool.astro';
const title = '文本提取 | 工具';
const description = '按正则表达式提取文本中的特定内容。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">文本提取</h1>
    <p class="text-gray-600 dark:text-gray-400">按正则表达式提取文本中的特定内容。</p>
  </div>
  <TextExtractTool cleanPath="/tools/text-extract/clean/" showCleanLink />
</MainLayout>
