---
import MainLayout from '@layouts/MainLayout.astro';
import WeightConvertTool from '@components/tools/WeightConvertTool.astro';
const title = '重量换算 | 工具';
const description = '千克/磅/盎司等重量单位互转。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">重量换算</h1>
    <p class="text-gray-600 dark:text-gray-400">千克/磅/盎司等重量单位互转。</p>
  </div>
  <WeightConvertTool cleanPath="/tools/weight-convert/clean/" showCleanLink />
</MainLayout>
