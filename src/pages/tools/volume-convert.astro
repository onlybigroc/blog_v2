---
import MainLayout from '@layouts/MainLayout.astro';
import VolumeConvertTool from '@components/tools/VolumeConvertTool.astro';
const title = '体积换算 | 工具';
const description = '升/毫升/加仑等体积单位互转。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">体积换算</h1>
    <p class="text-gray-600 dark:text-gray-400">升/毫升/加仑等体积单位互转。</p>
  </div>
  <VolumeConvertTool cleanPath="/tools/volume-convert/clean/" showCleanLink />
</MainLayout>
