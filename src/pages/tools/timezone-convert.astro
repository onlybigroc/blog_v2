---
import MainLayout from '@layouts/MainLayout.astro';
import TimezoneConvertTool from '@components/tools/TimezoneConvertTool.astro';
const title = '时区转换 | 工具';
const description = '在不同时区之间转换日期时间。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">时区转换</h1>
    <p class="text-gray-600 dark:text-gray-400">在不同时区之间转换日期时间。</p>
  </div>
  <TimezoneConvertTool cleanPath="/tools/timezone-convert/clean/" showCleanLink />
</MainLayout>
