---
import MainLayout from '@layouts/MainLayout.astro';
import SqlFormatTool from '@components/tools/SqlFormatTool.astro';
const title = 'SQL 格式化 | 工具';
const description = '格式化 SQL 语句，支持关键字大写。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">SQL 格式化</h1>
    <p class="text-gray-600 dark:text-gray-400">格式化 SQL 语句，支持关键字大写。</p>
  </div>
  <SqlFormatTool cleanPath="/tools/sql-format/clean/" showCleanLink />
</MainLayout>
