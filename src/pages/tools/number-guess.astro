---
import MainLayout from '@layouts/MainLayout.astro';
import NumberGuessTool from '@components/tools/NumberGuessTool.astro';
const title = '猜数字 | 工具';
const description = '猜一个 1-100 的随机数字。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">猜数字</h1>
    <p class="text-gray-600 dark:text-gray-400">猜一个 1-100 的随机数字。</p>
  </div>
  <NumberGuessTool cleanPath="/tools/number-guess/clean/" showCleanLink />
</MainLayout>
