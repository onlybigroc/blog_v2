---
import MainLayout from '@layouts/MainLayout.astro';
import TruncateUrlTool from '@components/tools/TruncateUrlTool.astro';
const title = 'URL 截断 | 工具';
const description = '截断长 URL，保留关键部分。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">URL 截断</h1>
    <p class="text-gray-600 dark:text-gray-400">截断长 URL，保留关键部分。</p>
  </div>
  <TruncateUrlTool cleanPath="/tools/truncate-url/clean/" showCleanLink />
</MainLayout>
