---
import MainLayout from '@layouts/MainLayout.astro';
import AesEncryptTool from '@components/tools/AesEncryptTool.astro';
const title = 'AES 加解密 | 工具';
const description = '使用 AES 算法加密和解密文本。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">AES 加解密</h1>
    <p class="text-gray-600 dark:text-gray-400">使用 AES 算法加密和解密文本。</p>
  </div>
  <AesEncryptTool cleanPath="/tools/aes-encrypt/clean/" showCleanLink />
</MainLayout>
