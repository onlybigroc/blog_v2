---
import MainLayout from '@layouts/MainLayout.astro';
import TextDiffTool from '@components/tools/TextDiffTool.astro';

const title = '文本差异对比 | 工具';
const description = '逐行对比两段文本，高亮显示差异。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-3">文本差异对比</h1>
    <p class="text-gray-600 dark:text-gray-400">逐行对比两段文本，高亮显示差异。</p>
  </div>
  <TextDiffTool cleanPath="/tools/text-diff/clean/" showCleanLink />
</MainLayout>
