---
import MainLayout from '@layouts/MainLayout.astro';
import CssVariableExtractTool from '@components/tools/CssVariableExtractTool.astro';
const title = 'CSS 变量提取 | 工具';
const description = '从 CSS 代码中提取所有自定义属性。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">CSS 变量提取</h1>
    <p class="text-gray-600 dark:text-gray-400">从 CSS 代码中提取所有自定义属性。</p>
  </div>
  <CssVariableExtractTool cleanPath="/tools/css-variable-extract/clean/" showCleanLink />
</MainLayout>
