---
import MainLayout from '@layouts/MainLayout.astro';
import SplitBillTool from '@components/tools/SplitBillTool.astro';
const title = 'AA 制分账 | 工具';
const description = '将账单平均分摊给多人。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">AA 制分账</h1>
    <p class="text-gray-600 dark:text-gray-400">将账单平均分摊给多人。</p>
  </div>
  <SplitBillTool cleanPath="/tools/split-bill/clean/" showCleanLink />
</MainLayout>
