---
import MainLayout from '@layouts/MainLayout.astro';
import JsonSchemaGenTool from '@components/tools/JsonSchemaGenTool.astro';
const title = 'JSON Schema 生成器 | 工具';
const description = '从 JSON 数据自动生成 JSON Schema。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">JSON Schema 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">从 JSON 数据自动生成 JSON Schema。</p>
  </div>
  <JsonSchemaGenTool cleanPath="/tools/json-schema-gen/clean/" showCleanLink />
</MainLayout>
