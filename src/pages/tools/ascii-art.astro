---
import MainLayout from '@layouts/MainLayout.astro';
import AsciiArtTool from '@components/tools/AsciiArtTool.astro';
const title = 'ASCII Art 生成器 | 工具';
const description = '将文本转换为 ASCII 艺术字。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">ASCII Art 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">将文本转换为 ASCII 艺术字。</p>
  </div>
  <AsciiArtTool cleanPath="/tools/ascii-art/clean/" showCleanLink />
</MainLayout>
