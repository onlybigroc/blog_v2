---
import MainLayout from '@layouts/MainLayout.astro';
import ColorTool from '@components/tools/ColorTool.astro';

const title = '颜色转换器 | 工具';
const description = 'HEX、RGB、HSL 颜色格式互转，含色板和随机颜色。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">颜色转换器</h1>
    <p class="text-gray-600 dark:text-gray-400">HEX / RGB / HSL 三种格式互转，实时预览。</p>
  </div>

  <ColorTool />
</MainLayout>
