---
import MainLayout from '@layouts/MainLayout.astro';
import QrGenTool from '@components/tools/QrGenTool.astro';
const title = '二维码生成器 | 工具';
const description = '将文本或 URL 生成二维码。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">二维码生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">将文本或 URL 生成二维码。</p>
  </div>
  <QrGenTool cleanPath="/tools/qr-gen/clean/" showCleanLink />
</MainLayout>
