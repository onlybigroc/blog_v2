---
import MainLayout from '@layouts/MainLayout.astro';
import CaseConvertTool from '@components/tools/CaseConvertTool.astro';

const title = '大小写转换 | 工具';
const description = '英文文本大小写、首字母大写、句首大写等多种转换。';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">大小写转换</h1>
    <p class="text-gray-600 dark:text-gray-400">英文文本大小写、首字母大写、句首大写等多种转换。</p>
  </div>

  <CaseConvertTool cleanPath="/tools/case-convert/clean/" showCleanLink />
</MainLayout>
