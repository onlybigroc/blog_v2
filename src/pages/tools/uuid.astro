---
import MainLayout from '@layouts/MainLayout.astro';
import UuidTool from '@components/tools/UuidTool.astro';
const title = 'UUID 生成器 | 工具';
const description = '生成 UUID v4，支持批量生成和格式自定义。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-3">UUID 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">生成 UUID v4，支持批量生成和格式自定义。</p>
  </div>
  <UuidTool cleanPath="/tools/uuid/clean/" showCleanLink />
</MainLayout>
