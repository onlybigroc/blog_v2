export async function getStaticPaths() {
  return tools
    .filter(tool => tool.status !== 'draft')
    .map(tool => ({
      params: { slug: tool.id },
      props: { tool },
    }));
}

const { tool } = Astro.props;
const ToolComponent = componentMap[tool.id];

if (!ToolComponent) {
  throw new Error(`Tool component not found for: ${tool.id}`);
}

const title = `${tool.name} | 工具`;
const description = tool.description;
---

<ToolLayout title={title} description={description}>
  <ToolComponent />
</ToolLayout>
