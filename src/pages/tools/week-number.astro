---
import MainLayout from '@layouts/MainLayout.astro';
import WeekNumberTool from '@components/tools/WeekNumberTool.astro';
const title = '周数查询 | 工具';
const description = '查询日期是当年的第几周。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">周数查询</h1>
    <p class="text-gray-600 dark:text-gray-400">查询日期是当年的第几周。</p>
  </div>
  <WeekNumberTool cleanPath="/tools/week-number/clean/" showCleanLink />
</MainLayout>
