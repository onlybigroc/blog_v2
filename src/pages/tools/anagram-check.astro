---
import MainLayout from '@layouts/MainLayout.astro';
import AnagramCheckTool from '@components/tools/AnagramCheckTool.astro';
const title = '变位词检测 | 工具';
const description = '检测两个文本是否为变位词。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">变位词检测</h1>
    <p class="text-gray-600 dark:text-gray-400">检测两个文本是否为变位词。</p>
  </div>
  <AnagramCheckTool cleanPath="/tools/anagram-check/clean/" showCleanLink />
</MainLayout>
