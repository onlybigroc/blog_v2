---
import MainLayout from '@layouts/MainLayout.astro';
import CalendarGenTool from '@components/tools/CalendarGenTool.astro';
const title = '日历生成器 | 工具';
const description = '生成指定月份的日历。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">日历生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">生成指定月份的日历。</p>
  </div>
  <CalendarGenTool cleanPath="/tools/calendar-gen/clean/" showCleanLink />
</MainLayout>
