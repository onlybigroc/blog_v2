---
import MainLayout from '@layouts/MainLayout.astro';
import CssClipPathTool from '@components/tools/CssClipPathTool.astro';
const title = 'Clip Path 生成器 | 工具';
const description = '可视化创建 CSS clip-path 裁剪效果。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">Clip Path 生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">可视化创建 CSS clip-path 裁剪效果。</p>
  </div>
  <CssClipPathTool cleanPath="/tools/css-clip-path/clean/" showCleanLink />
</MainLayout>
