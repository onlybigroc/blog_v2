---
import MainLayout from '@layouts/MainLayout.astro';
import DrawLotsTool from '@components/tools/DrawLotsTool.astro';
const title = '抽签器 | 工具';
const description = '从列表中随机抽取项目。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">抽签器</h1>
    <p class="text-gray-600 dark:text-gray-400">从列表中随机抽取项目。</p>
  </div>
  <DrawLotsTool cleanPath="/tools/draw-lots/clean/" showCleanLink />
</MainLayout>
