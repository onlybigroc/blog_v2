---
import MainLayout from '@layouts/MainLayout.astro';
import TextWrapTool from '@components/tools/TextWrapTool.astro';
const title = '文本换行工具 | 工具';
const description = '按指定字符数自动换行。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">文本换行工具</h1>
    <p class="text-gray-600 dark:text-gray-400">按指定字符数自动换行。</p>
  </div>
  <TextWrapTool cleanPath="/tools/text-wrap/clean/" showCleanLink />
</MainLayout>
