---
import MainLayout from '@layouts/MainLayout.astro';
import { tools } from '@/data/tools';

const title = '工具 | 个人技术博客-bigroc';
const description = '常用在线工具集合，后续会持续迁移和补充。';

const readyTools = tools.filter((tool) => tool.status !== 'draft');
const draftTools = tools.filter((tool) => tool.status === 'draft');
---

<MainLayout title={title} description={description}>
  <div class="mb-10">
    <h1 class="text-4xl font-bold mb-3">工具</h1>
    <p class="text-gray-600 dark:text-gray-400">
      这里会逐步迁移我常用的工具页面，统一收口到 <code class="px-2 py-1 rounded bg-gray-100 dark:bg-gray-800">/tools</code> 模块。
    </p>
  </div>

  {readyTools.length === 0 ? (
    <section class="rounded-xl border border-dashed border-gray-300 dark:border-gray-700 p-8">
      <h2 class="text-xl font-semibold mb-2">暂无已发布工具</h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">
        你可以先把工具页面迁移到 <code class="px-2 py-1 rounded bg-gray-100 dark:bg-gray-800">src/pages/tools</code>，然后在
        <code class="mx-1 px-2 py-1 rounded bg-gray-100 dark:bg-gray-800">src/data/tools.ts</code> 增加入口配置。
      </p>
      <div class="text-sm text-gray-500 dark:text-gray-500">
        示例路径：<code class="px-2 py-1 rounded bg-gray-100 dark:bg-gray-800">src/pages/tools/json-format.astro</code>
      </div>
    </section>
  ) : (
    <section>
      <h2 class="text-2xl font-bold mb-6">已发布</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {readyTools.map((tool) => (
          <a
            href={tool.path}
            class="block rounded-xl border border-gray-200 dark:border-gray-700 p-5 hover:border-primary-500 dark:hover:border-primary-400 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors"
          >
            <h3 class="text-lg font-semibold text-primary-600 dark:text-primary-400 mb-2">{tool.name}</h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {draftTools.length > 0 && (
    <section class="mt-10">
      <h2 class="text-2xl font-bold mb-4">迁移中</h2>
      <ul class="space-y-3">
        {draftTools.map((tool) => (
          <li class="rounded-lg border border-gray-200 dark:border-gray-700 p-4">
            <p class="font-medium">{tool.name}</p>
            <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{tool.description}</p>
          </li>
        ))}
      </ul>
    </section>
  )}
</MainLayout>
