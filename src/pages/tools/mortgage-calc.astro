---
import MainLayout from '@layouts/MainLayout.astro';
import MortgageCalcTool from '@components/tools/MortgageCalcTool.astro';
const title = '房贷计算器 | 工具';
const description = '计算等额本息/等额本金月供。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">房贷计算器</h1>
    <p class="text-gray-600 dark:text-gray-400">计算等额本息/等额本金月供。</p>
  </div>
  <MortgageCalcTool cleanPath="/tools/mortgage-calc/clean/" showCleanLink />
</MainLayout>
