---
import MainLayout from '@layouts/MainLayout.astro';
import TextEncryptTool from '@components/tools/TextEncryptTool.astro';
const title = '文本加密 | 工具';
const description = '使用简单加密算法对文本进行加密/解密。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">文本加密</h1>
    <p class="text-gray-600 dark:text-gray-400">使用简单加密算法对文本进行加密/解密。</p>
  </div>
  <TextEncryptTool cleanPath="/tools/text-encrypt/clean/" showCleanLink />
</MainLayout>
