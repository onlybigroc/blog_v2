---
import MainLayout from '@layouts/MainLayout.astro';
import QuoteWrapTool from '@components/tools/QuoteWrapTool.astro';
const title = '引号包裹工具 | 工具';
const description = '为每行文本添加引号。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">引号包裹工具</h1>
    <p class="text-gray-600 dark:text-gray-400">为每行文本添加引号。</p>
  </div>
  <QuoteWrapTool cleanPath="/tools/quote-wrap/clean/" showCleanLink />
</MainLayout>
