---
import MainLayout from '@layouts/MainLayout.astro';
import WordLimiterTool from '@components/tools/WordLimiterTool.astro';
const title = '字数限制器 | 工具';
const description = '限制文本字数，超出部分截断或提示。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">字数限制器</h1>
    <p class="text-gray-600 dark:text-gray-400">限制文本字数，超出部分截断或提示。</p>
  </div>
  <WordLimiterTool cleanPath="/tools/word-limiter/clean/" showCleanLink />
</MainLayout>
