---
import MainLayout from '@layouts/MainLayout.astro';
import Base64ImageTool from '@components/tools/Base64ImageTool.astro';
const title = 'Base64 图片预览 | 工具';
const description = '粘贴 Base64 编码的图片数据，实时预览并下载。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">Base64 图片预览</h1>
    <p class="text-gray-600 dark:text-gray-400">粘贴 Base64 编码的图片数据，实时预览并下载。</p>
  </div>
  <Base64ImageTool cleanPath="/tools/base64-image/clean/" showCleanLink />
</MainLayout>
