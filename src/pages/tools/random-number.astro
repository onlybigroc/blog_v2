---
import MainLayout from '@layouts/MainLayout.astro';
import RandomNumberTool from '@components/tools/RandomNumberTool.astro';
const title = '随机数生成器 | 工具';
const description = '生成指定范围内的随机数。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">随机数生成器</h1>
    <p class="text-gray-600 dark:text-gray-400">生成指定范围内的随机数。</p>
  </div>
  <RandomNumberTool cleanPath="/tools/random-number/clean/" showCleanLink />
</MainLayout>
