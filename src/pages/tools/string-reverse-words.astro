---
import MainLayout from '@layouts/MainLayout.astro';
import StringReverseWordsTool from '@components/tools/StringReverseWordsTool.astro';
const title = '单词反转 | 工具';
const description = '反转英文文本中单词的顺序。';
---
<MainLayout title={title} description={description}>
  <div class="mb-8">
    <a href="/tools" class="text-sm text-primary-600 dark:text-primary-400 hover:underline">← 返回工具列表</a>
    <h1 class="text-3xl font-bold mt-3 mb-2">单词反转</h1>
    <p class="text-gray-600 dark:text-gray-400">反转英文文本中单词的顺序。</p>
  </div>
  <StringReverseWordsTool cleanPath="/tools/string-reverse-words/clean/" showCleanLink />
</MainLayout>
