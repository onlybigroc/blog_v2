---
import MainLayout from '@layouts/MainLayout.astro';
import { getAiNewsDigest } from '@data/aiNews';
import { calculateReadingTime, calculateWordCount, formatChineseDateTime } from '@utils/site';

export function getStaticPaths() {
  const digest = getAiNewsDigest();

  return digest.items.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const contentSource = item.originalContentText || item.summaryZh || item.summary || item.titleZh || item.title;
const displayImage = item.coverImage || item.coverImageOriginal;
const coverImageWidth = item.coverImageWidth || 1200;
const coverImageHeight = item.coverImageHeight || 800;
const formattedPublishedDate = formatChineseDateTime(item.publishedAt);
const formattedArchiveDate = formatChineseDateTime(item.archiveFirstSeenAt);
const rawContentBlocks = item.originalContentText
  .split(/\n{2,}/)
  .map((block: string) => block.trim())
  .filter(Boolean);
const contentBlocks =
  rawContentBlocks.length > 1
    ? rawContentBlocks
    : item.originalContentText
        .split(/(?<=[。！？!?])\s+/)
        .map((sentence: string) => sentence.trim())
        .filter(Boolean)
        .reduce((blocks: string[], sentence: string) => {
          const current = blocks[blocks.length - 1] || '';

          if (!current || current.length >= 180) {
            blocks.push(sentence);
            return blocks;
          }

          blocks[blocks.length - 1] = `${current} ${sentence}`.trim();
          return blocks;
        }, []);
const description = item.summaryZh || item.summary || item.titleZh || item.title;
const siteURL = Astro.site?.toString() || 'https://bigroc.cn';
const canonicalURL = new URL(`/ai-news/${item.id}`, siteURL).toString();
const readingTime = calculateReadingTime(contentSource);
const wordCount = calculateWordCount(contentSource);
---

<MainLayout
  title={item.titleZh || item.title}
  description={description}
  image={displayImage || undefined}
  type="article"
  canonicalURL={canonicalURL}
  publishedTime={item.publishedAt}
  modifiedTime={item.lastSeenAt}
  wordCount={wordCount}
  section="AI 资讯"
  keywords={item.tags.join(',')}
  breadcrumbs={[
    { name: '首页', url: siteURL },
    { name: 'AI 资讯', url: `${siteURL}ai-news` },
    { name: item.titleZh || item.title, url: canonicalURL }
  ]}
>
  <article class="prose prose-lg mx-auto max-w-none dark:prose-invert">
    <header class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-800">
      <h1 class="text-4xl font-bold mb-4">{item.titleZh || item.title}</h1>
      {item.titleZh && item.titleZh !== item.title && (
        <p class="mt-0 mb-4 text-lg text-gray-600 dark:text-gray-400">{item.title}</p>
      )}

      <div class="flex flex-wrap gap-4 items-center text-sm text-gray-600 dark:text-gray-400">
        <time datetime={item.publishedAt}>{formattedPublishedDate}</time>
        <span>{item.source}</span>
        <span>{item.sourceRegion === 'cn' ? '中文资讯' : '国际资讯'}</span>
        <span>{item.importance}</span>
        <span>{readingTime} 分钟阅读</span>
        <span>{wordCount} 字</span>
        <span>归档：{formattedArchiveDate}</span>
        <a
          href={item.link}
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-600 hover:underline dark:text-primary-400"
        >
          查看原文 →
        </a>
      </div>

      {item.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4 not-prose">
          {item.tags.map((tag) => (
            <span class="px-3 py-1 bg-primary-100 text-primary-700 rounded text-sm dark:bg-primary-900/30 dark:text-primary-300">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {displayImage && (
      <figure class="not-prose mb-8 overflow-hidden rounded-2xl border border-gray-200 dark:border-gray-800">
        <img
          src={displayImage}
          alt={item.coverImageAlt || item.titleZh || item.title}
          width={coverImageWidth}
          height={coverImageHeight}
          class="w-full max-h-[460px] object-cover"
          loading="lazy"
        />
      </figure>
    )}

    {(item.summaryZh || item.summary) && (
      <div class="not-prose mb-8 rounded-2xl border border-primary-100 bg-primary-50/70 p-6 dark:border-primary-900/40 dark:bg-primary-900/20">
        <h2 class="text-2xl font-bold">导读</h2>
        {item.summaryZh && <p class="mt-4 leading-8 text-gray-800 dark:text-gray-200">{item.summaryZh}</p>}
        {item.summary && item.summary !== item.summaryZh && (
          <p class="mt-3 text-sm leading-7 text-gray-600 dark:text-gray-400">{item.summary}</p>
        )}
      </div>
    )}

    <h2>原文快照</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400">
      站内保留一份可阅读的正文副本；如抓取失败，则保留摘要和原文链接。
    </p>

    {item.originalContentAvailable && contentBlocks.length > 0 ? (
      contentBlocks.map((block: string) => <p>{block}</p>)
    ) : (
      <div class="not-prose mt-6 rounded-2xl border border-dashed border-gray-300 p-6 text-sm text-gray-500 dark:border-gray-700 dark:text-gray-400">
        <p>{item.originalContentWarning || '未抓取到正文快照。'}</p>
        <p class="mt-2">
          可通过
          <a href={item.link} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:underline dark:text-primary-400">
            原文链接
          </a>
          查看完整内容。
        </p>
      </div>
    )}

    <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 not-prose">
      <a href="/ai-news" class="text-primary-600 hover:underline dark:text-primary-400">← 返回 AI 资讯</a>
    </footer>
  </article>
</MainLayout>
