---
import PostCard from '@components/PostCard.astro';
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const title = '文章列表';
const description = '所有博客文章';

const allPosts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentPage = 1;
const pageSize = 20;
const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / pageSize);
const posts = allPosts.slice(0, pageSize);
const paginationPages = Array.from({ length: Math.min(totalPages - 1, 9) }, (_, index) => index + 2);
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">文章列表</h1>
    <p class="text-gray-600 dark:text-gray-400">共 {totalPosts} 篇文章</p>
  </div>

  <div class="space-y-8">
    {posts.map((post) => (
      <PostCard key={post.id} post={post} showCategories={true} />
    ))}
  </div>

  {totalPages > 1 && (
    <div class="mt-12 flex justify-center gap-2">
      <span class="px-4 py-2 bg-primary-600 text-white rounded">1</span>
      {paginationPages.map((pageNumber) => (
        <Fragment key={pageNumber}>
          <a
            href={`/posts/page/${pageNumber}`}
            class="px-4 py-2 bg-gray-100 text-gray-700 rounded hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
          >
            {pageNumber}
          </a>
        </Fragment>
      ))}
    </div>
  )}
</MainLayout>
