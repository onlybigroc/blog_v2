---
import Pagination from '@components/Pagination.astro';
import PostCard from '@components/PostCard.astro';
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  const pageSize = 20;
  const totalPages = Math.ceil(allPosts.length / pageSize);

  if (totalPages <= 1) {
    return [];
  }

  return Array.from({ length: totalPages - 1 }, (_, index) => {
    const currentPage = index + 2;
    return {
      params: { page: String(currentPage) },
      props: {
        posts: allPosts.slice((currentPage - 1) * pageSize, currentPage * pageSize),
        currentPage,
        totalPages,
        totalPosts: allPosts.length,
      },
    };
  });
}

const { posts, currentPage, totalPages, totalPosts } = Astro.props;
const title = `文章列表 - 第 ${currentPage} 页 | 个人技术博客 bigroc`;
const description = '所有博客文章';
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">文章列表</h1>
    <p class="text-gray-600 dark:text-gray-400">
      共 {totalPosts} 篇文章 · 第 {currentPage}/{totalPages} 页
    </p>
  </div>

  <div class="space-y-8">
    {posts.map((post) => (
      <PostCard key={post.id} post={post} showCategories={true} />
    ))}
  </div>

  <Pagination currentPage={currentPage} totalPages={totalPages} basePath="/posts/page" />
</MainLayout>
