---
import GiscusComments from '@components/GiscusComments.astro';
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getPostUrl, getTagUrl } from '@utils/slug';

export async function getStaticPaths() {
  const getInternalOriginPostSlug = (originUrl: string): string | null => {
    const match = originUrl.match(/^\/posts\/(.+?)\/?$/);

    if (!match) {
      return null;
    }

    const [, slug] = match;

    if (!slug || slug.startsWith('page/')) {
      return null;
    }

    return slug;
  };

  const posts = await getCollection('posts');
  const sortedPosts = posts
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  // 为每篇文章生成相关文章
  const getRelatedPosts = (currentPost: any, allPosts: any[]) => {
    return allPosts
      .filter((p) => p.id !== currentPost.id && !p.data.draft)
      .map((p) => {
        // 计算标签匹配度
        const commonTags = p.data.tags.filter((tag: string) => 
          currentPost.data.tags.includes(tag)
        );
        return {
          ...p,
          matchScore: commonTags.length
        };
      })
      .filter((p) => p.matchScore > 0)
      .sort((a, b) => b.matchScore - a.matchScore)
      .slice(0, 3);
  };

  return sortedPosts.flatMap((post, index) => {
    const prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
    const nextPost = index > 0 ? sortedPosts[index - 1] : null;
    const relatedPosts = getRelatedPosts(post, sortedPosts);
    const canonicalSlug = getPostUrl(post.id);
    const aliasSlug = getInternalOriginPostSlug(post.data.originUrl);
    const slugs = aliasSlug && aliasSlug !== canonicalSlug ? [canonicalSlug, aliasSlug] : [canonicalSlug];

    return slugs.map((slug) => ({
      params: { slug },
      props: {
        post,
        prevPost,
        nextPost,
        relatedPosts,
      },
    }));
  });
}

const { post, prevPost, nextPost, relatedPosts } = Astro.props;
const { Content } = await post.render();
const summary = post.data.summary.trim();
const siteURL = Astro.site?.toString() || 'https://bigroc.cn';
const canonicalURL = new URL(`/posts/${getPostUrl(post.id)}`, siteURL).toString();
---

<MainLayout
  title={post.data.title}
  description={summary}
  image={post.data.cover}
  canonicalURL={canonicalURL}
  publishedTime={post.data.date}
  modifiedTime={post.data.date}
>
  <article class="prose prose-lg mx-auto max-w-none dark:prose-invert">
    <header class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-800">
      <h1 class="text-4xl font-bold mb-4">{post.data.title}</h1>
      <div class="flex flex-wrap gap-4 items-center text-sm text-gray-600 dark:text-gray-400">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>

        {post.data.categories.length > 0 && <span>分类：{post.data.categories.join(', ')}</span>}

        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
          <span id="view-count">0</span>
        </span>

        <a
          href={post.data.originUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-600 hover:underline dark:text-primary-400"
        >
          查看原文 →
        </a>
      </div>

      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag) => (
            <Fragment key={tag}>
              <a
                href={getTagUrl(tag)}
                class="px-3 py-1 bg-primary-100 text-primary-700 rounded text-sm transition hover:bg-primary-200 dark:bg-primary-900/30 dark:text-primary-300 dark:hover:bg-primary-900/50"
              >
                {tag}
              </a>
            </Fragment>
          ))}
        </div>
      )}
    </header>

    <Content />

    <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="flex justify-center mb-8">
        <button
          id="like-button"
          class="group flex items-center gap-3 px-6 py-3 rounded-full bg-gray-100 transition-all duration-300 hover:scale-110 hover:bg-red-50 dark:bg-gray-800 dark:hover:bg-red-900/20"
          aria-label="点赞"
        >
          <svg
            id="like-icon"
            class="w-6 h-6 text-gray-400 transition-colors duration-300 group-hover:text-red-500"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          <span id="like-count" class="font-medium text-gray-700 dark:text-gray-300">0</span>
        </button>
      </div>

      <nav class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        {prevPost ? (
          <a
            href={`/posts/${getPostUrl(prevPost.id)}`}
            class="group p-4 rounded-lg border border-gray-200 transition-all hover:shadow-md hover:border-primary-500 dark:border-gray-700 dark:hover:border-primary-500"
          >
            <div class="text-sm text-gray-500 mb-1 dark:text-gray-400">← 上一篇</div>
            <div class="font-medium text-gray-900 transition line-clamp-2 group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
              {prevPost.data.title}
            </div>
          </a>
        ) : (
          <div class="p-4 rounded-lg border border-gray-200 opacity-50 dark:border-gray-700">
            <div class="text-sm text-gray-500 mb-1 dark:text-gray-400">← 上一篇</div>
            <div class="text-gray-400 dark:text-gray-600">已经是最早文章</div>
          </div>
        )}

        {nextPost ? (
          <a
            href={`/posts/${getPostUrl(nextPost.id)}`}
            class="group p-4 rounded-lg border border-gray-200 text-right transition-all hover:shadow-md hover:border-primary-500 dark:border-gray-700 dark:hover:border-primary-500"
          >
            <div class="text-sm text-gray-500 mb-1 dark:text-gray-400">下一篇 →</div>
            <div class="font-medium text-gray-900 transition line-clamp-2 group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
              {nextPost.data.title}
            </div>
          </a>
        ) : (
          <div class="p-4 rounded-lg border border-gray-200 opacity-50 text-right dark:border-gray-700">
            <div class="text-sm text-gray-500 mb-1 dark:text-gray-400">下一篇 →</div>
            <div class="text-gray-400 dark:text-gray-600">已经是最新文章</div>
          </div>
        )}
      </nav>

      <!-- 相关文章推荐 -->
      {relatedPosts.length > 0 && (
        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
          <h3 class="text-2xl font-bold mb-6">相关文章</h3>
          <div class="space-y-6">
            {relatedPosts.map((relatedPost) => (
              <article key={relatedPost.id} class="border-b border-gray-200 pb-6 last:border-0 dark:border-gray-800">
                <h4 class="text-xl font-bold mb-2">
                  <a 
                    href={`/posts/${getPostUrl(relatedPost.id)}`} 
                    class="text-primary-600 hover:underline dark:text-primary-400"
                  >
                    {relatedPost.data.title}
                  </a>
                </h4>
                <div class="flex flex-wrap gap-4 text-sm text-gray-600 mb-3 dark:text-gray-400">
                  <time datetime={relatedPost.data.date.toISOString()}>
                    {relatedPost.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                  {relatedPost.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2">
                      {relatedPost.data.tags.slice(0, 3).map((tag) => (
                        <a
                          key={tag}
                          href={getTagUrl(tag)}
                          class="px-2 py-1 bg-primary-100 text-primary-700 rounded text-xs transition-colors hover:bg-primary-200 dark:bg-primary-900/30 dark:text-primary-300 dark:hover:bg-primary-900/50"
                        >
                          {tag}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
                {relatedPost.data.summary && (
                  <p class="text-gray-700 line-clamp-2 dark:text-gray-300">
                    {relatedPost.data.summary}
                  </p>
                )}
              </article>
            ))}
          </div>
        </div>
      )}

      <div class="text-center mt-12">
        <a href="/" class="text-primary-600 hover:underline dark:text-primary-400">← 返回首页</a>
      </div>
    </footer>
  </article>

  <GiscusComments />

  <style>
    .liked {
      fill: currentColor !important;
      color: #ef4444 !important;
    }
  </style>

  <script>
    import { formatCount, recordView, toggleLike } from '@utils/stats';

    const postId = window.location.pathname.replace('/posts/', '').replace(/\/$/, '');

    document.addEventListener('DOMContentLoaded', async () => {
      const stats = await recordView(postId);

      const viewCountEl = document.getElementById('view-count');
      if (viewCountEl) {
        viewCountEl.textContent = formatCount(stats.views);
      }

      const likeCountEl = document.getElementById('like-count');
      const likeIcon = document.getElementById('like-icon');
      const likeButton = document.getElementById('like-button');

      if (likeCountEl) {
        likeCountEl.textContent = formatCount(stats.likes);
      }

      if (stats.liked && likeIcon) {
        likeIcon.classList.add('liked');
      }

      if (likeButton) {
        likeButton.addEventListener('click', async () => {
          const newStats = await toggleLike(postId);

          if (likeCountEl) {
            likeCountEl.textContent = formatCount(newStats.likes);
          }

          if (likeIcon) {
            if (newStats.liked) {
              likeIcon.classList.add('liked');
              likeButton.classList.add('scale-125');
              setTimeout(() => likeButton.classList.remove('scale-125'), 200);
            } else {
              likeIcon.classList.remove('liked');
            }
          }
        });
      }
    });
  </script>
</MainLayout>
