---
import GiscusComments from '@components/GiscusComments.astro';
import PageLikeButton from '@components/PageLikeButton.astro';
import AuthorBio from '@components/post/AuthorBio.astro';
import PostNav from '@components/post/PostNav.astro';
import RelatedPosts from '@components/post/RelatedPosts.astro';
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getExternalOriginUrl, getPostPath, getPostUrl, getTagUrl, normalizePostSlug } from '@utils/slug';
import { calculateReadingTime, calculateWordCount } from '@utils/site';

export async function getStaticPaths() {
  const getInternalOriginPostSlug = (originUrl: string): string | null => {
    const match = originUrl.match(/^\/posts\/(.+?)\/?$/);

    if (!match) {
      return null;
    }

    const [, slug] = match;

    if (!slug || slug.startsWith('page/')) {
      return null;
    }

    return normalizePostSlug(slug);
  };

  const posts = await getCollection('posts');
  const sortedPosts = posts
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  const postsByTag = new Map<string, typeof sortedPosts>();
  for (const post of sortedPosts) {
    for (const tag of post.data.tags) {
      const tagPosts = postsByTag.get(tag) || [];
      tagPosts.push(post);
      postsByTag.set(tag, tagPosts);
    }
  }

  const relatedPostsById = new Map<string, typeof sortedPosts>();
  for (const post of sortedPosts) {
    const scores = new Map<string, { post: (typeof sortedPosts)[number]; matchScore: number }>();

    for (const tag of post.data.tags) {
      for (const candidate of postsByTag.get(tag) || []) {
        if (candidate.id === post.id) {
          continue;
        }

        const scored = scores.get(candidate.id);
        if (scored) {
          scored.matchScore += 1;
        } else {
          scores.set(candidate.id, { post: candidate, matchScore: 1 });
        }
      }
    }

    relatedPostsById.set(
      post.id,
      [...scores.values()]
        .sort((a, b) => b.matchScore - a.matchScore || b.post.data.date.getTime() - a.post.data.date.getTime())
        .slice(0, 3)
        .map(({ post }) => post)
    );
  }

  return sortedPosts.flatMap((post, index) => {
    const prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;
    const nextPost = index > 0 ? sortedPosts[index - 1] : null;
    const relatedPosts = relatedPostsById.get(post.id) || [];
    const canonicalSlug = getPostUrl(post);
    const fileSlug = getPostUrl(post.id);
    const aliasSlug = getInternalOriginPostSlug(post.data.originUrl);
    const slugs = [...new Set([canonicalSlug, fileSlug, aliasSlug].filter(Boolean))];

    return slugs.map((slug) => ({
      params: { slug },
      props: {
        post,
        prevPost,
        nextPost,
        relatedPosts,
      },
    }));
  });
}

const { post, prevPost, nextPost, relatedPosts } = Astro.props;
const { Content } = await post.render();
const summary = post.data.summary.trim();
const siteURL = Astro.site?.toString() || 'https://bigroc.cn';
const postPath = getPostPath(post);
const canonicalURL = new URL(postPath, siteURL).toString();
const externalOriginUrl = getExternalOriginUrl(post.data.originUrl);
const readingTime = calculateReadingTime(post.body);
const wordCount = calculateWordCount(post.body);
---

<MainLayout
  title={post.data.title}
  description={summary}
  image={post.data.cover}
  canonicalURL={canonicalURL}
  publishedTime={post.data.date}
  modifiedTime={post.data.date}
  author="bigroc"
  wordCount={wordCount}
  section={post.data.categories[0] || undefined}
  keywords={post.data.tags.join(',')}
  breadcrumbs={[
    { name: '首页', url: siteURL },
    { name: '文章', url: `${siteURL}posts` },
    { name: post.data.title, url: canonicalURL }
  ]}
>
  <article class="prose prose-lg mx-auto max-w-none dark:prose-invert">
    <header class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-800">
      <h1 class="text-4xl font-bold mb-4">{post.data.title}</h1>
      <div class="flex flex-wrap gap-4 items-center text-sm text-gray-600 dark:text-gray-400">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>

        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          {readingTime} 分钟阅读
        </span>

        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          {wordCount} 字
        </span>

        {post.data.categories.length > 0 && <span>分类：{post.data.categories.join(', ')}</span>}

        <span class="flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
          <span id="view-count">0</span>
        </span>

        <a href={postPath} class="text-primary-600 hover:underline dark:text-primary-400">
          本文链接
        </a>

        {externalOriginUrl && (
          <a
            href={externalOriginUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary-600 hover:underline dark:text-primary-400"
          >
            原始出处 →
          </a>
        )}
      </div>

      {post.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag) => (
            <Fragment key={tag}>
              <a
                href={getTagUrl(tag)}
                class="px-3 py-1 bg-primary-100 text-primary-700 rounded text-sm transition hover:bg-primary-200 dark:bg-primary-900/30 dark:text-primary-300 dark:hover:bg-primary-900/50"
              >
                {tag}
              </a>
            </Fragment>
          ))}
        </div>
      )}
    </header>

    <Content />

    <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
      <div class="flex justify-center mb-8">
        <PageLikeButton />
      </div>

      <PostNav prevPost={prevPost} nextPost={nextPost} />
      <RelatedPosts relatedPosts={relatedPosts} />
      <AuthorBio />

      <div class="text-center mt-12">
        <a href="/" class="text-primary-600 hover:underline dark:text-primary-400">← 返回首页</a>
      </div>
    </footer>
  </article>

  <GiscusComments />

  <script>
    import { formatCount, recordView } from '@utils/stats';

    const postId = window.location.pathname.replace('/posts/', '').replace(/\/$/, '');

    document.addEventListener('DOMContentLoaded', async () => {
      const stats = await recordView(postId);

      const viewCountEl = document.getElementById('view-count');
      if (viewCountEl) {
        viewCountEl.textContent = formatCount(stats.views);
      }
    });
  </script>
</MainLayout>
