---
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';

const title = '搜索';
const description = '搜索博客文章';
const totalPosts = (await getCollection('posts')).filter((post) => !post.data.draft).length;
---

<MainLayout title={title} description={description} robots="noindex, nofollow" loadAds={false}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-6">搜索文章</h1>

    <div class="space-y-2">
      <label for="search-input" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
        搜索关键词
      </label>
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="输入关键词搜索文章标题、标签或摘要..."
          class="w-full px-4 py-3 pr-12 border border-gray-300 rounded-lg bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-primary-500 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-100"
          autofocus
        />
        <svg class="absolute right-4 top-3.5 w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
    </div>

    <div id="search-stats" class="mt-4 text-sm text-gray-600 dark:text-gray-400"></div>
  </div>

  <div id="search-results" class="space-y-8"></div>

  <div id="no-results" class="hidden text-center py-12">
    <svg class="mx-auto w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <p class="text-gray-600 text-lg dark:text-gray-400">没有找到相关文章</p>
    <p class="text-gray-500 text-sm mt-2 dark:text-gray-500">试试其他关键词吧</p>
  </div>

  <div id="search-prompt" class="text-center py-12">
    <svg class="mx-auto w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
    </svg>
    <p class="text-gray-600 text-lg dark:text-gray-400">输入关键词开始搜索</p>
    <p class="text-gray-500 text-sm mt-2 dark:text-gray-500">共 {totalPosts} 篇文章可供搜索</p>
  </div>
</MainLayout>

<script>
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const searchStats = document.getElementById('search-stats');
  const noResults = document.getElementById('no-results');
  const searchPrompt = document.getElementById('search-prompt');

  let searchIndexPromise;

  function resetSearchState() {
    searchResults.replaceChildren();
    searchStats.textContent = '';
    noResults.classList.add('hidden');
    searchPrompt.classList.remove('hidden');
  }

  async function loadSearchIndex() {
    if (!searchIndexPromise) {
      searchIndexPromise = fetch('/search-index.json').then(async (response) => {
        if (!response.ok) {
          throw new Error(`Failed to load search index: ${response.status}`);
        }

        return response.json();
      });
    }

    return searchIndexPromise;
  }

  function tokenizeQuery(query) {
    return Array.from(new Set(query.toLowerCase().split(/\s+/).filter(Boolean))).sort((a, b) => b.length - a.length);
  }

  function escapeRegex(value) {
    return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function createHighlightedFragment(text, keywords) {
    const fragment = document.createDocumentFragment();

    if (!text) {
      return fragment;
    }

    if (keywords.length === 0) {
      fragment.append(document.createTextNode(text));
      return fragment;
    }

    const pattern = new RegExp(`(${keywords.map(escapeRegex).join('|')})`, 'gi');
    let lastIndex = 0;

    for (const match of text.matchAll(pattern)) {
      const matchIndex = match.index ?? 0;

      if (matchIndex > lastIndex) {
        fragment.append(document.createTextNode(text.slice(lastIndex, matchIndex)));
      }

      const mark = document.createElement('mark');
      mark.className = 'bg-yellow-200 px-1 rounded dark:bg-yellow-700';
      mark.textContent = match[0];
      fragment.append(mark);

      lastIndex = matchIndex + match[0].length;
    }

    if (lastIndex < text.length) {
      fragment.append(document.createTextNode(text.slice(lastIndex)));
    }

    return fragment;
  }

  function createTagLink(tag) {
    const link = document.createElement('a');
    link.href = `/tags/${encodeURIComponent(tag)}`;
    link.className =
      'px-2 py-1 bg-primary-100 text-primary-700 rounded text-xs transition-colors hover:bg-primary-200 dark:bg-primary-900/30 dark:text-primary-300 dark:hover:bg-primary-900/50';
    link.textContent = tag;
    return link;
  }

  function createSearchResultCard(post, keywords) {
    const article = document.createElement('article');
    article.className = 'border-b border-gray-200 pb-8 last:border-0 dark:border-gray-800';

    const heading = document.createElement('h2');
    heading.className = 'text-2xl font-bold mb-2';

    const titleLink = document.createElement('a');
    titleLink.href = `/posts/${post.id}`;
    titleLink.className = 'text-primary-600 hover:underline dark:text-primary-400';
    titleLink.append(createHighlightedFragment(post.title, keywords));
    heading.append(titleLink);
    article.append(heading);

    const meta = document.createElement('div');
    meta.className = 'flex flex-wrap gap-4 text-sm text-gray-600 mb-3 dark:text-gray-400';

    const time = document.createElement('time');
    time.dateTime = post.date;
    time.textContent = post.dateFormatted;
    meta.append(time);

    if (post.tags.length > 0) {
      const tags = document.createElement('div');
      tags.className = 'flex flex-wrap gap-2';
      post.tags.forEach((tag) => tags.append(createTagLink(tag)));
      meta.append(tags);
    }

    article.append(meta);

    if (post.summary) {
      const summary = document.createElement('p');
      summary.className = 'text-gray-700 mb-3 line-clamp-2 dark:text-gray-300';
      summary.append(createHighlightedFragment(post.summary, keywords));
      article.append(summary);
    }

    const readMore = document.createElement('a');
    readMore.href = `/posts/${post.id}`;
    readMore.className = 'text-primary-600 hover:underline text-sm dark:text-primary-400';
    readMore.textContent = '阅读全文 →';
    article.append(readMore);

    return article;
  }

  function scorePost(post, keywords) {
    let score = 0;
    const titleLower = post.title.toLowerCase();
    const summaryLower = post.summary.toLowerCase();
    const tagsLower = post.tags.map((tag) => tag.toLowerCase()).join(' ');

    keywords.forEach((keyword) => {
      if (titleLower === keyword) {
        score += 10;
      } else if (titleLower.includes(keyword)) {
        score += 5;
      }

      if (tagsLower.includes(keyword)) {
        score += 3;
      }

      if (summaryLower.includes(keyword)) {
        score += 1;
      }
    });

    return score;
  }

  async function searchPosts(query) {
    const trimmedQuery = query.trim();

    if (!trimmedQuery) {
      resetSearchState();
      return;
    }

    searchPrompt.classList.add('hidden');
    noResults.classList.add('hidden');
    searchStats.textContent = '搜索中...';

    let allPosts = [];
    try {
      allPosts = await loadSearchIndex();
    } catch (error) {
      console.error('加载搜索索引失败:', error);
      searchResults.replaceChildren();
      searchStats.textContent = '搜索索引加载失败，请稍后重试。';
      return;
    }

    const keywords = tokenizeQuery(trimmedQuery);
    const scoredResults = allPosts
      .filter((post) => {
        const searchText = [post.title, post.summary, ...post.tags, ...post.categories].join(' ').toLowerCase();
        return keywords.some((keyword) => searchText.includes(keyword));
      })
      .map((post) => ({
        ...post,
        score: scorePost(post, keywords),
      }))
      .sort((a, b) => b.score - a.score);

    if (scoredResults.length === 0) {
      searchResults.replaceChildren();
      searchStats.textContent = '';
      noResults.classList.remove('hidden');
      return;
    }

    searchStats.textContent = `找到 ${scoredResults.length} 篇相关文章`;
    searchResults.replaceChildren(...scoredResults.map((post) => createSearchResultCard(post, keywords)));
  }

  function debounce(func, wait) {
    let timeout;

    return function debouncedFunction(...args) {
      clearTimeout(timeout);
      timeout = setTimeout(() => func(...args), wait);
    };
  }

  const debouncedSearch = debounce((event) => {
    searchPosts(event.target.value);
  }, 300);

  if (searchInput) {
    searchInput.addEventListener('input', debouncedSearch);

    const urlParams = new URLSearchParams(window.location.search);
    const queryParam = urlParams.get('q');

    if (queryParam) {
      searchInput.value = queryParam;
      searchPosts(queryParam);
    }
  }
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
