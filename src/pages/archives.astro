---
import MainLayout from '@layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getPostUrl, getTagUrl } from '@utils/slug';

const title = '归档 | 个人技术博客 bigroc';
const description = '按时间归档的所有文章';

const allPosts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

interface GroupedPosts {
  year: number;
  months: {
    month: number;
    posts: typeof allPosts;
  }[];
}

const grouped = new Map<number, Map<number, typeof allPosts>>();

allPosts.forEach((post) => {
  const date = post.data.date;
  const year = date.getFullYear();
  const month = date.getMonth() + 1;

  if (!grouped.has(year)) {
    grouped.set(year, new Map());
  }

  const yearMap = grouped.get(year);
  if (!yearMap?.has(month)) {
    yearMap?.set(month, []);
  }

  yearMap?.get(month)?.push(post);
});

const archives: GroupedPosts[] = Array.from(grouped.entries())
  .map(([year, monthMap]) => ({
    year,
    months: Array.from(monthMap.entries())
      .map(([month, posts]) => ({ month, posts }))
      .sort((a, b) => b.month - a.month),
  }))
  .sort((a, b) => b.year - a.year);

const totalPosts = allPosts.length;
const years = archives.length;
---

<MainLayout title={title} description={description}>
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2">归档</h1>
    <p class="text-gray-600 dark:text-gray-400">
      共 {totalPosts} 篇文章，跨越 {years} 年
    </p>
  </div>

  <div class="space-y-12">
    {archives.map(({ year, months }) => (
      <Fragment key={year}>
        <section>
          <h2 class="text-3xl font-bold mb-8 text-primary-600 sticky top-4 bg-white py-2 z-10 dark:bg-gray-900 dark:text-primary-400">
            {year}
            <span class="text-lg font-normal text-gray-500 ml-3 dark:text-gray-400">
              ({months.reduce((sum, monthEntry) => sum + monthEntry.posts.length, 0)} 篇)
            </span>
          </h2>

          <div class="space-y-8">
            {months.map(({ month, posts }) => (
              <Fragment key={`${year}-${month}`}>
                <div class="relative pl-8 border-l-2 border-gray-200 dark:border-gray-700">
                  <div class="absolute -left-3 top-0 w-6 h-6 bg-primary-600 rounded-full flex items-center justify-center dark:bg-primary-500">
                    <span class="text-xs text-white font-bold">{month}</span>
                  </div>

                  <h3 class="text-xl font-semibold mb-4 text-gray-700 dark:text-gray-300">
                    {month}月
                    <span class="text-sm font-normal text-gray-500 ml-2 dark:text-gray-400">
                      ({posts.length} 篇)
                    </span>
                  </h3>

                  <div class="space-y-4">
                    {posts.map((post) => (
                      <Fragment key={post.id}>
                        <article class="group">
                          <div class="flex gap-4 items-baseline">
                            <time
                              datetime={post.data.date.toISOString()}
                              class="text-sm text-gray-500 font-mono shrink-0 dark:text-gray-500"
                            >
                              {post.data.date.getDate().toString().padStart(2, '0')}日
                            </time>
                            <div class="flex-1">
                              <h4 class="text-lg font-medium mb-1">
                                <a
                                  href={`/posts/${getPostUrl(post.id)}`}
                                  class="text-gray-900 transition-colors hover:text-primary-600 dark:text-gray-100 dark:hover:text-primary-400"
                                >
                                  {post.data.title}
                                </a>
                              </h4>

                              {post.data.tags.length > 0 && (
                                <div class="flex flex-wrap gap-2 mt-2">
                                  {post.data.tags.slice(0, 5).map((tag) => (
                                    <Fragment key={tag}>
                                      <a
                                        href={getTagUrl(tag)}
                                        class="px-2 py-0.5 bg-gray-100 text-gray-600 rounded text-xs transition-colors hover:bg-primary-100 hover:text-primary-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-primary-900/30 dark:hover:text-primary-300"
                                      >
                                        {tag}
                                      </a>
                                    </Fragment>
                                  ))}
                                </div>
                              )}
                            </div>
                          </div>
                        </article>
                      </Fragment>
                    ))}
                  </div>
                </div>
              </Fragment>
            ))}
          </div>
        </section>
      </Fragment>
    ))}
  </div>

  <div class="mt-12 text-center">
    <a
      href="#top"
      class="inline-flex items-center gap-2 px-4 py-2 bg-primary-600 text-white rounded transition-colors hover:bg-primary-700"
    >
      ↑ 返回顶部
    </a>
  </div>
</MainLayout>
