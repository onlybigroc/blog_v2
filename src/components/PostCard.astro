---
import type { CollectionEntry } from 'astro:content';
import { getPostUrl, getTagUrl } from '@utils/slug';
import { calculateReadingTime, calculateWordCount } from '@utils/site';

interface Props {
  post: CollectionEntry<'posts'>;
  showCategories?: boolean;
  showReadMore?: boolean;
  tagLimit?: number;
  activeTag?: string;
  headingTag?: 'h2' | 'h3';
}

const {
  post,
  showCategories = false,
  showReadMore = true,
  tagLimit = post.data.tags.length,
  activeTag,
  headingTag = 'h2',
} = Astro.props;

const HeadingTag = headingTag;
const postHref = `/posts/${getPostUrl(post.id)}`;
const visibleTags = post.data.tags.slice(0, tagLimit);
const summary = post.data.summary.trim();
const formattedDate = post.data.date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const readingTime = calculateReadingTime(post.body);
const wordCount = calculateWordCount(post.body);
---

<article class="border-b border-gray-200 pb-8 last:border-0 dark:border-gray-800">
  <HeadingTag class="text-2xl font-bold mb-2">
    <a href={postHref} class="text-primary-600 hover:underline dark:text-primary-400">
      {post.data.title}
    </a>
  </HeadingTag>

  <div class="flex flex-wrap gap-4 text-sm text-gray-600 mb-3 dark:text-gray-400">
    <time datetime={post.data.date.toISOString()}>{formattedDate}</time>

    <span class="flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      {readingTime} 分钟阅读
    </span>

    <span class="flex items-center gap-1">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
      {wordCount} 字
    </span>

    {showCategories && post.data.categories.length > 0 && (
      <div class="flex flex-wrap gap-2">
        <span>分类：</span>
        {post.data.categories.map((category) => (
          <Fragment key={category}>
            <span class="text-primary-600 dark:text-primary-400">{category}</span>
          </Fragment>
        ))}
      </div>
    )}

    {visibleTags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {visibleTags.map((tag) => (
          <Fragment key={tag}>
            <a
              href={getTagUrl(tag)}
              class:list={[
                'px-2 py-1 rounded text-xs transition-colors',
                activeTag === tag
                  ? 'bg-primary-600 text-white'
                  : 'bg-primary-100 text-primary-700 hover:bg-primary-200 dark:bg-primary-900/30 dark:text-primary-300 dark:hover:bg-primary-900/50',
              ]}
            >
              {tag}
            </a>
          </Fragment>
        ))}
      </div>
    )}
  </div>

  {summary && (
    <p class="text-gray-700 mb-3 line-clamp-2 dark:text-gray-300">{summary}</p>
  )}

  {showReadMore && (
    <a href={postHref} class="text-primary-600 hover:underline text-sm dark:text-primary-400">
      阅读全文 →
    </a>
  )}
</article>
