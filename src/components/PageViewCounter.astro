---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<span data-page-view-counter class:list={['inline-flex items-center gap-1 text-sm text-gray-600 dark:text-gray-400', className]}>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
  </svg>
  <span data-page-view-count>0</span>
  <span>浏览</span>
</span>

<script>
  import { formatCount, recordView } from '@utils/stats';

  const INIT_FLAG = '__blogPageViewCounterInit__';

  function normalizePath(pathname: string) {
    if (!pathname || pathname === '/') {
      return '/';
    }
    const trimmed = pathname.replace(/\/+$/, '');
    return trimmed || '/';
  }

  async function syncPageViewCounters() {
    try {
      const pageId = `page:${normalizePath(window.location.pathname)}`;
      const stats = await recordView(pageId);

      const viewText = formatCount(stats.views);
      const counters = document.querySelectorAll('[data-page-view-counter]');
      counters.forEach((counter) => {
        const viewCountEl = counter.querySelector('[data-page-view-count]');
        if (viewCountEl) {
          viewCountEl.textContent = viewText;
        }
      });
    } catch (error) {
      console.warn('记录页面浏览量失败:', error);
    }
  }

  if (!(window as any)[INIT_FLAG]) {
    (window as any)[INIT_FLAG] = true;

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        void syncPageViewCounters();
      }, { once: true });
    } else {
      void syncPageViewCounters();
    }
  }
</script>
