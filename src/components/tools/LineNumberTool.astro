---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex gap-3">
    <button id="add" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">添加行号</button>
    <button id="remove" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-sm font-medium">移除行号</button>
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">起始</span><input id="start" type="number" value="1" min="0" class="w-16 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" /></label>
    <select id="sep" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value=". ">. </option><option value=": ">: </option><option value=" | "> | </option><option value=" - "> - </option></select>
    <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">复制</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label><textarea id="inp" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono" placeholder="每行文本..."></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输出</label><textarea id="out" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono" readonly></textarea></div>
  </div>
</div>
<script>
document.getElementById('add')?.addEventListener('click', () => {
  const lines = (document.getElementById('inp') as HTMLTextAreaElement).value.split('\n');
  const start = parseInt((document.getElementById('start') as HTMLInputElement).value) || 1;
  const sep = (document.getElementById('sep') as HTMLSelectElement).value;
  (document.getElementById('out') as HTMLTextAreaElement).value = lines.map((l, i) => `${i + start}${sep}${l}`).join('\n');
});
document.getElementById('remove')?.addEventListener('click', () => {
  const lines = (document.getElementById('inp') as HTMLTextAreaElement).value.split('\n');
  (document.getElementById('out') as HTMLTextAreaElement).value = lines.map(l => l.replace(/^\d+[.:|\s-]+\s*/, '')).join('\n');
});
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
