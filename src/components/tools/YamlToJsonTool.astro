---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex gap-3">
    <button id="convert" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">转换</button>
    <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm ml-auto">复制 JSON</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">YAML 输入</label><textarea id="inp" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono resize-y" placeholder={`name: Alice\nage: 30\nhobbies:\n  - reading\n  - coding\naddress:\n  city: Beijing`}></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">JSON 输出</label><textarea id="out" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono resize-y" readonly></textarea></div>
  </div>
  <div id="error" class="hidden rounded-lg p-3 text-sm bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400"></div>
</div>
<script>
function parseYaml(yaml: string): any {
  const lines = yaml.split('\n');
  const root: any = {};
  const stack: { indent: number; obj: any; key: string }[] = [{ indent: -1, obj: root, key: '' }];
  let currentList: { arr: any[]; indent: number } | null = null;

  for (let i = 0; i < lines.length; i++) {
    const rawLine = lines[i];
    if (rawLine.trim() === '' || rawLine.trim().startsWith('#')) continue;
    const indent = rawLine.search(/\S/);
    const line = rawLine.trim();

    // Pop stack to find parent
    while (stack.length > 1 && stack[stack.length - 1].indent >= indent) stack.pop();
    const parent = stack[stack.length - 1].obj;

    // List item
    if (line.startsWith('- ')) {
      const value = line.slice(2).trim();
      if (currentList && currentList.indent < indent) {
        // continuation
      } else {
        // Find array to append to
        const parentObj = stack[stack.length - 1].obj;
        const lastKey = stack[stack.length - 1].key;
        if (lastKey && !Array.isArray(parentObj[lastKey])) parentObj[lastKey] = [];
        currentList = { arr: lastKey ? parentObj[lastKey] : parentObj, indent };
      }
      if (value.includes(': ')) {
        const obj: any = {};
        const [k, ...v] = value.split(': ');
        obj[k.trim()] = parseValue(v.join(': '));
        currentList!.arr.push(obj);
      } else {
        currentList!.arr.push(parseValue(value));
      }
      continue;
    }
    currentList = null;

    // Key: Value
    const colonIdx = line.indexOf(':');
    if (colonIdx === -1) continue;
    const key = line.slice(0, colonIdx).trim();
    const val = line.slice(colonIdx + 1).trim();

    if (val === '' || val === '|' || val === '>') {
      // Nested object or multiline
      parent[key] = {};
      stack.push({ indent, obj: parent[key], key });
    } else {
      parent[key] = parseValue(val);
      stack[stack.length - 1].key = key;
    }
  }
  return root;
}

function parseValue(v: string): any {
  if (v === 'true') return true;
  if (v === 'false') return false;
  if (v === 'null' || v === '~') return null;
  if (/^-?\d+$/.test(v)) return parseInt(v);
  if (/^-?\d+\.\d+$/.test(v)) return parseFloat(v);
  if ((v.startsWith('"') && v.endsWith('"')) || (v.startsWith("'") && v.endsWith("'"))) return v.slice(1, -1);
  return v;
}

document.getElementById('convert')?.addEventListener('click', () => {
  const error = document.getElementById('error')!;
  error.classList.add('hidden');
  try {
    const result = parseYaml((document.getElementById('inp') as HTMLTextAreaElement).value);
    (document.getElementById('out') as HTMLTextAreaElement).value = JSON.stringify(result, null, 2);
  } catch (e) { error.textContent = '解析错误: ' + (e as Error).message; error.classList.remove('hidden'); }
});
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
