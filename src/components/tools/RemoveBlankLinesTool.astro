---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex gap-3">
    <button id="remove-all" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">去除所有空行</button>
    <button id="collapse" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-sm font-medium">合并连续空行</button>
    <span id="stats" class="text-sm text-gray-500 self-center"></span>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label><textarea id="inp" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输出</label><textarea id="out" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm" readonly></textarea></div>
  </div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLTextAreaElement;
function process(removeAll: boolean) {
  const lines = inp.value.split('\n');
  const before = lines.length;
  let result: string[];
  if (removeAll) result = lines.filter(l => l.trim() !== '');
  else {
    result = [];
    let prevBlank = false;
    for (const l of lines) { if (l.trim() === '') { if (!prevBlank) result.push(l); prevBlank = true; } else { result.push(l); prevBlank = false; } }
  }
  (document.getElementById('out') as HTMLTextAreaElement).value = result.join('\n');
  document.getElementById('stats')!.textContent = `去除 ${before - result.length} 行`;
}
document.getElementById('remove-all')?.addEventListener('click', () => process(true));
document.getElementById('collapse')?.addEventListener('click', () => process(false));
</script>
