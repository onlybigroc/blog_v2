---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex gap-3">
    <button id="left" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">左对齐</button>
    <button id="center" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">居中</button>
    <button id="right" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">右对齐</button>
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">宽度</span><input id="width" type="number" value="40" min="10" max="120" class="w-16 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" /></label>
    <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm ml-auto">复制</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label><textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">对齐结果</label><textarea id="out" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono" readonly></textarea></div>
  </div>
</div>
<script>
function align(dir: string) {
  const w = parseInt((document.getElementById('width') as HTMLInputElement).value) || 40;
  const lines = (document.getElementById('inp') as HTMLTextAreaElement).value.split('\n');
  const result = lines.map(l => {
    if (l.length >= w) return l;
    const pad = w - l.length;
    if (dir === 'left') return l + ' '.repeat(pad);
    if (dir === 'right') return ' '.repeat(pad) + l;
    return ' '.repeat(Math.floor(pad/2)) + l + ' '.repeat(Math.ceil(pad/2));
  });
  (document.getElementById('out') as HTMLTextAreaElement).value = result.join('\n');
}
document.getElementById('left')?.addEventListener('click', () => align('left'));
document.getElementById('center')?.addEventListener('click', () => align('center'));
document.getElementById('right')?.addEventListener('click', () => align('right'));
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
