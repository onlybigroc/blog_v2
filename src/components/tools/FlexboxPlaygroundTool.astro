---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-4">
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">容器属性</h3>
      <div><label class="block text-sm text-gray-500 mb-1">flex-direction</label><select id="fd" class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option>row</option><option>column</option><option>row-reverse</option><option>column-reverse</option></select></div>
      <div><label class="block text-sm text-gray-500 mb-1">justify-content</label><select id="jc" class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option>flex-start</option><option>center</option><option>flex-end</option><option selected>space-between</option><option>space-around</option><option>space-evenly</option></select></div>
      <div><label class="block text-sm text-gray-500 mb-1">align-items</label><select id="ai" class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option>flex-start</option><option selected>center</option><option>flex-end</option><option>stretch</option></select></div>
      <div><label class="block text-sm text-gray-500 mb-1">flex-wrap</label><select id="fw" class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option>nowrap</option><option>wrap</option></select></div>
      <div><label class="block text-sm text-gray-500 mb-1">gap: <span id="gap-val">10</span>px</label><input id="gap" type="range" min="0" max="30" value="10" class="w-full" /></div>
      <div class="flex gap-2">
        <button id="add-item" class="px-3 py-1 rounded bg-primary-600 text-white text-sm">+ 添加</button>
        <button id="remove-item" class="px-3 py-1 rounded bg-gray-200 dark:bg-gray-700 text-sm">- 移除</button>
      </div>
    </div>
    <div class="space-y-4">
      <div id="preview" class="rounded-lg bg-gray-100 dark:bg-gray-800 p-3 min-h-[200px]"></div>
      <div class="relative"><pre id="code" class="p-3 rounded-lg bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-sm font-mono"></pre><button id="copy" class="absolute top-2 right-2 px-2 py-1 text-xs rounded bg-gray-200 dark:bg-gray-700">复制</button></div>
    </div>
  </div>
</div>
<script>
const colors = ['#3b82f6','#ef4444','#22c55e','#f59e0b','#8b5cf6','#ec4899','#06b6d4'];
let itemCount = 3;
function update() {
  const fd = (document.getElementById('fd') as HTMLSelectElement).value;
  const jc = (document.getElementById('jc') as HTMLSelectElement).value;
  const ai = (document.getElementById('ai') as HTMLSelectElement).value;
  const fw = (document.getElementById('fw') as HTMLSelectElement).value;
  const gap = parseInt((document.getElementById('gap') as HTMLInputElement).value);
  document.getElementById('gap-val')!.textContent = String(gap);
  let items = '';
  for (let i = 0; i < itemCount; i++) items += `<div class="rounded flex items-center justify-center text-white text-xs font-bold" style="background:${colors[i%colors.length]};width:60px;height:40px">${i+1}</div>`;
  document.getElementById('preview')!.innerHTML = `<div style="display:flex;flex-direction:${fd};justify-content:${jc};align-items:${ai};flex-wrap:${fw};gap:${gap}px;min-height:160px">${items}</div>`;
  document.getElementById('code')!.textContent = `.container {\n  display: flex;\n  flex-direction: ${fd};\n  justify-content: ${jc};\n  align-items: ${ai};\n  flex-wrap: ${fw};\n  gap: ${gap}px;\n}`;
}
['fd','jc','ai','fw'].forEach(k => document.getElementById(k)?.addEventListener('change', update));
document.getElementById('gap')?.addEventListener('input', update);
document.getElementById('add-item')?.addEventListener('click', () => { itemCount++; update(); });
document.getElementById('remove-item')?.addEventListener('click', () => { if (itemCount > 1) { itemCount--; update(); } });
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText(document.getElementById('code')!.textContent!));
update();
</script>
