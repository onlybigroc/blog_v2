---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-3">
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">项目名称</label><input id="name" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="My Project" /></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">描述</label><input id="desc" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="A brief description" /></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">作者</label><input id="author" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="Your Name" /></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">许可证</label><select id="license" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm"><option>MIT</option><option>Apache-2.0</option><option>GPL-3.0</option></select></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">安装命令</label><input id="install" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm font-mono" value="npm install" /></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">功能特性（每行一项）</label><textarea id="features" class="w-full h-20 p-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="Feature 1\nFeature 2"></textarea></div>
      <button id="gen" class="w-full px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">生成 README</button>
    </div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">README.md</label><textarea id="out" class="w-full h-96 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono" readonly></textarea><button id="copy" class="mt-2 px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">复制</button></div>
  </div>
</div>
<script>
document.getElementById('gen')?.addEventListener('click', () => {
  const name = (document.getElementById('name') as HTMLInputElement).value || 'My Project';
  const desc = (document.getElementById('desc') as HTMLInputElement).value || '';
  const author = (document.getElementById('author') as HTMLInputElement).value || '';
  const lic = (document.getElementById('license') as HTMLSelectElement).value;
  const install = (document.getElementById('install') as HTMLInputElement).value || 'npm install';
  const features = (document.getElementById('features') as HTMLTextAreaElement).value.split('\n').filter(Boolean);
  let md = `# ${name}\n\n`;
  if (desc) md += `${desc}\n\n`;
  md += `## Installation\n\n\`\`\`bash\n${install}\n\`\`\`\n\n`;
  if (features.length) { md += `## Features\n\n${features.map(f => `- ${f}`).join('\n')}\n\n`; }
  md += `## License\n\nThis project is licensed under the ${lic} License.\n`;
  if (author) md += `\n## Author\n\n${author}\n`;
  (document.getElementById('out') as HTMLTextAreaElement).value = md;
});
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
