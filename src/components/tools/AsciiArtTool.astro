};

const textInput = document.getElementById('text') as HTMLInputElement;
const output = document.getElementById('output')!;

function render() {
  const text = textInput.value.toUpperCase();
  const size = (document.getElementById('font-size') as HTMLSelectElement).value;
  const variant = size === 'large' ? 0 : size === 'medium' ? 0 : 1;
  const lines = ['', '', '', '', ''];
  for (const ch of text) {
    const glyph = fonts[ch];
    if (!glyph) continue;
    const rows = glyph[variant] || glyph[0];
    for (let i = 0; i < 5; i++) lines[i] += (rows[i] || '     ') + '  ';
  }
  output.textContent = lines.join('\n');
}
textInput.addEventListener('input', render);
document.getElementById('font-size')?.addEventListener('change', render);
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText(output.textContent!));
render();
</script>
