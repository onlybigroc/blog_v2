---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="space-y-4">
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">密码/密钥</label>
      <input id="key" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm font-mono" placeholder="输入加密密钥" />
    </div>
    <div class="flex gap-3">
      <button id="encrypt" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">加密 →</button>
      <button id="decrypt" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium">← 解密</button>
      <button id="swap" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium">⇄ 互换</button>
    </div>
    <div class="grid gap-4 lg:grid-cols-2">
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">明文</label><textarea id="plain" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 font-mono text-sm resize-y" placeholder="输入要加密的文本..."></textarea></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">密文 (Base64)</label><textarea id="cipher" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 font-mono text-sm resize-y" placeholder="输入要解密的密文..."></textarea></div>
    </div>
    <div id="status" class="hidden rounded-lg p-3 text-sm"></div>
  </div>
</div>
<script>
const keyInput = document.getElementById('key') as HTMLInputElement;
const plainInput = document.getElementById('plain') as HTMLTextAreaElement;
const cipherInput = document.getElementById('cipher') as HTMLTextAreaElement;
const status = document.getElementById('status')!;

function showStatus(msg: string, type: 'success' | 'error') {
  status.textContent = msg;
  status.className = `rounded-lg p-3 text-sm ${type === 'success' ? 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400'}`;
  status.classList.remove('hidden');
}

async function getKey(password: string, salt: Uint8Array): Promise<CryptoKey> {
  const enc = new TextEncoder();
  const keyMaterial = await crypto.subtle.importKey('raw', enc.encode(password), 'PBKDF2', false, ['deriveKey']);
  return crypto.subtle.deriveKey({ name: 'PBKDF2', salt, iterations: 100000, hash: 'SHA-256' }, keyMaterial, { name: 'AES-GCM', length: 256 }, false, ['encrypt', 'decrypt']);
}

document.getElementById('encrypt')?.addEventListener('click', async () => {
  try {
    const key = keyInput.value;
    if (!key) { showStatus('请输入密钥', 'error'); return; }
    const salt = crypto.getRandomValues(new Uint8Array(16));
    const iv = crypto.getRandomValues(new Uint8Array(12));
    const cryptoKey = await getKey(key, salt);
    const enc = new TextEncoder();
    const encrypted = await crypto.subtle.encrypt({ name: 'AES-GCM', iv }, cryptoKey, enc.encode(plainInput.value));
    const combined = new Uint8Array(salt.length + iv.length + encrypted.byteLength);
    combined.set(salt, 0); combined.set(iv, salt.length); combined.set(new Uint8Array(encrypted), salt.length + iv.length);
    cipherInput.value = btoa(String.fromCharCode(...combined));
    showStatus('加密成功', 'success');
  } catch (e) { showStatus('加密失败: ' + (e as Error).message, 'error'); }
});

document.getElementById('decrypt')?.addEventListener('click', async () => {
  try {
    const key = keyInput.value;
    if (!key) { showStatus('请输入密钥', 'error'); return; }
    const data = Uint8Array.from(atob(cipherInput.value), c => c.charCodeAt(0));
    const salt = data.slice(0, 16);
    const iv = data.slice(16, 28);
    const encrypted = data.slice(28);
    const cryptoKey = await getKey(key, salt);
    const decrypted = await crypto.subtle.decrypt({ name: 'AES-GCM', iv }, cryptoKey, encrypted);
    plainInput.value = new TextDecoder().decode(decrypted);
    showStatus('解密成功', 'success');
  } catch (e) { showStatus('解密失败: 密钥错误或密文无效', 'error'); }
});

document.getElementById('swap')?.addEventListener('click', () => { const t = plainInput.value; plainInput.value = cipherInput.value; cipherInput.value = t; });
</script>
