---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex flex-wrap gap-3">
    <button id="format" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">格式化</button>
    <button id="compress" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-sm font-medium">压缩</button>
    <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm ml-auto">复制</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">XML 输入</label><textarea id="inp" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono resize-y" placeholder={`<root>\n<item id="1">Hello</item>\n</root>`}></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">格式化结果</label><textarea id="out" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono resize-y" readonly></textarea></div>
  </div>
  <div id="error" class="hidden rounded-lg p-3 text-sm bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400"></div>
</div>
<script>
function formatXml(xml: string, indent: number): string {
  let formatted = '', indentLevel = 0;
  const nodes = xml.replace(/(>)\s*(<)/g, '$1\n$2').split('\n');
  for (let node of nodes) {
    node = node.trim();
    if (!node) continue;
    if (node.startsWith('</')) indentLevel = Math.max(0, indentLevel - 1);
    formatted += '  '.repeat(indent * indentLevel) + node + '\n';
    if (node.startsWith('<') && !node.startsWith('</') && !node.startsWith('<?') && !node.endsWith('/>') && !node.includes('</')) indentLevel++;
  }
  return formatted.trim();
}

document.getElementById('format')?.addEventListener('click', () => {
  const xml = (document.getElementById('inp') as HTMLTextAreaElement).value.trim();
  const error = document.getElementById('error')!;
  error.classList.add('hidden');
  try {
    // Basic validation
    const parser = new DOMParser();
    const doc = parser.parseFromString(xml, 'text/xml');
    const parseError = doc.querySelector('parsererror');
    if (parseError) { error.textContent = 'XML 语法错误: ' + parseError.textContent?.slice(0, 100); error.classList.remove('hidden'); return; }
    (document.getElementById('out') as HTMLTextAreaElement).value = formatXml(xml, 1);
  } catch (e) { error.textContent = '错误: ' + (e as Error).message; error.classList.remove('hidden'); }
});

document.getElementById('compress')?.addEventListener('click', () => {
  const xml = (document.getElementById('inp') as HTMLTextAreaElement).value;
  (document.getElementById('out') as HTMLTextAreaElement).value = xml.replace(/>\s+</g, '><').replace(/\n\s*/g, '').trim();
});

document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
