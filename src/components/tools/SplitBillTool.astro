---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">总金额</label>
        <input id="total" type="number" value="300" step="0.01" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">参与人员</label>
        <div id="members" class="space-y-2"></div>
        <button id="add-member" class="mt-2 text-sm text-primary-600 hover:text-primary-700">+ 添加成员</button>
      </div>
      <button id="split" class="w-full px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">计算分摊</button>
    </div>
    <div>
      <div id="result" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-4 space-y-2"></div>
    </div>
  </div>
</div>
<script>
import { escapeHtml, escapeHtmlAttribute } from '@utils/safeHtml';

let members = ['甲', '乙'];
function renderMembers() {
  const el = document.getElementById('members')!;
  el.innerHTML = members.map((m, i) => `<div class="flex gap-2"><input type="text" value="${escapeHtmlAttribute(m)}" class="flex-1 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm member-name" data-idx="${i}" /><input type="number" placeholder="消费" min="0" class="w-28 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm member-expense" data-idx="${i}" />${members.length>1?`<button class="del-member px-2 text-red-500" data-idx="${i}">&times;</button>`:''}</div>`).join('');
  el.querySelectorAll('.del-member').forEach(b => b.addEventListener('click', () => { members.splice(parseInt((b as HTMLElement).dataset.idx!),1); renderMembers(); }));
}
document.getElementById('add-member')?.addEventListener('click', () => { members.push('成员' + (members.length+1)); renderMembers(); });
document.getElementById('split')?.addEventListener('click', () => {
  const total = parseFloat((document.getElementById('total') as HTMLInputElement).value) || 0;
  const names = Array.from(document.querySelectorAll('.member-name')).map(el => (el as HTMLInputElement).value.trim() || '匿名');
  const expenses = Array.from(document.querySelectorAll('.member-expense')).map(el => parseFloat((el as HTMLInputElement).value) || 0);
  const hasExpenses = expenses.some(e => e > 0);
  const resultDiv = document.getElementById('result')!;
  resultDiv.classList.remove('hidden');
  if (!hasExpenses) {
    const pp = total / names.length;
    resultDiv.innerHTML = `<div class="text-sm font-medium mb-2">平均分摊</div>` + names.map(n => `<div class="flex justify-between text-sm"><span>${escapeHtml(n)}</span><span class="font-mono font-bold">¥${pp.toFixed(2)}</span></div>`).join('');
  } else {
    const totalExp = expenses.reduce((a, b) => a + b, 0);
    const diff = total - totalExp;
    const share = diff / names.length;
    resultDiv.innerHTML = `<div class="text-sm font-medium mb-2">按消费分摊（公共部分平均）</div><div class="text-xs text-gray-500 mb-2">公共消费: ¥${diff.toFixed(2)}，每人分摊 ¥${share.toFixed(2)}</div>` + names.map((n, i) => `<div class="flex justify-between text-sm"><span>${escapeHtml(n)} (消费 ¥${expenses[i].toFixed(2)})</span><span class="font-mono font-bold">¥${(expenses[i]+share).toFixed(2)}</span></div>`).join('');
  }
});
renderMembers();
</script>
