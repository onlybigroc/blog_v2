---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="flex flex-wrap items-end gap-4">
    <div class="flex-1 min-w-[140px]"><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">数值</label><input id="val" type="number" value="100" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" /></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">从</label><select id="from" class="rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm"><option>摄氏度 (°C)</option><option>华氏度 (°F)</option><option>开尔文 (K)</option></select></div>
    <button id="swap" class="px-3 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-sm" aria-label="互换">⇄</button>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">到</label><select id="to" class="rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm"><option>华氏度 (°F)</option><option>摄氏度 (°C)</option><option>开尔文 (K)</option></select></div>
  </div>
  <div id="result" class="text-2xl font-bold text-center py-4 text-primary-600 dark:text-primary-400"></div>
  <div id="all-values" class="grid grid-cols-3 gap-3 text-center text-sm"></div>
  <div class="text-xs text-gray-500">参考: 水的冰点 0°C = 32°F = 273.15K | 水的沸点 100°C = 212°F = 373.15K</div>
</div>
<script>
const toC = (v: number, from: string) => from.includes('°C') ? v : from.includes('°F') ? (v - 32) * 5/9 : v - 273.15;
const fromC = (c: number, to: string) => to.includes('°C') ? c : to.includes('°F') ? c * 9/5 + 32 : c + 273.15;
const convert = () => {
  const v = parseFloat((document.getElementById('val') as HTMLInputElement).value);
  if (isNaN(v)) return;
  const from = (document.getElementById('from') as HTMLSelectElement).value;
  const to = (document.getElementById('to') as HTMLSelectElement).value;
  const c = toC(v, from);
  const result = fromC(c, to);
  document.getElementById('result')!.textContent = `${v} ${from.split(' ')[1]} = ${result.toFixed(2)} ${to.split(' ')[1]}`;
  document.getElementById('all-values')!.innerHTML = `<div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3"><div class="text-gray-500">摄氏度</div><div class="font-bold">${c.toFixed(2)} °C</div></div><div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3"><div class="text-gray-500">华氏度</div><div class="font-bold">${fromC(c,'°F').toFixed(2)} °F</div></div><div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3"><div class="text-gray-500">开尔文</div><div class="font-bold">${fromC(c,'K').toFixed(2)} K</div></div>`;
};
['val','from','to'].forEach(id => document.getElementById(id)?.addEventListener('input', convert));
document.getElementById('swap')?.addEventListener('click', () => { const f=document.getElementById('from') as HTMLSelectElement, t=document.getElementById('to') as HTMLSelectElement; const tmp=f.value; f.value=t.value; t.value=tmp; convert(); });
convert();
</script>
