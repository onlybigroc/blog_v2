---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div>
    <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">选择项目类型</label>
    <div id="types" class="flex flex-wrap gap-2"></div>
  </div>
  <button id="gen" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">生成 .gitignore</button>
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">结果</label><textarea id="out" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono" readonly></textarea></div>
  <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">复制</button>
</div>
<script>
const presets: Record<string, string[]> = {
  'Node.js': ['node_modules/','npm-debug.log*','yarn-debug.log*','yarn-error.log*','.npm','.yarn','.env','.env.local','dist/','build/'],
  'Python': ['__pycache__/','*.py[cod]','*.egg-info/','dist/','build/','.venv/','venv/','.env','*.egg','.pytest_cache/','.mypy_cache/'],
  'Java': ['*.class','*.jar','*.war','*.ear','target/','.gradle/','build/','.idea/','*.iml'],
  'Go': ['*.exe','*.exe~','*.dll','*.so','*.dylib','vendor/','go.sum'],
  'Rust': ['target/','**/*.rs.bk','Cargo.lock'],
  'macOS': ['.DS_Store','.DS_Store?','._*','.Spotlight-V100','.Trashes'],
  'Windows': ['Thumbs.db','ehthumbs.db','Desktop.ini','$RECYCLE.BIN/'],
  'Linux': ['*~','.fuse_hidden*','.directory','.Trash-*'],
  'VS Code': ['.vscode/','!.vscode/settings.json','!.vscode/tasks.json','!.vscode/launch.json','!.vscode/extensions.json'],
  'JetBrains': ['.idea/','*.iml','out/'],
  'Docker': ['*.log','.docker'],
  'React': ['.env.local','.env.development.local','.env.test.local','.env.production.local','build/'],
};

const selected = new Set<string>();
const typesEl = document.getElementById('types')!;
Object.keys(presets).forEach(name => {
  const btn = document.createElement('button');
  btn.textContent = name;
  btn.className = 'px-3 py-1 rounded-full text-sm border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors';
  btn.addEventListener('click', () => {
    if (selected.has(name)) { selected.delete(name); btn.className = 'px-3 py-1 rounded-full text-sm border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors'; }
    else { selected.add(name); btn.className = 'px-3 py-1 rounded-full text-sm bg-primary-100 dark:bg-primary-900/30 border border-primary-300 dark:border-primary-700 text-primary-700 dark:text-primary-300'; }
  });
  typesEl.appendChild(btn);
});

document.getElementById('gen')?.addEventListener('click', () => {
  const lines: string[] = ['# .gitignore'];
  for (const name of selected) { lines.push('', `# ${name}`); lines.push(...presets[name]); }
  (document.getElementById('out') as HTMLTextAreaElement).value = lines.join('\n');
});
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
