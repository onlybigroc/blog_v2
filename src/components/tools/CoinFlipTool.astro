---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="text-center py-8">
    <p id="display" class="text-6xl mb-4">🪙</p>
    <button id="run" class="px-6 py-3 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-lg font-medium">🪙 抛硬币</button>
    <p id="result" class="mt-4 text-xl font-bold text-primary-600 dark:text-primary-400"></p>
  </div>
</div>
<script>
document.getElementById('run').onclick=function(){var r=Math.random()>0.5;document.getElementById('display').textContent='🪙';document.getElementById('result').textContent=r?'正面':'反面'};
</script>
