---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label>
      <textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 font-mono text-sm" placeholder="粘贴 JSON 数据..."></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输出</label>
      <textarea id="out" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 font-mono text-sm" readonly></textarea>
    </div>
  </div>
  <div class="flex gap-3">
    <button id="run" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">生成 Schema</button>
    <button id="copy" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium">复制结果</button>
    <button id="swap" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium">⇄ 互换</button>
  </div>
</div>
<script>
document.getElementById('run').onclick=function(){try{var d=JSON.parse(document.getElementById('inp').value);var s=genSchema(d);document.getElementById('out').value=JSON.stringify(s,null,2)}catch(e){document.getElementById('out').value='JSON 解析错误: '+e.message}};
document.getElementById('copy').onclick=function(){navigator.clipboard.writeText(document.getElementById('out').value)};
document.getElementById('swap').onclick=function(){var a=document.getElementById('inp'),b=document.getElementById('out');var t=a.value;a.value=b.value;b.value=t};
function genSchema(v){if(v===null)return{type:'null'};if(Array.isArray(v)){var s={type:'array'};if(v.length)s.items=genSchema(v[0]);return s}if(typeof v==='object'){var p={};for(var k in v)p[k]=genSchema(v[k]);return{type:'object',properties:p,required:Object.keys(v)}}return{type:typeof v}}
</script>
