---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-4">
      <div><label class="block text-sm text-gray-500 mb-1">X 偏移: <span id="ox-val">4</span>px</label><input id="ox" type="range" min="-50" max="50" value="4" class="w-full" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">Y 偏移: <span id="oy-val">4</span>px</label><input id="oy" type="range" min="-50" max="50" value="4" class="w-full" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">模糊: <span id="blur-val">8</span>px</label><input id="blur" type="range" min="0" max="100" value="8" class="w-full" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">扩散: <span id="spread-val">0</span>px</label><input id="spread" type="range" min="-50" max="50" value="0" class="w-full" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">颜色</label><input id="shadow-color" type="color" value="#000000" class="w-full h-8 rounded cursor-pointer" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">透明度: <span id="opacity-val">25</span>%</label><input id="opacity" type="range" min="0" max="100" value="25" class="w-full" /></div>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input id="inset" type="checkbox" class="rounded" /><span class="text-gray-600 dark:text-gray-400">内阴影 (inset)</span></label>
    </div>
    <div class="space-y-4">
      <div class="flex items-center justify-center h-48 rounded-lg bg-gray-100 dark:bg-gray-800"><div id="preview" class="w-32 h-32 bg-white dark:bg-gray-700 rounded-lg"></div></div>
      <div class="relative"><pre id="code" class="p-3 rounded-lg bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-sm font-mono"></pre><button id="copy" class="absolute top-2 right-2 px-2 py-1 text-xs rounded bg-gray-200 dark:bg-gray-700">复制</button></div>
    </div>
  </div>
</div>
<script>
function hexToRgba(hex: string, opacity: number) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${opacity/100})`;
}
function update() {
  const ox = parseInt((document.getElementById('ox') as HTMLInputElement).value);
  const oy = parseInt((document.getElementById('oy') as HTMLInputElement).value);
  const blur = parseInt((document.getElementById('blur') as HTMLInputElement).value);
  const spread = parseInt((document.getElementById('spread') as HTMLInputElement).value);
  const color = (document.getElementById('shadow-color') as HTMLInputElement).value;
  const opacity = parseInt((document.getElementById('opacity') as HTMLInputElement).value);
  const inset = (document.getElementById('inset') as HTMLInputElement).checked;
  ['ox','oy','blur','spread','opacity'].forEach(k => document.getElementById(k+'-val')!.textContent = eval(k).toString());
  const rgba = hexToRgba(color, opacity);
  const value = `${inset?'inset ':''}${ox}px ${oy}px ${blur}px ${spread}px ${rgba}`;
  document.getElementById('preview')!.style.boxShadow = value;
  document.getElementById('code')!.textContent = `box-shadow: ${value};`;
}
['ox','oy','blur','spread','opacity'].forEach(k => document.getElementById(k)?.addEventListener('input', update));
['shadow-color','inset'].forEach(k => document.getElementById(k)?.addEventListener('change', update));
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText(document.getElementById('code')!.textContent!));
update();
</script>
