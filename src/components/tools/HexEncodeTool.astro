---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex flex-wrap gap-3">
    <button id="encode" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">编码 →</button>
    <button id="decode" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-sm font-medium">← 解码</button>
    <select id="sep" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value=" ">空格分隔</option><option value="">无分隔</option></select>
    <select id="case-sel" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value="lower">小写</option><option value="upper">大写</option></select>
    <span id="bytes" class="text-sm text-gray-500 self-center"></span>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">文本</label><textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="输入文本..."></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">十六进制</label><textarea id="out" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono"></textarea></div>
  </div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLTextAreaElement;
const out = document.getElementById('out') as HTMLTextAreaElement;
document.getElementById('encode')?.addEventListener('click', () => {
  const enc = new TextEncoder().encode(inp.value);
  const sep = (document.getElementById('sep') as HTMLSelectElement).value;
  const cs = (document.getElementById('case-sel') as HTMLSelectElement).value;
  const hex = Array.from(enc).map(b => b.toString(16).padStart(2, cs === 'upper' ? '0' : '0'));
  out.value = (cs === 'upper' ? hex.map(h => h.toUpperCase()) : hex).join(sep);
  document.getElementById('bytes')!.textContent = enc.length + ' 字节';
});
document.getElementById('decode')?.addEventListener('click', () => {
  try {
    const bytes = out.value.trim().split(/[\s,]+/).filter(Boolean).map(h => parseInt(h, 16));
    if (bytes.some(isNaN)) throw new Error();
    inp.value = new TextDecoder().decode(new Uint8Array(bytes));
    document.getElementById('bytes')!.textContent = bytes.length + ' 字节';
  } catch { inp.value = '解码失败: 无效的十六进制数据'; }
});
</script>
