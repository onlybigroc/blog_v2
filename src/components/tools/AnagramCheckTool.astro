---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="max-w-md mx-auto space-y-4">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">单词 1</label><input id="w1" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="listen" /></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">单词 2</label><input id="w2" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="silent" /></div>
    <label class="flex items-center gap-2 text-sm cursor-pointer"><input id="ignore" type="checkbox" class="rounded" checked /><span class="text-gray-600 dark:text-gray-400">忽略空格和标点</span></label>
    <button id="check" class="w-full px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">检测</button>
    <div id="result" class="hidden text-center py-4 rounded-lg text-lg font-bold"></div>
    <div id="detail" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-4 text-sm"></div>
  </div>
</div>
<script>
import { escapeHtml } from '@utils/safeHtml';

document.getElementById('check')?.addEventListener('click', () => {
  let w1 = (document.getElementById('w1') as HTMLInputElement).value;
  let w2 = (document.getElementById('w2') as HTMLInputElement).value;
  const ignore = (document.getElementById('ignore') as HTMLInputElement).checked;
  if (ignore) { w1 = w1.replace(/[^a-zA-Z]/g, '').toLowerCase(); w2 = w2.replace(/[^a-zA-Z]/g, '').toLowerCase(); }
  const result = document.getElementById('result')!;
  const detail = document.getElementById('detail')!;
  result.classList.remove('hidden');
  detail.classList.remove('hidden');
  const isAnagram = w1.split('').sort().join('') === w2.split('').sort().join('');
  result.className = `text-center py-4 rounded-lg text-lg font-bold ${isAnagram ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400' : 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400'}`;
  result.textContent = isAnagram ? '✅ 是变位词！' : '❌ 不是变位词';
  const sorted1 = w1.split('').sort().join('');
  const sorted2 = w2.split('').sort().join('');
  detail.innerHTML = `<div class="text-center mb-2"><span class="font-mono">${escapeHtml(sorted1)}</span> <span class="text-gray-400">vs</span> <span class="font-mono">${escapeHtml(sorted2)}</span></div>`;
  // Frequency comparison
  const freq1: Record<string, number> = {}, freq2: Record<string, number> = {};
  for (const c of w1) freq1[c] = (freq1[c] || 0) + 1;
  for (const c of w2) freq2[c] = (freq2[c] || 0) + 1;
  const allChars = new Set([...Object.keys(freq1), ...Object.keys(freq2)]);
  detail.innerHTML += '<table class="w-full mt-2"><tr class="border-b dark:border-gray-700"><th class="text-left py-1">字符</th><th class="text-center">单词1</th><th class="text-center">单词2</th></tr>' +
    Array.from(allChars).sort().map(c => `<tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-1 font-mono">${escapeHtml(c)}</td><td class="text-center">${freq1[c]||0}</td><td class="text-center">${freq2[c]||0}</td></tr>`).join('') + '</table>';
});
</script>
