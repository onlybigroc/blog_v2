---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex gap-3">
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">重复次数</span><input id="count" type="number" value="5" min="1" max="1000" class="w-20 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" /></label>
    <select id="sep" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value="\n">换行</option><option value=" ">空格</option><option value=",">逗号</option><option value="">无</option></select>
    <button id="repeat" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">重复</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label><textarea id="inp" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="要重复的文本"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">结果</label><textarea id="out" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm" readonly></textarea></div>
  </div>
  <div id="stats" class="text-sm text-gray-500"></div>
</div>
<script>
document.getElementById('repeat')?.addEventListener('click', () => {
  const text = (document.getElementById('inp') as HTMLTextAreaElement).value;
  const n = parseInt((document.getElementById('count') as HTMLInputElement).value) || 1;
  const sep = (document.getElementById('sep') as HTMLSelectElement).value.replace('\\n', '\n');
  const result = Array(n).fill(text).join(sep);
  (document.getElementById('out') as HTMLTextAreaElement).value = result;
  document.getElementById('stats')!.textContent = `${n} 次重复, ${result.length} 字符`;
});
</script>
