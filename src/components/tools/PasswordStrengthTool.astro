---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="space-y-4">
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">密码</label>
      <input id="pwd" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm font-mono" placeholder="输入密码检测强度" />
    </div>
    <div class="relative h-3 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden">
      <div id="bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
    </div>
    <div class="flex justify-between text-sm">
      <span id="label" class="font-medium"></span>
      <span id="crack-time" class="text-gray-500"></span>
    </div>
    <div id="criteria" class="space-y-1 text-sm"></div>
    <div id="tips" class="hidden rounded-lg p-3 text-sm bg-blue-50 dark:bg-blue-900/20 text-blue-700 dark:text-blue-300"></div>
  </div>
</div>
<script>
const pwdInput = document.getElementById('pwd') as HTMLInputElement;
const bar = document.getElementById('bar')!;
const label = document.getElementById('label')!;
const crackTime = document.getElementById('crack-time')!;
const criteriaEl = document.getElementById('criteria')!;
const tipsEl = document.getElementById('tips')!;

function check(pw: string) {
  const checks = [
    { ok: pw.length >= 8, text: '至少 8 个字符' },
    { ok: pw.length >= 12, text: '至少 12 个字符（推荐）' },
    { ok: /[a-z]/.test(pw), text: '包含小写字母' },
    { ok: /[A-Z]/.test(pw), text: '包含大写字母' },
    { ok: /\d/.test(pw), text: '包含数字' },
    { ok: /[^a-zA-Z0-9]/.test(pw), text: '包含特殊字符' },
    { ok: !/(.)\1{2,}/.test(pw), text: '无连续重复字符' },
    { ok: !/^(123|abc|qwerty|password)/i.test(pw), text: '非常见弱密码' },
  ];
  const score = checks.filter(c => c.ok).length;
  const pct = pw.length === 0 ? 0 : Math.min(100, score / checks.length * 100);
  let color = '#ef4444', lbl = '非常弱';
  if (pct >= 80) { color = '#22c55e'; lbl = '非常强'; }
  else if (pct >= 60) { color = '#84cc16'; lbl = '强'; }
  else if (pct >= 40) { color = '#eab308'; lbl = '中等'; }
  else if (pct >= 20) { color = '#f97316'; lbl = '弱'; }
  bar.style.width = pct + '%';
  bar.style.backgroundColor = color;
  label.textContent = pw.length ? `${lbl} (${score}/${checks.length})` : '';
  label.style.color = color;
  criteriaEl.innerHTML = checks.map(c => `<div class="flex items-center gap-2"><span>${c.ok ? '✅' : '❌'}</span><span class="${c.ok ? '' : 'text-gray-400'}">${c.text}</span></div>`).join('');

  // crack time estimate
  if (pw.length === 0) { crackTime.textContent = ''; tipsEl.classList.add('hidden'); return; }
  let charsetSize = 0;
  if (/[a-z]/.test(pw)) charsetSize += 26;
  if (/[A-Z]/.test(pw)) charsetSize += 26;
  if (/\d/.test(pw)) charsetSize += 10;
  if (/[^a-zA-Z0-9]/.test(pw)) charsetSize += 33;
  const combinations = Math.pow(charsetSize, pw.length);
  const guessesPerSec = 1e10; // 10 billion guesses/sec
  const seconds = combinations / guessesPerSec / 2;
  let timeStr: string;
  if (seconds < 1) timeStr = '瞬间';
  else if (seconds < 60) timeStr = Math.round(seconds) + ' 秒';
  else if (seconds < 3600) timeStr = Math.round(seconds/60) + ' 分钟';
  else if (seconds < 86400) timeStr = Math.round(seconds/3600) + ' 小时';
  else if (seconds < 86400*365) timeStr = Math.round(seconds/86400) + ' 天';
  else if (seconds < 86400*365*1000) timeStr = Math.round(seconds/(86400*365)) + ' 年';
  else timeStr = '数百万年以上';
  crackTime.textContent = '破解时间: ~' + timeStr;

  const tips: string[] = [];
  if (pw.length < 12) tips.push('增加密码长度到 12 位以上');
  if (!/[A-Z]/.test(pw)) tips.push('添加大写字母');
  if (!/\d/.test(pw)) tips.push('添加数字');
  if (!/[^a-zA-Z0-9]/.test(pw)) tips.push('添加特殊字符 (!@#$%等)');
  if (tips.length) { tipsEl.textContent = '建议: ' + tips.join('；'); tipsEl.classList.remove('hidden'); }
  else { tipsEl.classList.add('hidden'); }
}

pwdInput.addEventListener('input', () => check(pwdInput.value));
</script>
