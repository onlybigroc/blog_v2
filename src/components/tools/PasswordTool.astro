---
// 密码生成器

interface Props {
  cleanPath?: string;
  showCleanLink?: boolean;
  showPageMeta?: boolean;
}

const {
  cleanPath,
  showCleanLink = false,
  showPageMeta = false,
} = Astro.props;
---

<div class="space-y-6" id="password-tool">
    {showCleanLink && cleanPath && (
      <a
        href={cleanPath}
        title="打开可单独收藏的工具页面"
        class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"
      >
        <svg class="h-4 w-4" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" />
        </svg>
        独立打开
      </a>
    )}
  <div class="flex flex-wrap items-center gap-3">
    <button
      id="pwd-generate"
      class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium"
    >
      🔄 生成密码
    </button>
    <button
      id="pwd-copy"
      class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium"
    >
      📋 复制
    </button>
    <button
      id="pwd-batch"
      class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium"
    >
      批量生成 (10个)
    </button>
  </div>

  <!-- 密码显示 -->
  <div class="relative">
    <div id="pwd-display" class="w-full p-4 rounded-lg border-2 border-primary-200 dark:border-primary-800 bg-gray-50 dark:bg-gray-900 font-mono text-2xl text-center tracking-wider break-all min-h-[4rem] flex items-center justify-center">
      点击"生成密码"开始
    </div>
    <div class="absolute right-3 top-1/2 -translate-y-1/2 flex gap-1">
      <span id="pwd-strength-badge" class="px-2 py-1 rounded text-xs font-medium"></span>
    </div>
  </div>

  <!-- 强度条 -->
  <div>
    <div class="flex justify-between text-sm mb-1">
      <span class="text-gray-600 dark:text-gray-400">密码强度</span>
      <span id="pwd-strength-text" class="font-medium"></span>
    </div>
    <div class="w-full h-2 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden">
      <div id="pwd-strength-bar" class="h-full rounded-full transition-all duration-300" style="width: 0%"></div>
    </div>
  </div>

  <!-- 配置 -->
  <div class="grid gap-4 sm:grid-cols-2">
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">密码长度：<span id="pwd-len-val" class="text-primary-600">16</span></label>
      <input type="range" id="pwd-length" min="4" max="128" value="16" class="w-full accent-primary-600" />
      <div class="flex justify-between text-xs text-gray-500"><span>4</span><span>128</span></div>
    </div>
    <div class="space-y-2">
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="pwd-upper" class="rounded" checked />
        <span class="text-sm">大写字母 (A-Z)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="pwd-lower" class="rounded" checked />
        <span class="text-sm">小写字母 (a-z)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="pwd-digits" class="checked" checked />
        <span class="text-sm">数字 (0-9)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="pwd-symbols" class="rounded" checked />
        <span class="text-sm">特殊字符 (!@#$%...)</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <input type="checkbox" id="pwd-ambiguous" class="rounded" />
        <span class="text-sm">排除易混淆字符 (0OIl1)</span>
      </label>
    </div>
  </div>

  <!-- 批量结果 -->
  <div id="pwd-batch-container" class="hidden">
    <label class="block text-sm font-medium mb-2 text-gray-700 dark:text-gray-300">批量结果</label>
    <textarea
      id="pwd-batch-output"
      class="w-full h-48 p-4 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 font-mono text-sm resize-y"
      readonly
    ></textarea>
    <button
      id="pwd-batch-copy"
      class="mt-2 px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium"
    >
      复制全部
    </button>
  </div>

  <div id="pwd-status" class="hidden rounded-lg p-3 text-sm"></div>
</div>

<script>
  const pwdDisplay = document.getElementById('pwd-display')!;
  const pwdLength = document.getElementById('pwd-length') as HTMLInputElement;
  const pwdLenVal = document.getElementById('pwd-len-val')!;
  const upperCheck = document.getElementById('pwd-upper') as HTMLInputElement;
  const lowerCheck = document.getElementById('pwd-lower') as HTMLInputElement;
  const digitsCheck = document.getElementById('pwd-digits') as HTMLInputElement;
  const symbolsCheck = document.getElementById('pwd-symbols') as HTMLInputElement;
  const ambiguousCheck = document.getElementById('pwd-ambiguous') as HTMLInputElement;
  const strengthBar = document.getElementById('pwd-strength-bar')!;
  const strengthText = document.getElementById('pwd-strength-text')!;
  const strengthBadge = document.getElementById('pwd-strength-badge')!;
  const pwdStatus = document.getElementById('pwd-status');
  const batchContainer = document.getElementById('pwd-batch-container')!;
  const batchOutput = document.getElementById('pwd-batch-output') as HTMLTextAreaElement;

  const CHARS = {
    upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
    lower: 'abcdefghijklmnopqrstuvwxyz',
    digits: '0123456789',
    symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?',
    ambiguous: '0OIl1',
  };

  let currentPwd = '';

  function showPwdStatus(msg: string) {
    if (!pwdStatus) return;
    pwdStatus.textContent = msg;
    pwdStatus.className = 'rounded-lg p-3 text-sm bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400';
    pwdStatus.classList.remove('hidden');
    setTimeout(() => pwdStatus.classList.add('hidden'), 2000);
  }

  function generatePassword(): string {
    let chars = '';
    if (upperCheck.checked) chars += CHARS.upper;
    if (lowerCheck.checked) chars += CHARS.lower;
    if (digitsCheck.checked) chars += CHARS.digits;
    if (symbolsCheck.checked) chars += CHARS.symbols;
    if (!chars) chars = CHARS.lower; // fallback

    if (ambiguousCheck.checked) {
      for (const c of CHARS.ambiguous) chars = chars.replace(new RegExp(c.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), '');
    }

    const len = parseInt(pwdLength.value);
    const arr = new Uint32Array(len);
    crypto.getRandomValues(arr);
    return Array.from(arr, v => chars[v % chars.length]).join('');
  }

  function getStrength(pwd: string): { score: number; label: string; color: string } {
    let score = 0;
    if (pwd.length >= 8) score++;
    if (pwd.length >= 12) score++;
    if (pwd.length >= 16) score++;
    if (/[A-Z]/.test(pwd)) score++;
    if (/[a-z]/.test(pwd)) score++;
    if (/[0-9]/.test(pwd)) score++;
    if (/[^A-Za-z0-9]/.test(pwd)) score++;
    if (pwd.length >= 24) score++;

    if (score <= 2) return { score: 25, label: '弱', color: 'bg-red-500' };
    if (score <= 4) return { score: 50, label: '中', color: 'bg-yellow-500' };
    if (score <= 6) return { score: 75, label: '强', color: 'bg-blue-500' };
    return { score: 100, label: '极强', color: 'bg-green-500' };
  }

  function updateUI(pwd: string) {
    currentPwd = pwd;
    pwdDisplay.textContent = pwd;
    const str = getStrength(pwd);
    strengthBar.style.width = str.score + '%';
    strengthBar.className = `h-full rounded-full transition-all duration-300 ${str.color}`;
    strengthText.textContent = str.label;
    strengthText.className = `font-medium ${str.color.replace('bg-', 'text-').replace('-500', '-600')}`;
    strengthBadge.textContent = str.label;
    strengthBadge.className = `px-2 py-1 rounded text-xs font-medium ${str.color} text-white`;
  }

  pwdLength.addEventListener('input', () => {
    pwdLenVal.textContent = pwdLength.value;
  });

  document.getElementById('pwd-generate')?.addEventListener('click', () => {
    updateUI(generatePassword());
  });

  document.getElementById('pwd-copy')?.addEventListener('click', async () => {
    if (!currentPwd) return;
    await navigator.clipboard.writeText(currentPwd);
    showPwdStatus('✅ 密码已复制到剪贴板');
  });

  document.getElementById('pwd-batch')?.addEventListener('click', () => {
    const pwds = Array.from({ length: 10 }, () => generatePassword());
    batchOutput.value = pwds.join('\n');
    batchContainer.classList.remove('hidden');
  });

  document.getElementById('pwd-batch-copy')?.addEventListener('click', async () => {
    await navigator.clipboard.writeText(batchOutput.value);
    showPwdStatus('✅ 已复制全部密码');
  });

  // 初始生成一个
  updateUI(generatePassword());
</script>