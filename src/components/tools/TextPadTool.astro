---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex flex-wrap gap-3">
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">填充字符</span><input id="pad-char" type="text" value=" " maxlength="2" class="w-10 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-1 py-1 text-sm text-center" /></label>
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">目标长度</span><input id="target-len" type="number" value="20" min="1" max="200" class="w-16 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" /></label>
    <select id="dir" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value="right">右侧填充</option><option value="left">左侧填充</option><option value="both">两侧填充</option></select>
    <button id="pad" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">填充</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label><textarea id="inp" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono" placeholder="hello"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">结果</label><textarea id="out" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono" readonly></textarea></div>
  </div>
</div>
<script>
document.getElementById('pad')?.addEventListener('click', () => {
  const text = (document.getElementById('inp') as HTMLTextAreaElement).value;
  const char = (document.getElementById('pad-char') as HTMLInputElement).value || ' ';
  const len = parseInt((document.getElementById('target-len') as HTMLInputElement).value) || 20;
  const dir = (document.getElementById('dir') as HTMLSelectElement).value;
  const result = text.split('\n').map(line => {
    const padLen = Math.max(0, len - line.length);
    const pad = char.repeat(padLen);
    if (dir === 'left') return pad + line;
    if (dir === 'both') { const l = Math.floor(padLen/2); return char.repeat(l) + line + char.repeat(padLen - l); }
    return line + pad;
  });
  (document.getElementById('out') as HTMLTextAreaElement).value = result.join('\n');
});
</script>
