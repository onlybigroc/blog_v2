---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">账单金额</label>
        <input id="bill" type="number" value="100" step="0.01" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">小费比例</label>
        <div class="flex gap-2">
          <button data-tip="10" class="tip-btn flex-1 px-3 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-primary-100 dark:hover:bg-primary-900/30 text-sm font-medium transition-colors">10%</button>
          <button data-tip="15" class="tip-btn flex-1 px-3 py-2 rounded-lg bg-primary-100 dark:bg-primary-900/30 text-sm font-medium text-primary-700 dark:text-primary-300">15%</button>
          <button data-tip="18" class="tip-btn flex-1 px-3 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-primary-100 dark:hover:bg-primary-900/30 text-sm font-medium transition-colors">18%</button>
          <button data-tip="20" class="tip-btn flex-1 px-3 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-primary-100 dark:hover:bg-primary-900/30 text-sm font-medium transition-colors">20%</button>
        </div>
        <input id="custom-tip" type="number" value="15" min="0" max="100" class="w-full mt-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="自定义 %" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">分摊人数</label>
        <input id="people" type="number" value="1" min="1" max="50" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
      </div>
    </div>
    <div class="space-y-3">
      <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 space-y-3">
        <div class="flex justify-between text-sm"><span class="text-gray-500">账单金额</span><span id="bill-display">$100.00</span></div>
        <div class="flex justify-between text-sm"><span class="text-gray-500">小费 (<span id="tip-pct">15</span>%)</span><span id="tip-display" class="text-green-600 dark:text-green-400">$15.00</span></div>
        <hr class="border-gray-200 dark:border-gray-700" />
        <div class="flex justify-between font-medium"><span>总计</span><span id="total-display" class="text-lg">$115.00</span></div>
        <div id="per-person" class="flex justify-between text-primary-600 dark:text-primary-400 font-bold"><span>每人</span><span id="pp-display" class="text-lg">$115.00</span></div>
      </div>
    </div>
  </div>
</div>
<script>
let tipPct = 15;
document.querySelectorAll('.tip-btn').forEach(btn => btn.addEventListener('click', () => {
  tipPct = parseInt((btn as HTMLElement).dataset.tip!);
  (document.getElementById('custom-tip') as HTMLInputElement).value = String(tipPct);
  document.querySelectorAll('.tip-btn').forEach(b => { b.className = 'tip-btn flex-1 px-3 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-primary-100 dark:hover:bg-primary-900/30 text-sm font-medium transition-colors'; });
  btn.className = 'tip-btn flex-1 px-3 py-2 rounded-lg bg-primary-100 dark:bg-primary-900/30 text-sm font-medium text-primary-700 dark:text-primary-300';
  calc();
}));
document.getElementById('custom-tip')?.addEventListener('input', () => { tipPct = parseFloat((document.getElementById('custom-tip') as HTMLInputElement).value) || 0; calc(); });

function calc() {
  const bill = parseFloat((document.getElementById('bill') as HTMLInputElement).value) || 0;
  const people = parseInt((document.getElementById('people') as HTMLInputElement).value) || 1;
  const tip = bill * tipPct / 100;
  const total = bill + tip;
  document.getElementById('bill-display')!.textContent = `$${bill.toFixed(2)}`;
  document.getElementById('tip-pct')!.textContent = String(tipPct);
  document.getElementById('tip-display')!.textContent = `$${tip.toFixed(2)}`;
  document.getElementById('total-display')!.textContent = `$${total.toFixed(2)}`;
  document.getElementById('pp-display')!.textContent = `$${(total / people).toFixed(2)}`;
}

['bill', 'people'].forEach(id => document.getElementById(id)?.addEventListener('input', calc));
calc();
</script>
