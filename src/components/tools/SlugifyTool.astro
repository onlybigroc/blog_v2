---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex gap-3">
    <select id="sep" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value="-">连字符 -</option><option value="_">下划线 _</option></select>
    <label class="flex items-center gap-1 text-sm"><input id="lower" type="checkbox" checked class="rounded" /><span class="text-gray-500">小写</span></label>
    <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm ml-auto">复制</button>
  </div>
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入文本</label><input id="inp" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="Hello World! 你好世界" /></div>
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">Slug 结果</label><div id="result" class="rounded-lg border border-gray-200 dark:border-gray-700 p-3 font-mono text-sm bg-gray-50 dark:bg-gray-900 min-h-[2.5rem]"></div></div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLInputElement;
function slugify() {
  let s = inp.value.normalize('NFD').replace(/[̀-ͯ]/g, '');
  const sep = (document.getElementById('sep') as HTMLSelectElement).value;
  if ((document.getElementById('lower') as HTMLInputElement).checked) s = s.toLowerCase();
  s = s.replace(/[^\w\s一-鿿-]/g, '').replace(/[\s_]+/g, sep).replace(new RegExp(`${sep}+`, 'g'), sep).replace(new RegExp(`^${sep}|${sep}$`, 'g'), '');
  document.getElementById('result')!.textContent = s;
}
inp.addEventListener('input', slugify);
document.getElementById('sep')?.addEventListener('change', slugify);
document.getElementById('lower')?.addEventListener('change', slugify);
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText(document.getElementById('result')!.textContent!));
</script>
