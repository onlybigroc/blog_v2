---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex gap-3">
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">字数限制</span><input id="limit" type="number" value="100" min="1" class="w-20 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" /></label>
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">超出后缀</span><input id="suffix" type="text" value="..." class="w-16 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" /></label>
  </div>
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入文本</label><textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm"></textarea></div>
  <div class="flex items-center gap-3">
    <div class="flex-1 h-3 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden"><div id="meter" class="h-full rounded-full transition-all"></div></div>
    <span id="counter" class="text-sm font-mono w-20 text-right"></span>
  </div>
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">结果</label><div id="result" class="rounded-lg border border-gray-200 dark:border-gray-700 p-3 text-sm min-h-[3rem]"></div></div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLTextAreaElement;
function update() {
  const text = inp.value;
  const limit = parseInt((document.getElementById('limit') as HTMLInputElement).value) || 100;
  const suffix = (document.getElementById('suffix') as HTMLInputElement).value;
  const words = text.split(/\s+/).filter(Boolean);
  const count = words.length;
  const pct = Math.min(100, (count / limit) * 100);
  const meter = document.getElementById('meter')!;
  meter.style.width = pct + '%';
  meter.style.backgroundColor = pct > 100 ? '#ef4444' : pct > 80 ? '#f59e0b' : '#22c55e';
  document.getElementById('counter')!.textContent = `${count}/${limit}`;
  if (count <= limit) document.getElementById('result')!.textContent = text;
  else document.getElementById('result')!.textContent = words.slice(0, limit).join(' ') + suffix;
}
inp.addEventListener('input', update);
document.getElementById('limit')?.addEventListener('input', update);
document.getElementById('suffix')?.addEventListener('input', update);
</script>
