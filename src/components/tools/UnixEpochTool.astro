---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-6 text-center space-y-2">
    <div class="text-sm text-gray-500">当前 Unix 时间戳</div>
    <div id="current-ts" class="text-4xl font-mono font-bold text-primary-600 dark:text-primary-400"></div>
    <div id="current-date" class="text-sm text-gray-500"></div>
  </div>
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-3">
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">时间戳 → 日期</h3>
      <input id="ts-input" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm font-mono" placeholder="1700000000" />
      <div class="flex gap-2 text-xs"><label class="flex items-center gap-1"><input type="radio" name="ts-unit" value="s" checked /> 秒</label><label class="flex items-center gap-1"><input type="radio" name="ts-unit" value="ms" /> 毫秒</label></div>
      <button id="ts-to-date" class="w-full px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">转换</button>
      <div id="ts-result" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-3 text-sm font-mono"></div>
    </div>
    <div class="space-y-3">
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">日期 → 时间戳</h3>
      <input id="date-input" type="datetime-local" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
      <button id="date-to-ts" class="w-full px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">转换</button>
      <div id="date-result" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-3 text-sm font-mono"></div>
    </div>
  </div>
</div>
<script>
function update() {
  const now = Math.floor(Date.now() / 1000);
  document.getElementById('current-ts')!.textContent = String(now);
  document.getElementById('current-date')!.textContent = new Date().toLocaleString('zh-CN');
}
update(); setInterval(update, 1000);

document.getElementById('ts-to-date')?.addEventListener('click', () => {
  const ts = parseInt((document.getElementById('ts-input') as HTMLInputElement).value);
  if (isNaN(ts)) return;
  const unit = (document.querySelector('input[name="ts-unit"]:checked') as HTMLInputElement).value;
  const ms = unit === 'ms' ? ts : ts * 1000;
  const d = new Date(ms);
  const el = document.getElementById('ts-result')!;
  el.classList.remove('hidden');
  el.textContent = d.toLocaleString('zh-CN') + '\n' + d.toISOString();
});

document.getElementById('date-to-ts')?.addEventListener('click', () => {
  const d = new Date((document.getElementById('date-input') as HTMLInputElement).value);
  if (isNaN(d.getTime())) return;
  const el = document.getElementById('date-result')!;
  el.classList.remove('hidden');
  el.textContent = `秒: ${Math.floor(d.getTime() / 1000)}\n毫秒: ${d.getTime()}`;
});

(document.getElementById('date-input') as HTMLInputElement).value = new Date().toISOString().slice(0, 16);
</script>
