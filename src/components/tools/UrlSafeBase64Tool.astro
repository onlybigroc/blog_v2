---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex gap-3">
    <button id="encode" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">编码 →</button>
    <button id="decode" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-sm font-medium">← 解码</button>
    <button id="swap" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm" aria-label="互换">⇄</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">文本</label><textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="输入文本..."></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">URL Safe Base64</label><textarea id="out" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono"></textarea></div>
  </div>
  <div class="text-xs text-gray-500">URL Safe Base64 将 + 替换为 -，/ 替换为 _，并去除尾部 = 填充。</div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLTextAreaElement;
const out = document.getElementById('out') as HTMLTextAreaElement;
document.getElementById('encode')?.addEventListener('click', () => {
  let b64 = btoa(unescape(encodeURIComponent(inp.value)));
  b64 = b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
  out.value = b64;
});
document.getElementById('decode')?.addEventListener('click', () => {
  try {
    let b64 = out.value.replace(/-/g, '+').replace(/_/g, '/');
    while (b64.length % 4) b64 += '=';
    inp.value = decodeURIComponent(escape(atob(b64)));
  } catch { inp.value = '解码失败'; }
});
document.getElementById('swap')?.addEventListener('click', () => { const t = inp.value; inp.value = out.value; out.value = t; });
</script>
