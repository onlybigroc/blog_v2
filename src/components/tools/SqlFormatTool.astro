---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex flex-wrap gap-3">
    <button id="format" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">格式化</button>
    <button id="minify" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-sm font-medium">压缩</button>
    <select id="indent" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value="2">2 空格</option><option value="4">4 空格</option><option value="tab">Tab</option></select>
    <label class="flex items-center gap-1 text-sm"><input id="upper-kw" type="checkbox" class="rounded" checked /><span class="text-gray-500">大写关键字</span></label>
    <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm ml-auto">复制</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">SQL 输入</label><textarea id="inp" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono resize-y" placeholder="SELECT id, name FROM users WHERE age > 18 ORDER BY name LIMIT 10;"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">格式化结果</label><textarea id="out" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono resize-y" readonly></textarea></div>
  </div>
</div>
<script>
const keywords = ['SELECT','FROM','WHERE','AND','OR','ORDER BY','GROUP BY','HAVING','LIMIT','OFFSET','JOIN','LEFT JOIN','RIGHT JOIN','INNER JOIN','OUTER JOIN','CROSS JOIN','ON','INSERT','INTO','VALUES','UPDATE','SET','DELETE','CREATE','ALTER','DROP','TABLE','INDEX','AS','IN','NOT','NULL','IS','BETWEEN','LIKE','EXISTS','UNION','ALL','DISTINCT','CASE','WHEN','THEN','ELSE','END','ASC','DESC','COUNT','SUM','AVG','MIN','MAX'];

document.getElementById('format')?.addEventListener('click', () => {
  let sql = (document.getElementById('inp') as HTMLTextAreaElement).value.trim();
  const indentOpt = (document.getElementById('indent') as HTMLSelectElement).value;
  const upperKw = (document.getElementById('upper-kw') as HTMLInputElement).checked;
  const indentStr = indentOpt === 'tab' ? '\t' : ' '.repeat(parseInt(indentOpt));
  if (upperKw) {
    keywords.forEach(kw => {
      sql = sql.replace(new RegExp('\\b' + kw.replace(/ /g, '\\s+') + '\\b', 'gi'), kw);
    });
  }
  // Add newlines before major keywords
  const breakBefore = ['SELECT','FROM','WHERE','AND','OR','ORDER BY','GROUP BY','HAVING','LIMIT','JOIN','LEFT JOIN','RIGHT JOIN','INNER JOIN','ON','INSERT INTO','VALUES','UPDATE','SET','DELETE FROM','UNION'];
  breakBefore.forEach(kw => {
    sql = sql.replace(new RegExp('\\s*' + kw.replace(/ /g, '\\s+'), 'gi'), '\n' + (upperKw ? kw : kw));
  });
  // Indent subqueries
  let indent = 0;
  const lines = sql.split('\n').map(l => l.trim()).filter(Boolean);
  const result: string[] = [];
  for (const line of lines) {
    if (line.startsWith(')')) indent = Math.max(0, indent - 1);
    result.push(indentStr.repeat(indent) + line);
    if (line.includes('(') && !line.includes(')')) indent++;
  }
  (document.getElementById('out') as HTMLTextAreaElement).value = result.join('\n').trim();
});

document.getElementById('minify')?.addEventListener('click', () => {
  const sql = (document.getElementById('inp') as HTMLTextAreaElement).value.replace(/\s+/g, ' ').replace(/\s*([(),])\s*/g, '$1').trim();
  (document.getElementById('out') as HTMLTextAreaElement).value = sql;
});

document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
