---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入 URL</label><input id="inp" type="url" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm font-mono" placeholder="https://example.com/path/to/page?foo=bar&baz=qux#section" /></div>
  <div id="result" class="hidden space-y-3">
    <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-4 space-y-2 text-sm" id="parts"></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">缩短版本</label><div id="short" class="rounded-lg border border-gray-200 dark:border-gray-700 p-3 font-mono text-sm bg-gray-50 dark:bg-gray-900"></div></div>
    <div id="params-table" class="hidden"><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">查询参数</label><table class="w-full text-sm"><thead><tr class="border-b dark:border-gray-700"><th class="text-left py-1 px-2">参数</th><th class="text-left py-1 px-2">值</th></tr></thead><tbody id="params"></tbody></table></div>
  </div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLInputElement;
function parse() {
  const url = inp.value.trim();
  if (!url) { document.getElementById('result')!.classList.add('hidden'); return; }
  try {
    const u = new URL(url);
    document.getElementById('result')!.classList.remove('hidden');
    document.getElementById('parts')!.innerHTML = `
      <div class="flex justify-between"><span class="text-gray-500">协议</span><span class="font-mono">${u.protocol}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">域名</span><span class="font-mono font-medium">${u.hostname}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">端口</span><span class="font-mono">${u.port || '默认'}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">路径</span><span class="font-mono">${u.pathname || '/'}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">查询</span><span class="font-mono">${u.search || '无'}</span></div>
      <div class="flex justify-between"><span class="text-gray-500">锚点</span><span class="font-mono">${u.hash || '无'}</span></div>`;
    const segments = u.pathname.split('/').filter(Boolean);
    const short = u.hostname + (segments.length > 0 ? '/' + segments[0] + (segments.length > 1 ? '/...' : '') : '');
    document.getElementById('short')!.textContent = short;
    const params = u.searchParams;
    const pt = document.getElementById('params-table')!;
    if (params.toString()) {
      pt.classList.remove('hidden');
      let rows = '';
      params.forEach((v, k) => rows += `<tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-1 px-2 font-mono">${k}</td><td class="py-1 px-2 font-mono">${v}</td></tr>`);
      document.getElementById('params')!.innerHTML = rows;
    } else pt.classList.add('hidden');
  } catch { document.getElementById('result')!.classList.add('hidden'); }
}
inp.addEventListener('input', parse);
</script>
