---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono" placeholder={`# 配置文件\nDB_HOST=localhost\nDB_PORT=5432\nAPI_KEY="secret-key"\nDEBUG=true\n# 注释行`}></textarea>
  <div class="flex gap-3">
    <input id="search" type="text" class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="搜索变量..." />
    <label class="flex items-center gap-1 text-sm"><input id="hide-vals" type="checkbox" class="rounded" /><span class="text-gray-500">隐藏值</span></label>
  </div>
  <div id="table" class="overflow-auto"><table class="w-full text-sm"><thead><tr class="border-b dark:border-gray-700"><th class="text-left py-2 px-3">变量名</th><th class="text-left py-2 px-3">值</th><th class="text-left py-2 px-3">类型</th></tr></thead><tbody id="tbody"></tbody></table></div>
  <div id="count" class="text-sm text-gray-500"></div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLTextAreaElement;
const searchInput = document.getElementById('search') as HTMLInputElement;
let vars: {key: string, value: string, type: string}[] = [];

function parse() {
  vars = [];
  for (const rawLine of inp.value.split('\n')) {
    const line = rawLine.trim();
    if (!line || line.startsWith('#')) continue;
    const eqIdx = line.indexOf('=');
    if (eqIdx === -1) continue;
    const key = line.slice(0, eqIdx).trim();
    let value = line.slice(eqIdx + 1).trim();
    if ((value.startsWith('"') && value.endsWith('"')) || (value.startsWith("'") && value.endsWith("'"))) value = value.slice(1, -1);
    let type = '字符串';
    if (value === 'true' || value === 'false') type = '布尔';
    else if (/^-?\d+(\.\d+)?$/.test(value)) type = '数字';
    vars.push({ key, value, type });
  }
  render();
}

function render() {
  const q = searchInput.value.toLowerCase();
  const hide = (document.getElementById('hide-vals') as HTMLInputElement).checked;
  const filtered = vars.filter(v => !q || v.key.toLowerCase().includes(q) || v.value.toLowerCase().includes(q));
  document.getElementById('tbody')!.innerHTML = filtered.map(v =>
    `<tr class="border-b border-gray-100 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/50"><td class="py-2 px-3 font-mono font-medium">${v.key}</td><td class="py-2 px-3 font-mono">${hide ? '••••••' : v.value}</td><td class="py-2 px-3"><span class="px-2 py-0.5 rounded text-xs ${v.type==='布尔'?'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400':v.type==='数字'?'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400':'bg-gray-100 dark:bg-gray-700'}">${v.type}</span></td></tr>`
  ).join('');
  document.getElementById('count')!.textContent = `${filtered.length} / ${vars.length} 个变量`;
}

inp.addEventListener('input', parse);
searchInput.addEventListener('input', render);
document.getElementById('hide-vals')?.addEventListener('change', render);
</script>
