---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="space-y-4">
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">名单（每行一项）</label>
      <textarea id="items" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder={`张三\n李四\n王五\n赵六\n钱七`}></textarea>
    </div>
    <div class="flex items-center gap-3">
      <label class="text-sm text-gray-600 dark:text-gray-400">抽取数量</label>
      <input id="draw-count" type="number" value="1" min="1" class="w-20 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" />
      <label class="flex items-center gap-1 text-sm cursor-pointer"><input id="no-repeat" type="checkbox" class="rounded" checked /><span class="text-gray-600 dark:text-gray-400">不重复</span></label>
      <button id="draw" class="px-6 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">抽签！</button>
    </div>
  </div>
  <div id="result" class="hidden text-center space-y-3">
    <div class="text-4xl">🎉</div>
    <div id="drawn-items" class="text-xl font-bold text-primary-600 dark:text-primary-400"></div>
  </div>
  <div id="history" class="space-y-1 text-sm text-gray-500"></div>
</div>
<script>
const drawn = new Set<string>();
document.getElementById('draw')?.addEventListener('click', () => {
  const text = (document.getElementById('items') as HTMLTextAreaElement).value;
  let items = text.split('\n').map(s => s.trim()).filter(Boolean);
  const count = Math.min(parseInt((document.getElementById('draw-count') as HTMLInputElement).value) || 1, items.length);
  const noRepeat = (document.getElementById('no-repeat') as HTMLInputElement).checked;
  if (noRepeat) items = items.filter(i => !drawn.has(i));
  if (items.length === 0) return;
  const picked: string[] = [];
  for (let i = 0; i < count && items.length > 0; i++) {
    const idx = Math.floor(Math.random() * items.length);
    picked.push(items[idx]);
    if (noRepeat) { drawn.add(items[idx]); items.splice(idx, 1); }
  }
  const result = document.getElementById('result')!;
  result.classList.remove('hidden');
  document.getElementById('drawn-items')!.textContent = picked.join('、');
  const log = document.createElement('div');
  log.textContent = `抽中: ${picked.join(', ')}`;
  document.getElementById('history')!.prepend(log);
});
</script>
