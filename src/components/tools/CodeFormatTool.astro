---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---

<div class="space-y-6" id="code-format-tool">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex flex-wrap items-center gap-3">
    <select id="cf-lang" class="rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm">
      <option value="json">JSON</option>
      <option value="css">CSS</option>
      <option value="html">HTML</option>
    </select>
    <select id="cf-indent" class="rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm">
      <option value="2">2 空格</option>
      <option value="4">4 空格</option>
      <option value="tab">Tab</option>
    </select>
    <button id="cf-format" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">✨ 格式化</button>
    <button id="cf-minify" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium">📦 压缩</button>
    <button id="cf-copy" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium">📋 复制</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label>
      <textarea id="cf-input" class="w-full h-80 p-4 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 font-mono text-sm resize-y" placeholder="粘贴代码到这里..."></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输出</label>
      <textarea id="cf-output" class="w-full h-80 p-4 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 font-mono text-sm resize-y" readonly></textarea>
    </div>
  </div>
  <div id="cf-status" class="hidden rounded-lg p-3 text-sm"></div>
</div>

<script>
  const input = document.getElementById('cf-input') as HTMLTextAreaElement;
  const output = document.getElementById('cf-output') as HTMLTextAreaElement;
  const langSel = document.getElementById('cf-lang') as HTMLSelectElement;
  const indentSel = document.getElementById('cf-indent') as HTMLSelectElement;
  const statusEl = document.getElementById('cf-status')!;

  function showStatus(msg: string, ok = true) {
    statusEl.textContent = msg;
    statusEl.className = `rounded-lg p-3 text-sm ${ok ? 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400'}`;
    statusEl.classList.remove('hidden');
    setTimeout(() => statusEl.classList.add('hidden'), 3000);
  }

  function getIndent(): string {
    const v = indentSel.value;
    return v === 'tab' ? '\t' : ' '.repeat(parseInt(v));
  }

  function formatCSS(css: string, indent: string): string {
    let level = 0;
    return css.replace(/\s*{\s*/g, ' {\n').replace(/\s*}\s*/g, '\n}\n').replace(/\s*;\s*/g, ';\n').split('\n').map(line => {
      line = line.trim();
      if (!line) return '';
      if (line === '}') { level = Math.max(0, level - 1); return indent.repeat(level) + '}'; }
      const out = indent.repeat(level) + line;
      if (line.endsWith('{')) level++;
      return out;
    }).filter(Boolean).join('\n');
  }

  function formatHTML(html: string, indent: string): string {
    const selfClose = /^<(area|base|br|col|embed|hr|img|input|link|meta|param|source|track|wbr)\b/i;
    let level = 0;
    const tokens = html.replace(/>\s*</g, '>\n<').split('\n');
    return tokens.map(token => {
      token = token.trim();
      if (!token) return '';
      if (token.startsWith('</')) { level = Math.max(0, level - 1); return indent.repeat(level) + token; }
      const out = indent.repeat(level) + token;
      if (token.startsWith('<') && !token.endsWith('/>') && !selfClose.test(token) && !token.startsWith('<!')) level++;
      return out;
    }).filter(Boolean).join('\n');
  }

  document.getElementById('cf-format')?.addEventListener('click', () => {
    try {
      const indent = getIndent();
      const lang = langSel.value;
      if (lang === 'json') { output.value = JSON.stringify(JSON.parse(input.value), null, indent); }
      else if (lang === 'css') { output.value = formatCSS(input.value, indent); }
      else { output.value = formatHTML(input.value, indent); }
      showStatus('✅ 格式化完成');
    } catch (e: any) { showStatus('❌ ' + e.message, false); }
  });

  document.getElementById('cf-minify')?.addEventListener('click', () => {
    try {
      const lang = langSel.value;
      if (lang === 'json') { output.value = JSON.stringify(JSON.parse(input.value)); }
      else if (lang === 'css') { output.value = input.value.replace(/\/\*[\s\S]*?\*\//g, '').replace(/\s+/g, ' ').replace(/\s*([{}:;,])\s*/g, '$1').trim(); }
      else { output.value = input.value.replace(/>\s+</g, '><').replace(/\s+/g, ' ').trim(); }
      showStatus('✅ 压缩完成');
    } catch (e: any) { showStatus('❌ ' + e.message, false); }
  });

  document.getElementById('cf-copy')?.addEventListener('click', async () => {
    if (!output.value) return;
    await navigator.clipboard.writeText(output.value);
    showStatus('✅ 已复制');
  });
</script>
