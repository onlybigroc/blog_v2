---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex gap-3">
    <button id="reverse" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">反转单词</button>
    <label class="flex items-center gap-1 text-sm"><input id="keep-lines" type="checkbox" class="rounded" /><span class="text-gray-500">保留行结构</span></label>
    <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm ml-auto">复制</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label><textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="hello world foo bar"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">结果</label><textarea id="out" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm" readonly></textarea></div>
  </div>
</div>
<script>
document.getElementById('reverse')?.addEventListener('click', () => {
  const text = (document.getElementById('inp') as HTMLTextAreaElement).value;
  const keep = (document.getElementById('keep-lines') as HTMLInputElement).checked;
  const result = keep ? text.split('\n').map(l => l.split(/\s+/).reverse().join(' ')).join('\n') : text.split(/\s+/).reverse().join(' ');
  (document.getElementById('out') as HTMLTextAreaElement).value = result;
});
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
