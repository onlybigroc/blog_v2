---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex gap-3">
    <input id="keyword" type="text" class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="输入关键词..." />
    <label class="flex items-center gap-1 text-sm"><input id="cs" type="checkbox" class="rounded" /><span class="text-gray-500">区分大小写</span></label>
    <span id="count" class="text-sm text-gray-500 self-center"></span>
  </div>
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入文本</label><textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="在此输入要搜索的文本..."></textarea></div>
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">高亮结果</label><div id="preview" class="w-full min-h-[12rem] p-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm whitespace-pre-wrap"></div></div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLTextAreaElement;
const keyword = document.getElementById('keyword') as HTMLInputElement;
function highlight() {
  const text = inp.value;
  const kw = keyword.value;
  if (!kw || !text) { document.getElementById('preview')!.textContent = text; document.getElementById('count')!.textContent = ''; return; }
  const cs = (document.getElementById('cs') as HTMLInputElement).checked;
  const flags = cs ? 'g' : 'gi';
  const escaped = kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const regex = new RegExp(escaped, flags);
  let count = 0;
  const html = text.replace(regex, m => { count++; return `<mark class="bg-yellow-200 dark:bg-yellow-800 px-0.5 rounded">${m}</mark>`; });
  document.getElementById('preview')!.innerHTML = html;
  document.getElementById('count')!.textContent = `${count} 处匹配`;
}
inp.addEventListener('input', highlight);
keyword.addEventListener('input', highlight);
document.getElementById('cs')?.addEventListener('change', highlight);
</script>
