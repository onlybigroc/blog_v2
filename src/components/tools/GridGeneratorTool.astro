---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-4">
      <div class="grid grid-cols-2 gap-3">
        <div><label class="block text-sm text-gray-500 mb-1">列数: <span id="cols-val">3</span></label><input id="cols" type="range" min="1" max="6" value="3" class="w-full" /></div>
        <div><label class="block text-sm text-gray-500 mb-1">行数: <span id="rows-val">3</span></label><input id="rows" type="range" min="1" max="6" value="3" class="w-full" /></div>
      </div>
      <div><label class="block text-sm text-gray-500 mb-1">列模板</label><input id="col-template" type="text" class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm font-mono" value="1fr 1fr 1fr" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">行模板</label><input id="row-template" type="text" class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm font-mono" value="1fr 1fr 1fr" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">间距: <span id="gap-val">10</span>px</label><input id="gap" type="range" min="0" max="40" value="10" class="w-full" /></div>
    </div>
    <div class="space-y-4">
      <div id="preview" class="rounded-lg bg-gray-100 dark:bg-gray-800 p-3 min-h-[200px]"></div>
      <div class="relative"><pre id="code" class="p-3 rounded-lg bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-sm font-mono"></pre><button id="copy" class="absolute top-2 right-2 px-2 py-1 text-xs rounded bg-gray-200 dark:bg-gray-700">复制</button></div>
    </div>
  </div>
</div>
<script>
const colors = ['#3b82f6','#ef4444','#22c55e','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316','#10b981'];
function update() {
  const cols = parseInt((document.getElementById('cols') as HTMLInputElement).value);
  const rows = parseInt((document.getElementById('rows') as HTMLInputElement).value);
  const colTpl = (document.getElementById('col-template') as HTMLInputElement).value || `repeat(${cols}, 1fr)`;
  const rowTpl = (document.getElementById('row-template') as HTMLInputElement).value || `repeat(${rows}, 1fr)`;
  const gap = parseInt((document.getElementById('gap') as HTMLInputElement).value);
  document.getElementById('cols-val')!.textContent = String(cols);
  document.getElementById('rows-val')!.textContent = String(rows);
  document.getElementById('gap-val')!.textContent = String(gap);
  const n = cols * rows;
  let cells = '';
  for (let i = 0; i < n; i++) cells += `<div class="rounded flex items-center justify-center text-white text-xs font-bold" style="background:${colors[i%colors.length]};min-height:40px">${i+1}</div>`;
  document.getElementById('preview')!.innerHTML = `<div style="display:grid;grid-template-columns:${colTpl};grid-template-rows:${rowTpl};gap:${gap}px">${cells}</div>`;
  document.getElementById('code')!.textContent = `.container {\n  display: grid;\n  grid-template-columns: ${colTpl};\n  grid-template-rows: ${rowTpl};\n  gap: ${gap}px;\n}`;
}
['cols','rows','gap'].forEach(k => document.getElementById(k)?.addEventListener('input', update));
['col-template','row-template'].forEach(k => document.getElementById(k)?.addEventListener('input', update));
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText(document.getElementById('code')!.textContent!));
update();
</script>
