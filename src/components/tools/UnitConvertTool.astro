---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="flex flex-wrap items-end gap-4">
    <div class="flex-1 min-w-[120px]">
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">数值</label>
      <input id="val" type="number" value="1" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">类别</label>
      <select id="cat" class="rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm"></select>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">从</label>
      <select id="from" class="rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm"></select>
    </div>
    <button id="swap" class="px-3 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-sm" aria-label="互换">⇄</button>
    <div>
      <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">到</label>
      <select id="to" class="rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm"></select>
    </div>
  </div>
  <div id="result" class="text-2xl font-bold text-center py-4 text-primary-600 dark:text-primary-400"></div>
  <div id="formula" class="text-sm text-gray-500 text-center"></div>
</div>
<script>
const cats: Record<string, Record<string, number>> = {
  '长度': { '米': 1, '千米': 1000, '厘米': 0.01, '毫米': 0.001, '英里': 1609.344, '英尺': 0.3048, '英寸': 0.0254, '码': 0.9144, '海里': 1852, '里': 500, '尺': 0.3333 },
  '重量': { '千克': 1, '克': 0.001, '吨': 1000, '毫克': 0.000001, '磅': 0.453592, '盎司': 0.0283495, '斤': 0.5, '两': 0.05 },
  '面积': { '平方米': 1, '平方千米': 1e6, '公顷': 1e4, '平方英尺': 0.092903, '平方英里': 2.59e6, '亩': 666.667, '英亩': 4046.86 },
  '速度': { '米/秒': 1, '千米/时': 0.277778, '英里/时': 0.44704, '节': 0.514444, '马赫': 343 },
  '数据': { '字节': 1, 'KB': 1024, 'MB': 1048576, 'GB': 1073741824, 'TB': 1099511627776, 'PB': 1125899906842624 },
};
const catEl = document.getElementById('cat') as HTMLSelectElement;
const fromEl = document.getElementById('from') as HTMLSelectElement;
const toEl = document.getElementById('to') as HTMLSelectElement;
Object.keys(cats).forEach(c => catEl.innerHTML += `<option value="${c}">${c}</option>`);
function updateUnits() {
  const units = Object.keys(cats[catEl.value]);
  fromEl.innerHTML = units.map((u, i) => `<option ${i===0?'selected':''}>${u}</option>`).join('');
  toEl.innerHTML = units.map((u, i) => `<option ${i===1||units.length<2?'selected':''}>${u}</option>`).join('');
}
function convert() {
  const v = parseFloat((document.getElementById('val') as HTMLInputElement).value) || 0;
  const units = cats[catEl.value];
  const result = v * units[fromEl.value] / units[toEl.value];
  document.getElementById('result')!.textContent = `${v} ${fromEl.value} = ${result.toPrecision(8).replace(/\.?0+$/, '')} ${toEl.value}`;
}
catEl.addEventListener('change', () => { updateUnits(); convert(); });
[fromEl, toEl].forEach(el => el.addEventListener('change', convert));
document.getElementById('val')?.addEventListener('input', convert);
document.getElementById('swap')?.addEventListener('click', () => { const t = fromEl.value; fromEl.value = toEl.value; toEl.value = t; convert(); });
updateUnits(); convert();
</script>
