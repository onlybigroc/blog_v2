---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex gap-3">
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">最大长度</span><input id="max-len" type="number" value="50" min="1" class="w-20 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" /></label>
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">后缀</span><input id="suffix" type="text" value="..." class="w-16 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" /></label>
    <label class="flex items-center gap-1 text-sm"><input id="word-boundary" type="checkbox" class="rounded" /><span class="text-gray-500">单词边界</span></label>
    <button id="truncate" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">截断</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label><textarea id="inp" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">截断结果</label><textarea id="out" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm" readonly></textarea></div>
  </div>
  <div id="stats" class="text-sm text-gray-500"></div>
</div>
<script>
document.getElementById('truncate')?.addEventListener('click', () => {
  const text = (document.getElementById('inp') as HTMLTextAreaElement).value;
  const maxLen = parseInt((document.getElementById('max-len') as HTMLInputElement).value) || 50;
  const suffix = (document.getElementById('suffix') as HTMLInputElement).value;
  const wordBoundary = (document.getElementById('word-boundary') as HTMLInputElement).checked;
  let result: string;
  if (text.length <= maxLen) result = text;
  else {
    let end = maxLen - suffix.length;
    if (wordBoundary) { while (end > 0 && text[end] !== ' ' && text[end] !== '\n') end--; if (end === 0) end = maxLen - suffix.length; }
    result = text.slice(0, end) + suffix;
  }
  (document.getElementById('out') as HTMLTextAreaElement).value = result;
  document.getElementById('stats')!.textContent = `原始 ${text.length} 字符 → 截断后 ${result.length} 字符`;
});
</script>
