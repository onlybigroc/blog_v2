---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex gap-2 border-b border-gray-200 dark:border-gray-700">
    <button id="tab-edit" class="tab py-2 px-4 text-sm font-medium border-b-2 border-primary-600 text-primary-600">编辑</button>
    <button id="tab-preview" class="tab py-2 px-4 text-sm font-medium border-b-2 border-transparent text-gray-500">预览</button>
    <button id="tab-html" class="tab py-2 px-4 text-sm font-medium border-b-2 border-transparent text-gray-500">HTML</button>
    <button id="copy" class="ml-auto px-3 py-1 my-1 rounded bg-gray-200 dark:bg-gray-700 text-sm">复制 HTML</button>
  </div>
  <div id="view-edit"><textarea id="inp" class="w-full h-80 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono" placeholder="# 标题\n\n正文内容，**加粗** 和 *斜体*。"></textarea></div>
  <div id="view-preview" class="hidden prose dark:prose-invert max-w-none p-4 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800"></div>
  <div id="view-html" class="hidden"><textarea id="html-out" class="w-full h-80 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm font-mono" readonly></textarea></div>
</div>
<script>
import { escapeHtml, normalizeSafeUrl } from '@utils/safeHtml';

function md2html(md: string): string {
  const codeBlocks: string[] = [];
  const inlineCodes: string[] = [];
  let html = md
    .replace(/```([\s\S]*?)```/g, (_m, code) => {
      const idx = codeBlocks.length;
      codeBlocks.push(`<pre><code>${escapeHtml(code.replace(/\n$/, ''))}</code></pre>`);
      return `@@CODEBLOCK${idx}@@`;
    })
    .replace(/`([^`]+)`/g, (_m, code) => {
      const idx = inlineCodes.length;
      inlineCodes.push(`<code>${escapeHtml(code)}</code>`);
      return `@@INLINECODE${idx}@@`;
    });

  html = escapeHtml(html)
    .replace(/^### (.+)$/gm, '<h3>$1</h3>').replace(/^## (.+)$/gm, '<h2>$1</h2>').replace(/^# (.+)$/gm, '<h1>$1</h1>')
    .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/~~(.+?)~~/g, '<del>$1</del>')
    .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, (_m, alt, src) => `<img src="${normalizeSafeUrl(src)}" alt="${alt.replace(/`/g, '&#96;')}" />`)
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_m, label, href) => `<a href="${normalizeSafeUrl(href)}">${label}</a>`)
    .replace(/^---$/gm, '<hr />')
    .replace(/^(\d+)\. (.+)$/gm, '<li>$2</li>')
    .replace(/^[-*] (.+)$/gm, '<li>$1</li>');

  codeBlocks.forEach((block, i) => {
    html = html.replace(`@@CODEBLOCK${i}@@`, block);
  });
  inlineCodes.forEach((code, i) => {
    html = html.replace(`@@INLINECODE${i}@@`, code);
  });

  // Convert newlines
  html = html.split(/\n\n+/).map(block => {
    block = block.trim();
    if (!block) return '';
    if (block.startsWith('<h') || block.startsWith('<blockquote') || block.startsWith('<pre') || block.startsWith('<hr') || block.startsWith('<li')) return block;
    return `<p>${block.replace(/\n/g, '<br />')}</p>`;
  }).join('\n');
  return html;
}
const inp = document.getElementById('inp') as HTMLTextAreaElement;
function update() {
  const html = md2html(inp.value);
  document.getElementById('view-preview')!.innerHTML = html;
  (document.getElementById('html-out') as HTMLTextAreaElement).value = html;
}
inp.addEventListener('input', update);
document.querySelectorAll('.tab').forEach(btn => btn.addEventListener('click', () => {
  document.querySelectorAll('.tab').forEach(b => b.className = 'tab py-2 px-4 text-sm font-medium border-b-2 border-transparent text-gray-500');
  btn.className = 'tab py-2 px-4 text-sm font-medium border-b-2 border-primary-600 text-primary-600';
  const id = (btn as HTMLElement).id.replace('tab-', 'view-');
  ['edit','preview','html'].forEach(v => document.getElementById('view-'+v)!.classList.toggle('hidden', 'view-'+v !== id));
  if (id === 'view-preview' || id === 'view-html') update();
}));
document.getElementById('copy')?.addEventListener('click', async () => { update(); await navigator.clipboard.writeText((document.getElementById('html-out') as HTMLTextAreaElement).value); });
</script>
