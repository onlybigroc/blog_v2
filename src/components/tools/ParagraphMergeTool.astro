---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex gap-3">
    <select id="sep" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value=" ">空格</option><option value="">无分隔</option><option value="，">逗号</option><option value="\n">换行</option></select>
    <label class="flex items-center gap-1 text-sm"><input id="trim" type="checkbox" checked class="rounded" /><span class="text-gray-500">去除空白</span></label>
    <button id="merge" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">合并</button>
    <button id="copy" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">复制</button>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入</label><textarea id="inp" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="第一段\n第二段\n第三段"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">合并结果</label><textarea id="out" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm" readonly></textarea></div>
  </div>
  <div id="stats" class="text-sm text-gray-500"></div>
</div>
<script>
document.getElementById('merge')?.addEventListener('click', () => {
  let lines = (document.getElementById('inp') as HTMLTextAreaElement).value.split('\n');
  if ((document.getElementById('trim') as HTMLInputElement).checked) lines = lines.map(l => l.trim()).filter(Boolean);
  const sep = (document.getElementById('sep') as HTMLSelectElement).value.replace('\\n', '\n');
  const result = lines.join(sep);
  (document.getElementById('out') as HTMLTextAreaElement).value = result;
  document.getElementById('stats')!.textContent = `原始 ${lines.length} 段 → 合并后 ${result.length} 字符`;
});
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText((document.getElementById('out') as HTMLTextAreaElement).value));
</script>
