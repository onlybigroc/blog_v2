---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-4">
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">关键帧设置</h3>
      <div class="space-y-3">
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3">
          <div class="text-xs text-gray-500 mb-2">0% (起始)</div>
          <label class="text-sm text-gray-500">旋转: <span id="r0-val">0</span>°</label><input id="r0" type="range" min="0" max="360" value="0" class="w-full" />
          <label class="text-sm text-gray-500">缩放: <span id="s0-val">1</span></label><input id="s0" type="range" min="50" max="200" value="100" class="w-full" />
          <label class="text-sm text-gray-500">透明度: <span id="o0-val">1</span></label><input id="o0" type="range" min="0" max="100" value="100" class="w-full" />
        </div>
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3">
          <div class="text-xs text-gray-500 mb-2">50% (中间)</div>
          <label class="text-sm text-gray-500">旋转: <span id="r50-val">180</span>°</label><input id="r50" type="range" min="0" max="360" value="180" class="w-full" />
          <label class="text-sm text-gray-500">缩放: <span id="s50-val">1.5</span></label><input id="s50" type="range" min="50" max="200" value="150" class="w-full" />
          <label class="text-sm text-gray-500">透明度: <span id="o50-val">1</span></label><input id="o50" type="range" min="0" max="100" value="100" class="w-full" />
        </div>
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 p-3">
          <div class="text-xs text-gray-500 mb-2">100% (结束)</div>
          <label class="text-sm text-gray-500">旋转: <span id="r100-val">360</span>°</label><input id="r100" type="range" min="0" max="720" value="360" class="w-full" />
          <label class="text-sm text-gray-500">缩放: <span id="s100-val">1</span></label><input id="s100" type="range" min="50" max="200" value="100" class="w-full" />
          <label class="text-sm text-gray-500">透明度: <span id="o100-val">1</span></label><input id="o100" type="range" min="0" max="100" value="100" class="w-full" />
        </div>
      </div>
      <div><label class="block text-sm text-gray-500 mb-1">时长: <span id="dur-val">2</span>s</label><input id="duration" type="range" min="1" max="10" value="2" step="0.5" class="w-full" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">缓动</label><select id="easing" class="w-full rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option>linear</option><option>ease</option><option selected>ease-in-out</option><option>ease-in</option><option>ease-out</option></select></div>
    </div>
    <div class="space-y-4">
      <div class="flex items-center justify-center h-48 rounded-lg bg-gray-100 dark:bg-gray-800 overflow-hidden">
        <div id="preview" class="w-16 h-16 bg-primary-500 rounded-lg"></div>
      </div>
      <div class="relative"><pre id="code" class="p-3 rounded-lg bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-sm font-mono"></pre><button id="copy" class="absolute top-2 right-2 px-2 py-1 text-xs rounded bg-gray-200 dark:bg-gray-700">复制</button></div>
    </div>
  </div>
</div>
<script>
function update() {
  const r0 = parseInt((document.getElementById('r0') as HTMLInputElement).value);
  const s0 = parseInt((document.getElementById('s0') as HTMLInputElement).value) / 100;
  const o0 = parseInt((document.getElementById('o0') as HTMLInputElement).value) / 100;
  const r50 = parseInt((document.getElementById('r50') as HTMLInputElement).value);
  const s50 = parseInt((document.getElementById('s50') as HTMLInputElement).value) / 100;
  const o50 = parseInt((document.getElementById('o50') as HTMLInputElement).value) / 100;
  const r100 = parseInt((document.getElementById('r100') as HTMLInputElement).value);
  const s100 = parseInt((document.getElementById('s100') as HTMLInputElement).value) / 100;
  const o100 = parseInt((document.getElementById('o100') as HTMLInputElement).value) / 100;
  const dur = parseFloat((document.getElementById('duration') as HTMLInputElement).value);
  const easing = (document.getElementById('easing') as HTMLSelectElement).value;
  ['r0','s0','o0','r50','s50','o50','r100','s100','o100','dur'].forEach(k => { const el = document.getElementById(k+'-val'); if (el) el.textContent = eval(k.replace('dur','dur')).toString(); });
  document.getElementById('dur-val')!.textContent = String(dur);
  const animName = 'my-animation';
  const style = document.getElementById('preview') as HTMLElement;
  style.style.animation = `${animName} ${dur}s ${easing} infinite`;
  // Inject keyframes
  let styleTag = document.getElementById('anim-style');
  if (!styleTag) { styleTag = document.createElement('style'); styleTag.id = 'anim-style'; document.head.appendChild(styleTag); }
  styleTag.textContent = `@keyframes ${animName} { 0% { transform: rotate(${r0}deg) scale(${s0}); opacity: ${o0}; } 50% { transform: rotate(${r50}deg) scale(${s50}); opacity: ${o50}; } 100% { transform: rotate(${r100}deg) scale(${s100}); opacity: ${o100}; } }`;
  document.getElementById('code')!.textContent = `@keyframes ${animName} {\n  0% {\n    transform: rotate(${r0}deg) scale(${s0});\n    opacity: ${o0};\n  }\n  50% {\n    transform: rotate(${r50}deg) scale(${s50});\n    opacity: ${o50};\n  }\n  100% {\n    transform: rotate(${r100}deg) scale(${s100});\n    opacity: ${o100};\n  }\n}\n\n.element {\n  animation: ${animName} ${dur}s ${easing} infinite;\n}`;
}
['r0','s0','o0','r50','s50','o50','r100','s100','o100','duration'].forEach(k => document.getElementById(k)?.addEventListener('input', update));
document.getElementById('easing')?.addEventListener('change', update);
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText(document.getElementById('code')!.textContent!));
update();
</script>
