---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="space-y-4">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">密码</label><input id="pwd" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="输入密钥" /></div>
    <div class="flex gap-3">
      <button id="enc" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">加密</button>
      <button id="dec" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 text-sm font-medium">解密</button>
      <button id="swap" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm" aria-label="互换">⇄</button>
    </div>
    <div class="grid gap-4 lg:grid-cols-2">
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">明文</label><textarea id="plain" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="输入要加密的文本"></textarea></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">密文 (Hex)</label><textarea id="cipher" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-mono" placeholder="输入要解密的密文"></textarea></div>
    </div>
    <div id="status" class="hidden rounded-lg p-3 text-sm"></div>
  </div>
</div>
<script>
function showStatus(msg: string, type: string) {
  const s = document.getElementById('status')!;
  s.textContent = msg;
  s.className = `rounded-lg p-3 text-sm ${type === 'ok' ? 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400'}`;
  s.classList.remove('hidden');
}
function xorCrypt(text: string, key: string): string {
  if (!key) return text;
  const result: number[] = [];
  for (let i = 0; i < text.length; i++) result.push(text.charCodeAt(i) ^ key.charCodeAt(i % key.length));
  return result.map(b => b.toString(16).padStart(2, '0')).join(' ');
}
function xorDecrypt(hex: string, key: string): string {
  if (!key) return hex;
  const bytes = hex.trim().split(/\s+/).map(h => parseInt(h, 16));
  if (bytes.some(isNaN)) throw new Error('无效的十六进制数据');
  return String.fromCharCode(...bytes.map((b, i) => b ^ key.charCodeAt(i % key.length)));
}
document.getElementById('enc')?.addEventListener('click', () => {
  const key = (document.getElementById('pwd') as HTMLInputElement).value;
  if (!key) { showStatus('请输入密码', 'err'); return; }
  (document.getElementById('cipher') as HTMLTextAreaElement).value = xorCrypt((document.getElementById('plain') as HTMLTextAreaElement).value, key);
  showStatus('加密成功', 'ok');
});
document.getElementById('dec')?.addEventListener('click', () => {
  const key = (document.getElementById('pwd') as HTMLInputElement).value;
  if (!key) { showStatus('请输入密码', 'err'); return; }
  try {
    (document.getElementById('plain') as HTMLTextAreaElement).value = xorDecrypt((document.getElementById('cipher') as HTMLTextAreaElement).value, key);
    showStatus('解密成功', 'ok');
  } catch (e) { showStatus('解密失败: ' + (e as Error).message, 'err'); }
});
document.getElementById('swap')?.addEventListener('click', () => {
  const p = document.getElementById('plain') as HTMLTextAreaElement, c = document.getElementById('cipher') as HTMLTextAreaElement;
  const t = p.value; p.value = c.value; c.value = t;
});
</script>
