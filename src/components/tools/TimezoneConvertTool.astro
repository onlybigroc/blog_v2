---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="grid gap-4 md:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">源时区</label><select id="from-tz" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm"></select></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">目标时区</label><select id="to-tz" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm"></select></div>
  </div>
  <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">日期时间</label><input id="dt" type="datetime-local" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" /></div>
  <button id="convert" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">转换</button>
  <div id="result" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-4 space-y-2 text-sm"></div>
  <div id="live-times" class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm"></div>
</div>
<script>
const timezones = [
  'UTC','Asia/Shanghai','Asia/Tokyo','Asia/Seoul','Asia/Singapore','Asia/Kolkata','Asia/Dubai',
  'Europe/London','Europe/Paris','Europe/Berlin','Europe/Moscow',
  'America/New_York','America/Chicago','America/Denver','America/Los_Angeles','America/Sao_Paulo',
  'Australia/Sydney','Pacific/Auckland'
];
const fromEl = document.getElementById('from-tz') as HTMLSelectElement;
const toEl = document.getElementById('to-tz') as HTMLSelectElement;
timezones.forEach(tz => {
  const label = tz.replace(/_/g, ' ').split('/').pop();
  fromEl.innerHTML += `<option value="${tz}" ${tz==='Asia/Shanghai'?'selected':''}>${label} (${tz})</option>`;
  toEl.innerHTML += `<option value="${tz}" ${tz==='America/New_York'?'selected':''}>${label} (${tz})</option>`;
});

document.getElementById('convert')?.addEventListener('click', () => {
  const dt = (document.getElementById('dt') as HTMLInputElement).value;
  if (!dt) return;
  const fromTz = fromEl.value, toTz = toEl.value;
  try {
    const date = new Date(dt);
    const fromStr = date.toLocaleString('zh-CN', { timeZone: fromTz });
    const toStr = date.toLocaleString('zh-CN', { timeZone: toTz });
    const el = document.getElementById('result')!;
    el.classList.remove('hidden');
    el.innerHTML = `<div class="flex justify-between"><span class="text-gray-500">源时间</span><span>${fromStr} (${fromTz})</span></div><div class="text-center text-primary-600 font-bold">↓</div><div class="flex justify-between"><span class="text-gray-500">目标时间</span><span class="font-bold">${toStr} (${toTz})</span></div>`;
  } catch (e) {}
});

function updateLive() {
  const live = document.getElementById('live-times')!;
  live.innerHTML = timezones.slice(0, 8).map(tz => {
    const time = new Date().toLocaleTimeString('zh-CN', { timeZone: tz, hour: '2-digit', minute: '2-digit', second: '2-digit' });
    const label = tz.split('/').pop()!.replace(/_/g, ' ');
    return `<div class="rounded-lg border border-gray-200 dark:border-gray-700 p-2 text-center"><div class="text-xs text-gray-500">${label}</div><div class="font-mono font-medium">${time}</div></div>`;
  }).join('');
}
updateLive();
setInterval(updateLive, 1000);

const now = new Date();
(document.getElementById('dt') as HTMLInputElement).value = now.toISOString().slice(0, 16);
</script>
