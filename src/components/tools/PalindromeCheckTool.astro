---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="max-w-md mx-auto space-y-4">
    <input id="inp" type="text" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-4 py-3 text-lg text-center" placeholder="输入要检测的文本..." />
    <label class="flex items-center gap-2 text-sm cursor-pointer"><input id="ignore" type="checkbox" class="rounded" checked /><span class="text-gray-600 dark:text-gray-400">忽略空格和标点</span></label>
    <div id="result" class="hidden text-center py-4 rounded-lg"></div>
    <div id="visual" class="hidden text-center font-mono text-lg tracking-wider py-3"></div>
  </div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLInputElement;
const ignoreCheck = document.getElementById('ignore') as HTMLInputElement;
function check() {
  const text = inp.value;
  if (!text) { document.getElementById('result')!.classList.add('hidden'); document.getElementById('visual')!.classList.add('hidden'); return; }
  const clean = ignoreCheck.checked ? text.replace(/[^a-zA-Z0-9一-鿿]/g, '').toLowerCase() : text.toLowerCase();
  const reversed = clean.split('').reverse().join('');
  const isPalin = clean === reversed;
  const result = document.getElementById('result')!;
  result.classList.remove('hidden');
  result.className = `text-center py-4 rounded-lg ${isPalin ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400' : 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400'}`;
  result.textContent = isPalin ? '✅ 是回文！' : '❌ 不是回文';
  const visual = document.getElementById('visual')!;
  visual.classList.remove('hidden');
  visual.textContent = '';
  const original = document.createElement('span');
  original.textContent = text;
  const separator = document.createElement('span');
  separator.className = 'text-gray-400';
  separator.textContent = ' vs ';
  const reversedText = document.createElement('span');
  reversedText.textContent = text.split('').reverse().join('');
  visual.append(original, separator, reversedText);
}
inp.addEventListener('input', check);
ignoreCheck.addEventListener('change', check);
</script>
