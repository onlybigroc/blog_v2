  // --- DOM ---
  const input = document.getElementById('md-input') as HTMLTextAreaElement;
  const preview = document.getElementById('md-preview') as HTMLElement;
  const status = document.getElementById('md-status') as HTMLElement;
  const split = document.getElementById('md-split') as HTMLElement;

  function showStatus(msg: string, type: 'success' | 'error') {
    status.textContent = msg;
    status.className = `rounded-lg p-3 text-sm ${type === 'success' ? 'bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-red-50 text-red-700 dark:bg-red-900/30 dark:text-red-400'}`;
    status.classList.remove('hidden');
    setTimeout(() => status.classList.add('hidden'), 2000);
  }

  // е®һж—¶йў„и§Ҳ
  let debounceTimer: number;
  function updatePreview() {
    clearTimeout(debounceTimer);
    debounceTimer = window.setTimeout(() => {
      const md = input.value;
      if (!md.trim()) {
        preview.innerHTML = '<p class="text-gray-400 italic">йў„и§Ҳе°ҶжҳҫзӨәеңЁиҝҷйҮҢ...</p>';
        return;
      }
      preview.innerHTML = parseMarkdown(md);
    }, 150);
  }

  input.addEventListener('input', updatePreview);

  // еӨҚеҲ¶ Markdown
  document.getElementById('btn-copy-md')?.addEventListener('click', async () => {
    if (!input.value) return;
    await navigator.clipboard.writeText(input.value);
    showStatus('вң… Markdown е·ІеӨҚеҲ¶', 'success');
  });

  // еӨҚеҲ¶ HTML
  document.getElementById('btn-copy-html')?.addEventListener('click', async () => {
    const html = preview.innerHTML;
    if (!html || html.includes('йў„и§Ҳе°ҶжҳҫзӨәеңЁиҝҷйҮҢ')) return;
    await navigator.clipboard.writeText(html);
    showStatus('вң… HTML е·ІеӨҚеҲ¶', 'success');
  });

  // е…ЁеұҸйў„и§Ҳ
  let isFullscreen = false;
  const btnFullscreen = document.getElementById('btn-fullscreen')!;
  btnFullscreen.addEventListener('click', () => {
    isFullscreen = !isFullscreen;
    if (isFullscreen) {
      split.classList.remove('lg:grid-cols-2');
      split.classList.add('lg:grid-cols-1');
      // йҡҗи—Ҹиҫ“е…ҘеҢә
      (split.children[0] as HTMLElement).style.display = 'none';
      preview.style.height = '80vh';
      btnFullscreen.textContent = 'йҖҖеҮәе…ЁеұҸ';
    } else {
      split.classList.remove('lg:grid-cols-1');
      split.classList.add('lg:grid-cols-2');
      (split.children[0] as HTMLElement).style.display = '';
      preview.style.height = '';
      btnFullscreen.textContent = 'е…ЁеұҸйў„и§Ҳ';
    }
  });

  // еҠ иҪҪзӨәдҫӢ
  document.getElementById('btn-sample')?.addEventListener('click', () => {
    input.value = sampleMarkdown;
    updatePreview();
  });

  // жё…з©ә
  document.getElementById('btn-clear')?.addEventListener('click', () => {
    input.value = '';
    preview.innerHTML = '<p class="text-gray-400 italic">йў„и§Ҳе°ҶжҳҫзӨәеңЁиҝҷйҮҢ...</p>';
  });
</script>
