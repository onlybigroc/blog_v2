---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <textarea id="inp" class="w-full h-40 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="输入文本..."></textarea>
  <div class="flex gap-3 items-center">
    <button id="sort-freq" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">按频率排序</button>
    <button id="sort-alpha" class="px-3 py-1.5 rounded bg-gray-200 dark:bg-gray-700 text-sm">按字符排序</button>
    <span id="total" class="text-sm text-gray-500 ml-auto"></span>
  </div>
  <div id="table-wrap" class="hidden overflow-auto"><table class="w-full text-sm"><thead><tr class="border-b dark:border-gray-700"><th class="text-left py-2 px-2">字符</th><th class="text-right py-2 px-2">次数</th><th class="text-right py-2 px-2">频率</th><th class="py-2 px-2 w-1/3">分布</th></tr></thead><tbody id="tbody"></tbody></table></div>
</div>
<script>
const inp = document.getElementById('inp') as HTMLTextAreaElement;
let data: [string, number][] = [];
let sortBy: 'freq'|'alpha' = 'freq';
function analyze() {
  const text = inp.value;
  if (!text) { document.getElementById('table-wrap')!.classList.add('hidden'); return; }
  const map = new Map<string, number>();
  for (const c of text) map.set(c, (map.get(c) || 0) + 1);
  data = Array.from(map.entries());
  if (sortBy === 'freq') data.sort((a, b) => b[1] - a[1]);
  else data.sort((a, b) => a[0].localeCompare(b[0]));
  const total = text.length;
  const max = data[0]?.[1] || 1;
  document.getElementById('table-wrap')!.classList.remove('hidden');
  document.getElementById('total')!.textContent = `${total} 字符，${data.length} 种`;
  document.getElementById('tbody')!.innerHTML = data.map(([c, n]) => {
    const display = c === ' ' ? '空格' : c === '\n' ? '\\n' : c === '\t' ? '\\t' : c;
    const pct = (n / total * 100).toFixed(1);
    const barW = (n / max * 100);
    return `<tr class="border-b border-gray-100 dark:border-gray-800"><td class="py-1 px-2 font-mono">${display}</td><td class="text-right py-1 px-2">${n}</td><td class="text-right py-1 px-2">${pct}%</td><td class="py-1 px-2"><div class="h-3 rounded bg-primary-200 dark:bg-primary-800" style="width:${barW}%"></div></td></tr>`;
  }).join('');
}
inp.addEventListener('input', analyze);
document.getElementById('sort-freq')!.addEventListener('click', () => { sortBy = 'freq'; analyze(); });
document.getElementById('sort-alpha')!.addEventListener('click', () => { sortBy = 'alpha'; analyze(); });
</script>
