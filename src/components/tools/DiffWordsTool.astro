---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <button id="diff" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">对比差异</button>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">原文</label><textarea id="a" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="输入原文..."></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">修改后</label><textarea id="b" class="w-full h-48 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm" placeholder="输入修改后文本..."></textarea></div>
  </div>
  <div id="result" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-4 font-mono text-sm whitespace-pre-wrap leading-relaxed"></div>
</div>
<script>
import { escapeHtml } from '@utils/safeHtml';

document.getElementById('diff')?.addEventListener('click', () => {
  const wordsA = (document.getElementById('a') as HTMLTextAreaElement).value.split(/(\s+)/);
  const wordsB = (document.getElementById('b') as HTMLTextAreaElement).value.split(/(\s+)/);
  // Simple LCS-based word diff
  const m = wordsA.length, n = wordsB.length;
  const dp = Array.from({length: m+1}, () => Array(n+1).fill(0));
  for (let i = 1; i <= m; i++) for (let j = 1; j <= n; j++)
    dp[i][j] = wordsA[i-1] === wordsB[j-1] ? dp[i-1][j-1]+1 : Math.max(dp[i-1][j], dp[i][j-1]);
  const result: string[] = [];
  let i = m, j = n;
  while (i > 0 || j > 0) {
    if (i > 0 && j > 0 && wordsA[i-1] === wordsB[j-1]) { result.unshift(escapeHtml(wordsA[i-1])); i--; j--; }
    else if (j > 0 && (i === 0 || dp[i][j-1] >= dp[i-1][j])) { result.unshift(`<ins class="bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-0.5 rounded">${escapeHtml(wordsB[j-1])}</ins>`); j--; }
    else { result.unshift(`<del class="bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400 px-0.5 rounded line-through">${escapeHtml(wordsA[i-1])}</del>`); i--; }
  }
  const el = document.getElementById('result')!;
  el.classList.remove('hidden');
  el.innerHTML = result.join('');
});
</script>
