---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (<a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>)}
  <div class="flex gap-3">
    <label class="flex items-center gap-1 text-sm"><input id="case" type="checkbox" class="rounded" /><span class="text-gray-500">忽略大小写</span></label>
    <label class="flex items-center gap-1 text-sm"><input id="trim" type="checkbox" checked class="rounded" /><span class="text-gray-500">去除空白</span></label>
    <button id="dedup" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm font-medium">去重</button>
    <span id="stats" class="text-sm text-gray-500 self-center"></span>
  </div>
  <div class="grid gap-4 lg:grid-cols-2">
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">输入（每行一项）</label><textarea id="inp" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm"></textarea></div>
    <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">去重结果</label><textarea id="out" class="w-full h-64 p-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 text-sm" readonly></textarea></div>
  </div>
</div>
<script>
document.getElementById('dedup')?.addEventListener('click', () => {
  const lines = (document.getElementById('inp') as HTMLTextAreaElement).value.split('\n');
  const ignoreCase = (document.getElementById('case') as HTMLInputElement).checked;
  const doTrim = (document.getElementById('trim') as HTMLInputElement).checked;
  const seen = new Set<string>();
  const result: string[] = [];
  for (const l of lines) {
    const key = ignoreCase ? (doTrim ? l.trim().toLowerCase() : l.toLowerCase()) : (doTrim ? l.trim() : l);
    if (!seen.has(key)) { seen.add(key); result.push(l); }
  }
  (document.getElementById('out') as HTMLTextAreaElement).value = result.join('\n');
  document.getElementById('stats')!.textContent = `原始 ${lines.length} 行 → ${result.length} 行 (移除 ${lines.length - result.length} 重复)`;
});
</script>
