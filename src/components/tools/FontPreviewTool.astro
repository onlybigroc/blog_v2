---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="flex flex-wrap gap-3">
    <input id="text" type="text" class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" value="The quick brown fox jumps over the lazy dog" />
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">大小</span><input id="size" type="range" min="8" max="72" value="24" class="w-24" /><span id="size-val" class="w-8 text-sm">24</span></label>
    <label class="flex items-center gap-1 text-sm"><span class="text-gray-500">字重</span><select id="weight" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm"><option value="400">Regular</option><option value="600">Semi Bold</option><option value="700">Bold</option><option value="300">Light</option></select></label>
  </div>
  <div class="space-y-4">
    <div id="fonts" class="space-y-3"></div>
  </div>
</div>
<script>
const fonts = [
  { name: 'Serif', family: 'Georgia, "Times New Roman", serif' },
  { name: 'Sans-Serif', family: 'system-ui, -apple-system, sans-serif' },
  { name: 'Monospace', family: '"Courier New", Courier, monospace' },
  { name: 'Cursive', family: '"Brush Script MT", cursive' },
  { name: 'Fantasy', family: 'Impact, "Comic Sans MS", fantasy' },
  { name: 'System UI', family: 'system-ui, sans-serif' },
  { name: 'Arial', family: 'Arial, Helvetica, sans-serif' },
  { name: 'Verdana', family: 'Verdana, Geneva, sans-serif' },
  { name: 'Trebuchet', family: '"Trebuchet MS", sans-serif' },
  { name: 'Palatino', family: '"Palatino Linotype", "Book Antiqua", serif' },
  { name: 'Garamond', family: 'Garamond, serif' },
  { name: 'Courier New', family: '"Courier New", monospace' },
];

function render() {
  const text = (document.getElementById('text') as HTMLInputElement).value;
  const size = parseInt((document.getElementById('size') as HTMLInputElement).value);
  const weight = (document.getElementById('weight') as HTMLSelectElement).value;
  document.getElementById('size-val')!.textContent = String(size);
  document.getElementById('fonts')!.innerHTML = fonts.map(f =>
    `<div class="rounded-lg border border-gray-200 dark:border-gray-700 p-4">
      <div class="text-xs text-gray-500 mb-2">${f.name} <span class="font-mono">${f.family.split(',')[0]}</span></div>
      <div style="font-family:${f.family};font-size:${size}px;font-weight:${weight};line-height:1.4">${text}</div>
    </div>`
  ).join('');
}

document.getElementById('text')?.addEventListener('input', render);
document.getElementById('size')?.addEventListener('input', render);
document.getElementById('weight')?.addEventListener('change', render);
render();
</script>
