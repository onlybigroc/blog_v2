---
import type { ToolWrapperProps } from '../../types/tool';
import ToolCleanLink from './ToolCleanLink.astro';

interface Props extends ToolWrapperProps {}
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && <ToolCleanLink cleanPath={cleanPath} />}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-4">
      <div class="flex gap-2 mb-2">
        <button class="preset px-2 py-1 rounded text-xs bg-gray-200 dark:bg-gray-700" data-v="8">圆角</button>
        <button class="preset px-2 py-1 rounded text-xs bg-gray-200 dark:bg-gray-700" data-v="50">圆形</button>
        <button class="preset px-2 py-1 rounded text-xs bg-gray-200 dark:bg-gray-700" data-v="0">直角</button>
      </div>
      <label class="flex items-center gap-2 text-sm cursor-pointer"><input id="link" type="checkbox" class="rounded" checked /><span class="text-gray-500">联动四角</span></label>
      <div><label class="block text-sm text-gray-500 mb-1">左上: <span id="tl-val">16</span>%</label><input id="tl" type="range" min="0" max="50" value="16" class="w-full" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">右上: <span id="tr-val">16</span>%</label><input id="tr" type="range" min="0" max="50" value="16" class="w-full" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">右下: <span id="br-val">16</span>%</label><input id="br" type="range" min="0" max="50" value="16" class="w-full" /></div>
      <div><label class="block text-sm text-gray-500 mb-1">左下: <span id="bl-val">16</span>%</label><input id="bl" type="range" min="0" max="50" value="16" class="w-full" /></div>
    </div>
    <div class="space-y-4">
      <div class="flex items-center justify-center h-48 rounded-lg bg-gray-100 dark:bg-gray-800"><div id="preview" class="w-32 h-32 bg-primary-400"></div></div>
      <div class="relative"><pre id="code" class="p-3 rounded-lg bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-700 text-sm font-mono"></pre><button id="copy" class="absolute top-2 right-2 px-2 py-1 text-xs rounded bg-gray-200 dark:bg-gray-700">复制</button></div>
    </div>
  </div>
</div>
<script>
function update() {
  const tl = parseInt((document.getElementById('tl') as HTMLInputElement).value);
  const tr = parseInt((document.getElementById('tr') as HTMLInputElement).value);
  const br = parseInt((document.getElementById('br') as HTMLInputElement).value);
  const bl = parseInt((document.getElementById('bl') as HTMLInputElement).value);
  ['tl','tr','br','bl'].forEach(k => document.getElementById(k+'-val')!.textContent = eval(k).toString());
  const value = `${tl}% ${tr}% ${br}% ${bl}%`;
  document.getElementById('preview')!.style.borderRadius = value;
  document.getElementById('code')!.textContent = `border-radius: ${value};`;
}
['tl','tr','br','bl'].forEach(k => document.getElementById(k)?.addEventListener('input', (e) => {
  if ((document.getElementById('link') as HTMLInputElement).checked) {
    const v = (e.target as HTMLInputElement).value;
    ['tl','tr','br','bl'].forEach(kk => { if (kk !== k) (document.getElementById(kk) as HTMLInputElement).value = v; });
  }
  update();
}));
document.querySelectorAll('.preset').forEach(btn => btn.addEventListener('click', () => {
  const v = (btn as HTMLElement).dataset.v!;
  ['tl','tr','br','bl'].forEach(k => (document.getElementById(k) as HTMLInputElement).value = v);
  update();
}));
document.getElementById('copy')?.addEventListener('click', () => navigator.clipboard.writeText(document.getElementById('code')!.textContent!));
update();
</script>
