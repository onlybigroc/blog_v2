---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="flex flex-wrap items-center gap-3">
    <label class="text-sm text-gray-600 dark:text-gray-400">DPI</label>
    <input id="dpi" type="number" value="96" class="w-20 rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm" />
    <label class="text-sm text-gray-600 dark:text-gray-400">方向</label>
    <select id="orient" class="rounded border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-2 py-1 text-sm">
      <option value="h">水平</option>
      <option value="v">垂直</option>
    </select>
  </div>
  <div class="overflow-auto p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700">
    <canvas id="ruler" class="mx-auto"></canvas>
  </div>
  <p class="text-sm text-gray-500 text-center">使用信用卡（85.6mm × 53.98mm）校准 DPI 以获得精确测量。</p>
</div>
<script>
const canvas = document.getElementById('ruler') as HTMLCanvasElement;
const ctx = canvas.getContext('2d')!;
function draw() {
  const dpi = parseInt((document.getElementById('dpi') as HTMLInputElement).value) || 96;
  const vert = (document.getElementById('orient') as HTMLSelectElement).value === 'v';
  const len = vert ? 400 : 600;
  const pxPerCm = dpi / 2.54;
  canvas.width = vert ? 60 : len;
  canvas.height = vert ? len : 60;
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  ctx.fillStyle = '#fff'; ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.strokeStyle = '#374151'; ctx.fillStyle = '#374151'; ctx.font = '10px sans-serif';
  const cmCount = Math.floor(len / pxPerCm);
  for (let i = 0; i <= cmCount; i++) {
    const pos = i * pxPerCm;
    if (vert) {
      ctx.beginPath(); ctx.moveTo(40, pos); ctx.lineTo(60, pos); ctx.stroke();
      ctx.fillText(i + '', 25, pos + 4);
      ctx.beginPath(); ctx.moveTo(50, pos + pxPerCm / 2); ctx.lineTo(60, pos + pxPerCm / 2); ctx.stroke();
      for (let m = 1; m < 10; m++) { if (m === 5) continue; ctx.beginPath(); ctx.moveTo(55, pos + pxPerCm * m / 10); ctx.lineTo(60, pos + pxPerCm * m / 10); ctx.stroke(); }
    } else {
      ctx.beginPath(); ctx.moveTo(pos, 0); ctx.lineTo(pos, 20); ctx.stroke();
      ctx.fillText(i + '', pos + 2, 35);
      ctx.beginPath(); ctx.moveTo(pos + pxPerCm / 2, 0); ctx.lineTo(pos + pxPerCm / 2, 10); ctx.stroke();
      for (let m = 1; m < 10; m++) { if (m === 5) continue; ctx.beginPath(); ctx.moveTo(pos + pxPerCm * m / 10, 0); ctx.lineTo(pos + pxPerCm * m / 10, 5); ctx.stroke(); }
    }
  }
}
document.getElementById('dpi')?.addEventListener('input', draw);
document.getElementById('orient')?.addEventListener('change', draw);
draw();
</script>
