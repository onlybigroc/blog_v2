---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="grid gap-6 md:grid-cols-2">
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">身高 (cm)</label>
        <input id="height" type="number" value="170" min="50" max="250" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
      </div>
      <div>
        <label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">体重 (kg)</label>
        <input id="weight" type="number" value="65" min="10" max="300" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" />
      </div>
      <button id="calc" class="w-full px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">计算 BMI</button>
    </div>
    <div class="space-y-4">
      <div id="result-card" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-6 text-center space-y-3">
        <div class="text-4xl font-bold" id="bmi-value"></div>
        <div id="bmi-category" class="text-lg font-medium"></div>
        <div class="relative h-4 rounded-full overflow-hidden bg-gradient-to-r from-blue-400 via-green-400 via-yellow-400 to-red-500">
          <div id="bmi-marker" class="absolute top-0 w-1 h-full bg-black dark:bg-white shadow transition-all"></div>
        </div>
        <div class="flex justify-between text-xs text-gray-500"><span>偏瘦&lt;18.5</span><span>正常18.5-24</span><span>偏胖24-28</span><span>肥胖&gt;28</span></div>
        <div id="bmi-tip" class="text-sm text-gray-600 dark:text-gray-400"></div>
      </div>
    </div>
  </div>
</div>
<script>
document.getElementById('calc')?.addEventListener('click', () => {
  const h = parseFloat((document.getElementById('height') as HTMLInputElement).value) / 100;
  const w = parseFloat((document.getElementById('weight') as HTMLInputElement).value);
  if (h <= 0 || w <= 0) return;
  const bmi = w / (h * h);
  const card = document.getElementById('result-card')!;
  card.classList.remove('hidden');
  document.getElementById('bmi-value')!.textContent = bmi.toFixed(1);
  let cat = '', color = '', tip = '';
  if (bmi < 18.5) { cat = '偏瘦'; color = 'text-blue-600 dark:text-blue-400'; tip = '建议适当增加营养摄入，加强力量训练。'; }
  else if (bmi < 24) { cat = '正常'; color = 'text-green-600 dark:text-green-400'; tip = '体重正常，请继续保持健康的生活方式！'; }
  else if (bmi < 28) { cat = '偏胖'; color = 'text-yellow-600 dark:text-yellow-400'; tip = '建议控制饮食，增加有氧运动。'; }
  else { cat = '肥胖'; color = 'text-red-600 dark:text-red-400'; tip = '建议咨询医生，制定科学的减重计划。'; }
  const el = document.getElementById('bmi-category')!;
  el.textContent = cat; el.className = `text-lg font-medium ${color}`;
  document.getElementById('bmi-tip')!.textContent = tip;
  const pct = Math.min(100, Math.max(0, ((bmi - 15) / 25) * 100));
  document.getElementById('bmi-marker')!.style.left = `calc(${pct}% - 2px)`;
});
</script>
