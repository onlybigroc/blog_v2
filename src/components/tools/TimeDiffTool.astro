---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="space-y-4">
    <div class="grid gap-4 md:grid-cols-3">
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">开始时间</label><input id="t1" type="time" step="1" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" /></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">结束时间</label><input id="t2" type="time" step="1" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" /></div>
      <div class="flex items-end"><button id="calc" class="w-full px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">计算</button></div>
    </div>
    <div id="result" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-4 space-y-2 text-sm"></div>
  </div>
</div>
<script>
document.getElementById('calc')?.addEventListener('click', () => {
  const parse = (s: string) => { const [h,m,sec] = s.split(':').map(Number); return h*3600+m*60+(sec||0); };
  const t1 = parse((document.getElementById('t1') as HTMLInputElement).value);
  const t2 = parse((document.getElementById('t2') as HTMLInputElement).value);
  if (isNaN(t1) || isNaN(t2)) return;
  const diff = t2 >= t1 ? t2 - t1 : 86400 - t1 + t2;
  const h = Math.floor(diff / 3600), m = Math.floor((diff % 3600) / 60), s = diff % 60;
  const el = document.getElementById('result')!;
  el.classList.remove('hidden');
  el.innerHTML = `<div class="flex justify-between"><span>时间差</span><span class="font-bold text-lg">${h}小时 ${m}分 ${s}秒</span></div><div class="flex justify-between"><span>总秒数</span><span>${diff} 秒</span></div><div class="flex justify-between"><span>总分钟</span><span>${(diff/60).toFixed(2)} 分钟</span></div>`;
});
</script>
