---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="flex items-center gap-3">
    <input id="name-input" type="text" class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" placeholder="添加选手名称..." />
    <button id="add-player" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">添加</button>
    <button id="reset" class="px-4 py-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-sm font-medium">重置</button>
  </div>
  <div id="board" class="space-y-2"></div>
  <div id="empty" class="text-center text-gray-500 py-8">添加选手开始计分</div>
</div>
<script>
interface Player { name: string; score: number; }
const players: Player[] = [];
const board = document.getElementById('board')!;
const empty = document.getElementById('empty')!;
const colors = ['#3b82f6','#ef4444','#22c55e','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316'];

function render() {
  empty.style.display = players.length ? 'none' : '';
  const sorted = [...players].sort((a, b) => b.score - a.score);
  board.innerHTML = sorted.map((p, i) => {
    const ci = players.indexOf(p);
    return `<div class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 dark:border-gray-700 ${i===0&&p.score>0?'bg-yellow-50 dark:bg-yellow-900/10 border-yellow-300 dark:border-yellow-700':''}">
      <span class="w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold" style="background:${colors[ci%colors.length]}">${p.name[0]}</span>
      <span class="flex-1 font-medium">${p.name}</span>
      <span class="text-2xl font-bold w-16 text-center">${p.score}</span>
      <div class="flex gap-1">
        <button class="score-btn w-8 h-8 rounded bg-gray-100 dark:bg-gray-800 hover:bg-green-100 dark:hover:bg-green-900/30 text-sm font-bold" data-idx="${ci}" data-d="1">+1</button>
        <button class="score-btn w-8 h-8 rounded bg-gray-100 dark:bg-gray-800 hover:bg-green-100 dark:hover:bg-green-900/30 text-sm font-bold" data-idx="${ci}" data-d="5">+5</button>
        <button class="score-btn w-8 h-8 rounded bg-gray-100 dark:bg-gray-800 hover:bg-red-100 dark:hover:bg-red-900/30 text-sm font-bold" data-idx="${ci}" data-d="-1">-1</button>
      </div>
    </div>`;
  }).join('');
  board.querySelectorAll('.score-btn').forEach(btn => btn.addEventListener('click', () => {
    const idx = parseInt((btn as HTMLElement).dataset.idx!);
    players[idx].score += parseInt((btn as HTMLElement).dataset.d!);
    render();
  }));
}

document.getElementById('add-player')?.addEventListener('click', () => {
  const input = document.getElementById('name-input') as HTMLInputElement;
  const name = input.value.trim();
  if (!name) return;
  players.push({ name, score: 0 });
  input.value = '';
  render();
});
(document.getElementById('name-input') as HTMLInputElement).addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('add-player')?.click(); });
document.getElementById('reset')?.addEventListener('click', () => { players.forEach(p => p.score = 0); render(); });
</script>
