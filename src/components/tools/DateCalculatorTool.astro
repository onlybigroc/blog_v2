---
interface Props { cleanPath?: string; showCleanLink?: boolean; }
const { cleanPath, showCleanLink = false } = Astro.props;
---
<div class="space-y-6">
  {showCleanLink && cleanPath && (
    <a href={cleanPath} title="独立打开" class="mb-4 inline-flex shrink-0 items-center justify-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium transition-colors hover:bg-gray-50 dark:border-gray-600 dark:hover:bg-gray-800">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4m8 0h4v4M4 16v4h4m12-4v4h-4" /></svg>独立打开</a>
  )}
  <div class="border-b border-gray-200 dark:border-gray-700">
    <nav class="flex gap-4">
      <button class="tab-btn py-2 text-sm font-medium border-b-2 border-primary-600 text-primary-600" data-tab="diff">日期差</button>
      <button class="tab-btn py-2 text-sm font-medium border-b-2 border-transparent text-gray-500" data-tab="add">加减天数</button>
    </nav>
  </div>
  <div id="tab-diff" class="space-y-4">
    <div class="grid gap-4 md:grid-cols-2">
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">开始日期</label><input id="d1" type="date" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" /></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">结束日期</label><input id="d2" type="date" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" /></div>
    </div>
    <button id="calc-diff" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm font-medium">计算</button>
    <div id="diff-result" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-4 space-y-2 text-sm"></div>
  </div>
  <div id="tab-add" class="hidden space-y-4">
    <div class="grid gap-4 md:grid-cols-2">
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">起始日期</label><input id="base-date" type="date" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" /></div>
      <div><label class="block text-sm font-medium mb-1 text-gray-700 dark:text-gray-300">天数</label><div class="flex gap-2"><input id="days-input" type="number" value="30" class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-3 py-2 text-sm" /><button id="calc-add" class="px-4 py-2 rounded-lg bg-primary-600 text-white hover:bg-primary-700 text-sm">计算</button></div></div>
    </div>
    <div id="add-result" class="hidden rounded-lg border border-gray-200 dark:border-gray-700 p-4 text-sm"></div>
  </div>
</div>
<script>
document.querySelectorAll('.tab-btn').forEach(btn => btn.addEventListener('click', () => {
  document.querySelectorAll('.tab-btn').forEach(b => b.className = 'tab-btn py-2 text-sm font-medium border-b-2 border-transparent text-gray-500');
  btn.className = 'tab-btn py-2 text-sm font-medium border-b-2 border-primary-600 text-primary-600';
  document.getElementById('tab-diff')?.classList.toggle('hidden', (btn as HTMLElement).dataset.tab !== 'diff');
  document.getElementById('tab-add')?.classList.toggle('hidden', (btn as HTMLElement).dataset.tab !== 'add');
}));

document.getElementById('calc-diff')?.addEventListener('click', () => {
  const d1 = new Date((document.getElementById('d1') as HTMLInputElement).value);
  const d2 = new Date((document.getElementById('d2') as HTMLInputElement).value);
  if (isNaN(d1.getTime()) || isNaN(d2.getTime())) return;
  const diffMs = Math.abs(d2.getTime() - d1.getTime());
  const days = Math.floor(diffMs / 86400000);
  const weeks = Math.floor(days / 7);
  const el = document.getElementById('diff-result')!;
  el.classList.remove('hidden');
  el.innerHTML = `<div class="flex justify-between"><span>天数</span><span class="font-bold">${days.toLocaleString()} 天</span></div><div class="flex justify-between"><span>周数</span><span>${weeks} 周余 ${days % 7} 天</span></div><div class="flex justify-between"><span>小时</span><span>${(days * 24).toLocaleString()} 小时</span></div><div class="flex justify-between"><span>分钟</span><span>${(days * 24 * 60).toLocaleString()} 分钟</span></div>`;
});

document.getElementById('calc-add')?.addEventListener('click', () => {
  const base = new Date((document.getElementById('base-date') as HTMLInputElement).value);
  const days = parseInt((document.getElementById('days-input') as HTMLInputElement).value) || 0;
  if (isNaN(base.getTime())) return;
  const result = new Date(base.getTime() + days * 86400000);
  const el = document.getElementById('add-result')!;
  el.classList.remove('hidden');
  const weekdays = ['日','一','二','三','四','五','六'];
  el.textContent = `${days >= 0 ? '加' : '减'} ${Math.abs(days)} 天后: ${result.getFullYear()}年${result.getMonth()+1}月${result.getDate()}日 星期${weekdays[result.getDay()]}`;
});
</script>
