---
interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<button
  data-page-like-button
  class:list={[
    'group flex items-center gap-3 px-6 py-3 rounded-full transition-all duration-300 hover:scale-110 bg-gray-100 dark:bg-gray-800 hover:bg-red-50 dark:hover:bg-red-900/20',
    className,
  ]}
  aria-label="喜欢"
>
  <svg
    data-page-like-icon
    class="w-6 h-6 transition-colors duration-300 text-gray-400 group-hover:text-red-500"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
  </svg>
  <span data-page-like-count class="font-medium text-gray-700 dark:text-gray-300">0</span>
</button>

<script>
  import { formatCount, getPostStats, toggleLike } from '@utils/stats';

  const INIT_FLAG = '__blogPageLikeButtonInit__';

  function normalizePath(pathname: string) {
    if (!pathname || pathname === '/') {
      return '/';
    }
    const trimmed = pathname.replace(/\/+$/, '');
    return trimmed || '/';
  }

  function applyLikeState(stats: { likes?: number; liked?: boolean }, likeCountEl: Element | null, likeIcon: Element | null) {
    if (likeCountEl) {
      likeCountEl.textContent = formatCount(stats.likes || 0);
    }
    if (likeIcon) {
      likeIcon.classList.toggle('liked', !!stats.liked);
    }
  }

  async function initPageLikeButton() {
    const likeButton = document.querySelector('[data-page-like-button]');
    if (!likeButton) return;

    const likeCountEl = likeButton.querySelector('[data-page-like-count]');
    const likeIcon = likeButton.querySelector('[data-page-like-icon]');
    const pageId = `page:${normalizePath(window.location.pathname)}`;

    const localStats = getPostStats(pageId);
    applyLikeState(localStats, likeCountEl, likeIcon);

    likeButton.addEventListener('click', async () => {
      const newStats = await toggleLike(pageId);
      applyLikeState(newStats, likeCountEl, likeIcon);

      if (newStats.liked) {
        likeButton.classList.add('scale-125');
        setTimeout(() => likeButton.classList.remove('scale-125'), 200);
      }
    });
  }

  if (!(window as any)[INIT_FLAG]) {
    (window as any)[INIT_FLAG] = true;

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        void initPageLikeButton();
      }, { once: true });
    } else {
      void initPageLikeButton();
    }
  }
</script>

<style>
  [data-page-like-icon].liked {
    fill: currentColor !important;
    color: #ef4444 !important;
  }
</style>
