---
import { getPostPath } from '@utils/slug';

interface Props {
  prevPost?: any;
  nextPost?: any;
}

const { prevPost, nextPost } = Astro.props;
---

<nav class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
  {prevPost ? (
    <a
      href={getPostPath(prevPost)}
      class="group p-4 rounded-lg border border-gray-200 transition-all hover:shadow-md hover:border-primary-500 dark:border-gray-700 dark:hover:border-primary-500"
    >
      <div class="text-sm text-gray-500 mb-1 dark:text-gray-400">← 上一篇</div>
      <div class="font-medium text-gray-900 transition line-clamp-2 group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
        {prevPost.data.title}
      </div>
    </a>
  ) : (
    <div class="p-4 rounded-lg border border-gray-200 opacity-50 dark:border-gray-700">
      <div class="text-sm text-gray-500 mb-1 dark:text-gray-400">← 上一篇</div>
      <div class="text-gray-400 dark:text-gray-600">已经是最早文章</div>
    </div>
  )}

  {nextPost ? (
    <a
      href={getPostPath(nextPost)}
      class="group p-4 rounded-lg border border-gray-200 text-right transition-all hover:shadow-md hover:border-primary-500 dark:border-gray-700 dark:hover:border-primary-500"
    >
      <div class="text-sm text-gray-500 mb-1 dark:text-gray-400">下一篇 →</div>
      <div class="font-medium text-gray-900 transition line-clamp-2 group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
        {nextPost.data.title}
      </div>
    </a>
  ) : (
    <div class="p-4 rounded-lg border border-gray-200 opacity-50 text-right dark:border-gray-700">
      <div class="text-sm text-gray-500 mb-1 dark:text-gray-400">下一篇 →</div>
      <div class="text-gray-400 dark:text-gray-600">已经是最新文章</div>
    </div>
  )}
</nav>
