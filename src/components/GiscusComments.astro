---
interface Props {
  title?: string;
  className?: string;
}

const { title = '💬 评论', className = '' } = Astro.props;
---

<div class:list={['max-w-4xl mx-auto mt-12', className]}>
  <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">{title}</h2>
  <div class="giscus-container">
    <script src="https://giscus.app/client.js"
      data-repo="onlybigroc/blog_v2"
      data-repo-id="R_kgDOQcdPKA"
      data-category="General"
      data-category-id="DIC_kwDOQcdPKM4Cy-ek"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="preferred_color_scheme"
      data-lang="zh-CN"
      crossorigin="anonymous"
      async>
    </script>
  </div>
</div>

<style>
  .giscus-container {
    border-radius: 0.5rem;
  }
</style>
