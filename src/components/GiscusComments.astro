---
interface Props {
  title?: string;
  className?: string;
}

const { title = '评论', className = '' } = Astro.props;
const containerId = `giscus-${Math.random().toString(36).slice(2, 10)}`;
---

<div class:list={['max-w-4xl mx-auto mt-12', className]}>
  <h2 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">{title}</h2>
  <div id={containerId} class="giscus-container">
    <p class="text-sm text-gray-500 dark:text-gray-400">滚动到评论区域时再加载第三方评论脚本。</p>
  </div>
</div>

<script is:inline define:vars={{ containerId }}>
  const container = document.getElementById(containerId);

  const mountGiscus = () => {
    if (!container || container.dataset.loaded === 'true') {
      return;
    }

    container.dataset.loaded = 'true';
    container.replaceChildren();

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.async = true;
    script.crossOrigin = 'anonymous';
    script.setAttribute('data-repo', 'onlybigroc/blog_v2');
    script.setAttribute('data-repo-id', 'R_kgDOQcdPKA');
    script.setAttribute('data-category', 'General');
    script.setAttribute('data-category-id', 'DIC_kwDOQcdPKM4Cy-ek');
    script.setAttribute('data-mapping', 'pathname');
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'bottom');
    script.setAttribute('data-theme', 'preferred_color_scheme');
    script.setAttribute('data-lang', 'zh-CN');
    container.appendChild(script);
  };

  if (container && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        if (entries.some((entry) => entry.isIntersecting)) {
          observer.disconnect();
          mountGiscus();
        }
      },
      {
        rootMargin: '400px 0px',
      },
    );

    observer.observe(container);
  } else {
    mountGiscus();
  }
</script>

<style>
  .giscus-container {
    border-radius: 0.5rem;
  }
</style>
