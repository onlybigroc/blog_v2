---
import type { AINewsItem } from '@data/aiNews';
import { formatChineseDateTime } from '@utils/site';

interface Props {
  item: AINewsItem;
  compact?: boolean;
}

const { item, compact = false } = Astro.props;
const formattedDate = formatChineseDateTime(item.publishedAt);
const archiveHref = `/ai-news/${item.id}`;
const regionLabel = item.sourceRegion === 'cn' ? '中文' : '国际';
const displayImage = item.coverImage || item.coverImageOriginal;
const coverImageWidth = item.coverImageWidth || 600;
const coverImageHeight = item.coverImageHeight || 400;

const importanceStyles = {
  '重点': 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300',
  '关注': 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300',
  '快讯': 'bg-sky-100 text-sky-700 dark:bg-sky-900/30 dark:text-sky-300',
} as const;

const regionStyles = {
  cn: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300',
  global: 'bg-violet-100 text-violet-700 dark:bg-violet-900/30 dark:text-violet-300',
} as const;
---

{compact ? (
  <article class="animate-on-scroll glass-card rounded-2xl p-5 dark:border-gray-800">
    {displayImage && (
      <a href={archiveHref} class="mb-4 block overflow-hidden rounded-xl border border-gray-200 dark:border-gray-800">
        <img
          src={displayImage}
          alt={item.coverImageAlt || item.titleZh || item.title}
          width={coverImageWidth}
          height={coverImageHeight}
          class="h-44 w-full object-cover transition duration-300 hover:scale-[1.02]"
          loading="lazy"
        />
      </a>
    )}

    <div class="mb-3 flex flex-wrap items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
      <span class:list={['rounded-full px-2.5 py-1 text-xs font-medium', importanceStyles[item.importance]]}>
        {item.importance}
      </span>
      <span class:list={['rounded-full px-2.5 py-1 text-xs font-medium', regionStyles[item.sourceRegion]]}>
        {regionLabel}
      </span>
      <span>{item.source}</span>
    </div>

    <h3 class="text-xl font-bold leading-8">
      <a href={archiveHref} class="text-primary-600 hover:underline dark:text-primary-400">
        {item.titleZh || item.title}
      </a>
    </h3>

    <div class="mt-3 flex flex-wrap gap-4 text-sm text-gray-600 dark:text-gray-400">
      <time datetime={item.publishedAt}>{formattedDate}</time>
    </div>

    {item.summaryZh && item.summaryZh !== item.summary ? (
      <p class="mt-3 line-clamp-4 text-sm leading-7 text-gray-700 dark:text-gray-300">{item.summaryZh}</p>
    ) : item.summary ? (
      <p class="mt-3 line-clamp-4 text-sm leading-7 text-gray-700 dark:text-gray-300">{item.summary}</p>
    ) : null}

    <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
      <div class="flex flex-wrap gap-2">
        {item.tags.slice(0, 3).map((tag) => (
          <span class="rounded-full bg-primary-50 px-2.5 py-1 text-xs text-primary-700 dark:bg-primary-900/30 dark:text-primary-300">
            {tag}
          </span>
        ))}
      </div>

      <a href={archiveHref} class="text-sm text-primary-600 hover:underline dark:text-primary-400">
        阅读全文 →
      </a>
    </div>
  </article>
) : (
  <article class="animate-on-scroll glass-card rounded-xl p-6 last:mb-0">
    <div class:list={['gap-6', displayImage ? 'grid md:grid-cols-[minmax(0,1fr)_220px] md:items-start' : 'block']}>
      <div>
        <h3 class="text-2xl font-bold mb-2">
          <a href={archiveHref} class="text-primary-600 hover:underline dark:text-primary-400">
            {item.titleZh || item.title}
          </a>
        </h3>

        {item.titleZh && item.titleZh !== item.title && (
          <p class="mb-2 text-sm leading-7 text-gray-500 dark:text-gray-400">{item.title}</p>
        )}

        <div class="mb-3 flex flex-wrap gap-4 text-sm text-gray-600 dark:text-gray-400">
          <time datetime={item.publishedAt}>{formattedDate}</time>
          <span>{item.source}</span>
          <span class:list={['rounded-full px-2 py-0.5 text-xs font-medium', importanceStyles[item.importance]]}>
            {item.importance}
          </span>
          <span class:list={['rounded-full px-2 py-0.5 text-xs font-medium', regionStyles[item.sourceRegion]]}>
            {regionLabel}
          </span>
        </div>

        {item.tags.length > 0 && (
          <div class="mb-3 flex flex-wrap gap-2">
            {item.tags.map((tag) => (
              <span class="px-2 py-1 rounded text-xs bg-primary-100 text-primary-700 dark:bg-primary-900/30 dark:text-primary-300">
                {tag}
              </span>
            ))}
          </div>
        )}

        {item.summaryZh && item.summaryZh !== item.summary ? (
          <p class="text-gray-700 mb-3 line-clamp-3 dark:text-gray-300">{item.summaryZh}</p>
        ) : item.summary ? (
          <p class="text-gray-700 mb-3 line-clamp-3 dark:text-gray-300">{item.summary}</p>
        ) : null}

        <div class="flex flex-wrap items-center gap-4">
          <a href={archiveHref} class="text-primary-600 hover:underline text-sm dark:text-primary-400">
            阅读全文 →
          </a>
          <a
            href={item.link}
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary-600 hover:underline text-sm dark:text-primary-400"
          >
            原文链接 →
          </a>
        </div>
      </div>

      {displayImage && (
        <a href={archiveHref} class="block overflow-hidden rounded-xl border border-gray-200 dark:border-gray-800">
          <img
            src={displayImage}
            alt={item.coverImageAlt || item.titleZh || item.title}
            width={coverImageWidth}
            height={coverImageHeight}
            class="h-40 w-full object-cover"
            loading="lazy"
          />
        </a>
      )}
    </div>
  </article>
)}
